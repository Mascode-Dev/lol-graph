@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix lol:   <http://leagueoflegends.knowledge/ontology#> .
@prefix champ: <http://leagueoflegends.knowledge/champion/> .
@prefix spell: <http://leagueoflegends.knowledge/spell/> .
@prefix skin:  <http://leagueoflegends.knowledge/skin/> .
@prefix role:  <http://leagueoflegends.knowledge/role/> .
@prefix res:   <http://leagueoflegends.knowledge/resource/> .

# ============================================================
# ONTOLOGY DECLARATION
# ============================================================
<http://leagueoflegends.knowledge/ontology>
    a owl:Ontology ;
    rdfs:label "League of Legends Knowledge Graph"@en ;
    rdfs:comment "OWL ontology for League of Legends champions, spells, skins, and game mechanics. Version 16.5.1"@en ;
    owl:versionInfo "1.0.0" .

# ============================================================
# CLASSES
# ============================================================

lol:Champion a owl:Class ;
    rdfs:label "Champion"@en ;
    rdfs:comment "A playable character in League of Legends."@en .

lol:Spell a owl:Class ;
    rdfs:label "Spell"@en ;
    rdfs:comment "An ability that a Champion can use in game."@en .

lol:ActiveSpell a owl:Class ;
    rdfs:subClassOf lol:Spell ;
    rdfs:label "Active Spell"@en ;
    rdfs:comment "A spell that must be actively activated (Q, W, E, R)."@en .

lol:PassiveAbility a owl:Class ;
    rdfs:subClassOf lol:Spell ;
    rdfs:label "Passive Ability"@en ;
    rdfs:comment "A passive ability that triggers automatically."@en .

lol:Skin a owl:Class ;
    rdfs:label "Skin"@en ;
    rdfs:comment "A cosmetic variant of a Champion."@en .

lol:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:comment "A champion role/class (Fighter, Mage, Tank, etc.)."@en .

lol:ResourceType a owl:Class ;
    rdfs:label "Resource Type"@en ;
    rdfs:comment "The type of resource a champion uses for abilities (Mana, Energy, Blood Well, etc.)."@en .

lol:BaseStats a owl:Class ;
    rdfs:label "Base Stats"@en ;
    rdfs:comment "The base combat statistics of a champion at level 1."@en .

lol:InfoRating a owl:Class ;
    rdfs:label "Info Rating"@en ;
    rdfs:comment "Riot's difficulty/playstyle ratings for a champion."@en .

# ============================================================
# OBJECT PROPERTIES
# ============================================================

lol:hasRole a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:Role ;
    rdfs:label "has role"@en ;
    rdfs:comment "Associates a champion with one or more gameplay roles."@en .

lol:hasResourceType a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:ResourceType ;
    rdfs:label "has resource type"@en ;
    rdfs:comment "The resource type used by a champion's abilities."@en .

lol:hasSpell a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:Spell ;
    rdfs:label "has spell"@en ;
    rdfs:comment "Links a champion to one of its active spells."@en .

lol:hasPassive a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:PassiveAbility ;
    rdfs:label "has passive"@en ;
    rdfs:comment "Links a champion to its passive ability."@en .

lol:hasSkin a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:Skin ;
    rdfs:label "has skin"@en ;
    rdfs:comment "Links a champion to one of its cosmetic skins."@en .

lol:hasStats a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:BaseStats ;
    rdfs:label "has stats"@en ;
    rdfs:comment "Links a champion to its base statistics."@en .

lol:hasInfoRating a owl:ObjectProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range lol:InfoRating ;
    rdfs:label "has info rating"@en .

lol:belongsToChampion a owl:ObjectProperty ;
    owl:inverseOf lol:hasSpell ;
    rdfs:domain lol:Spell ;
    rdfs:range lol:Champion ;
    rdfs:label "belongs to champion"@en .

# ============================================================
# DATATYPE PROPERTIES
# ============================================================

# -- Champion core --
lol:championId a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "champion ID"@en .

lol:championKey a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "champion key"@en ;
    rdfs:comment "Numeric key used by Riot API."@en .

lol:championName a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "champion name"@en .

lol:championTitle a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "champion title"@en .

lol:lore a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "lore"@en .

lol:blurb a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "blurb"@en .

lol:allyTip a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "ally tip"@en .

lol:enemyTip a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "enemy tip"@en .

lol:dataVersion a owl:DatatypeProperty ;
    rdfs:domain lol:Champion ;
    rdfs:range xsd:string ;
    rdfs:label "data version"@en .

# -- Base Stats --
lol:hp a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base HP"@en .

lol:hpPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "HP per level"@en .

lol:mp a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base MP"@en .

lol:mpPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "MP per level"@en .

lol:movespeed a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "movement speed"@en .

lol:armor a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base armor"@en .

lol:armorPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "armor per level"@en .

lol:spellblock a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base magic resist"@en .

lol:spellblockPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "magic resist per level"@en .

lol:attackrange a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "attack range"@en .

lol:hpregen a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base HP regen"@en .

lol:hpregenPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "HP regen per level"@en .

lol:mpregen a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base MP regen"@en .

lol:mpregenPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "MP regen per level"@en .

lol:attackdamage a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base attack damage"@en .

lol:attackdamagePerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "attack damage per level"@en .

lol:attackspeed a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base attack speed"@en .

lol:attackspeedPerLevel a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "attack speed per level"@en .

lol:crit a owl:DatatypeProperty ;
    rdfs:domain lol:BaseStats ;
    rdfs:range xsd:double ;
    rdfs:label "base crit chance"@en .

# -- InfoRating --
lol:attackRating a owl:DatatypeProperty ;
    rdfs:domain lol:InfoRating ;
    rdfs:range xsd:integer ;
    rdfs:label "attack rating"@en .

lol:defenseRating a owl:DatatypeProperty ;
    rdfs:domain lol:InfoRating ;
    rdfs:range xsd:integer ;
    rdfs:label "defense rating"@en .

lol:magicRating a owl:DatatypeProperty ;
    rdfs:domain lol:InfoRating ;
    rdfs:range xsd:integer ;
    rdfs:label "magic rating"@en .

lol:difficultyRating a owl:DatatypeProperty ;
    rdfs:domain lol:InfoRating ;
    rdfs:range xsd:integer ;
    rdfs:label "difficulty rating"@en .

# -- Spell --
lol:spellId a owl:DatatypeProperty ;
    rdfs:domain lol:Spell ;
    rdfs:range xsd:string ;
    rdfs:label "spell ID"@en .

lol:spellName a owl:DatatypeProperty ;
    rdfs:domain lol:Spell ;
    rdfs:range xsd:string ;
    rdfs:label "spell name"@en .

lol:spellDescription a owl:DatatypeProperty ;
    rdfs:domain lol:Spell ;
    rdfs:range xsd:string ;
    rdfs:label "spell description"@en .

lol:spellTooltip a owl:DatatypeProperty ;
    rdfs:domain lol:Spell ;
    rdfs:range xsd:string ;
    rdfs:label "spell tooltip"@en .

lol:spellSlot a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:string ;
    rdfs:label "spell slot"@en ;
    rdfs:comment "The key slot: Q, W, E, or R."@en .

lol:maxRank a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:integer ;
    rdfs:label "max rank"@en .

lol:cooldownBurn a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:string ;
    rdfs:label "cooldown by rank"@en ;
    rdfs:comment "Slash-separated cooldowns for each rank."@en .

lol:costBurn a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:string ;
    rdfs:label "cost by rank"@en .

lol:costType a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:string ;
    rdfs:label "cost type"@en .

lol:rangeBurn a owl:DatatypeProperty ;
    rdfs:domain lol:ActiveSpell ;
    rdfs:range xsd:string ;
    rdfs:label "range by rank"@en .

# -- Skin --
lol:skinId a owl:DatatypeProperty ;
    rdfs:domain lol:Skin ;
    rdfs:range xsd:string ;
    rdfs:label "skin ID"@en .

lol:skinName a owl:DatatypeProperty ;
    rdfs:domain lol:Skin ;
    rdfs:range xsd:string ;
    rdfs:label "skin name"@en .

lol:skinNum a owl:DatatypeProperty ;
    rdfs:domain lol:Skin ;
    rdfs:range xsd:integer ;
    rdfs:label "skin number"@en .

lol:hasChromas a owl:DatatypeProperty ;
    rdfs:domain lol:Skin ;
    rdfs:range xsd:boolean ;
    rdfs:label "has chromas"@en .

# -- Role --
lol:roleName a owl:DatatypeProperty ;
    rdfs:domain lol:Role ;
    rdfs:range xsd:string ;
    rdfs:label "role name"@en .

# -- ResourceType --
lol:resourceName a owl:DatatypeProperty ;
    rdfs:domain lol:ResourceType ;
    rdfs:range xsd:string ;
    rdfs:label "resource name"@en .

# ============================================================
# ROLE INDIVIDUALS
# ============================================================

role:Fighter a lol:Role, owl:NamedIndividual ;
    lol:roleName "Fighter" .

role:Mage a lol:Role, owl:NamedIndividual ;
    lol:roleName "Mage" .

role:Assassin a lol:Role, owl:NamedIndividual ;
    lol:roleName "Assassin" .

role:Marksman a lol:Role, owl:NamedIndividual ;
    lol:roleName "Marksman" .

role:Support a lol:Role, owl:NamedIndividual ;
    lol:roleName "Support" .

role:Tank a lol:Role, owl:NamedIndividual ;
    lol:roleName "Tank" .

# ============================================================
# RESOURCE TYPE INDIVIDUALS
# ============================================================

res:Mana a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Mana" .

res:Energy a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Energy" .

res:Blood_Well a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Blood Well" .

res:Courage a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Courage" .

res:Crimson_Rush a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Crimson Rush" .

res:Ferocity a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Ferocity" .

res:Flow a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Flow" .

res:Fury a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Fury" .

res:Grit a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Grit" .

res:Heat a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Heat" .

res:None a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "None" .

res:Rage a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Rage" .

res:Shield a lol:ResourceType, owl:NamedIndividual ;
    lol:resourceName "Shield" .

