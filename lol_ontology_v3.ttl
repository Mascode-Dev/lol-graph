# ══ CHAMPION INDIVIDUALS (174) ══

champ:Aatrox a lol:Champion, owl:NamedIndividual ;
    lol:championId "Aatrox" ;
    lol:championKey "266" ;
    lol:championName "Aatrox" ;
    lol:championTitle "the Darkin Blade" ;
    lol:blurb "Once honored defenders of Shurima against the Void, Aatrox and his brethren would eventually become an even greater threat to Runeterra, and were defeated only by cunning mortal sorcery. But after centuries of imprisonment, Aatrox was the first to find..." ;
    lol:lore "Once honored defenders of Shurima against the Void, Aatrox and his brethren would eventually become an even greater threat to Runeterra, and were defeated only by cunning mortal sorcery. But after centuries of imprisonment, Aatrox was the first to find freedom once more, corrupting and transforming those foolish enough to try and wield the magical weapon that contained his essence. Now, with stolen flesh, he walks Runeterra in a brutal approximation of his previous form, seeking an apocalyptic and long overdue vengeance." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.02" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Use Umbral Dash while casting The Darkin Blade to increase your chances of hitting the enemy." ;
    lol:allyTip "Crowd Control abilities like Infernal Chains or your allies' immobilizing effects will help you set up The Darkin Blade." ;
    lol:allyTip "Cast World Ender when you are sure you can force a fight." ;
    lol:enemyTip "Aatrox's attacks are very telegraphed, so use the time to dodge the hit zones." ;
    lol:enemyTip "Aatrox's Infernal Chains are easier to exit when running towards the sides or at Aatrox." ;
    lol:enemyTip "Keep your distance when Aatrox uses his Ultimate to prevent him from reviving." ;
    lol:hasRole role:Fighter ;
    lol:hasResourceType res:Blood_Well ;
    lol:isFromRegion region:Shurima ;
    lol:playsPosition pos:Jungle ;
    lol:playsPosition pos:Top ;
    lol:hasSpell spell:Aatrox_Q ;
    lol:hasSpell spell:Aatrox_W ;
    lol:hasSpell spell:Aatrox_E ;
    lol:hasSpell spell:Aatrox_R ;
    lol:hasPassive spell:Aatrox_Passive ;
    lol:hasSkin skin:skin_266000 ;
    lol:hasSkin skin:skin_266001 ;
    lol:hasSkin skin:skin_266002 ;
    lol:hasSkin skin:skin_266003 ;
    lol:hasSkin skin:skin_266007 ;
    lol:hasSkin skin:skin_266008 ;
