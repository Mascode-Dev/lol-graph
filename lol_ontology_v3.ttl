    lol:spellName "Abscond / Abduct" ;
    lol:spellDescription "Sylas dashes to a location. Sylas can recast the ability to throw his chains out, pulling himself to an enemy he hits." ;
    lol:spellTooltip "Sylas quickly dashes, and prepares a Recast for 3.5 seconds.Recast: Sylas throws his chains, pulling himself to the first enemy hit, dealing {{ damage }} magic damage, and Knocking Up for {{ knockupduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
