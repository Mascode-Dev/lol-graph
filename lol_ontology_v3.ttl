spell:Malzahar_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "MalzaharE" ;
    lol:spellName "Malefic Visions" ;
    lol:spellDescription "Malzahar infects his target's mind with cruel visions of their demise, dealing damage over time. Using Malzahar's other spells on the target will refresh the visions.If the target dies while afflicted by the visions, they pass on to a nearby enemy unit and Malzahar gains Mana. Malzahar's Voidlings are attracted to affected units." ;
    lol:spellTooltip "Malzahar inflicts terrible visions, dealing {{ totaldamage }} magic damage over {{ duration }} seconds. Applying Call of the Void or Nether Grasp to the victim during this time refreshes the visions.If the victim dies, Malzahar gains {{ manarestore }} Mana and the visions spread to the nearest enemy.Malefic Visions executes minions below {{ minionexecutethreshold }} Health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "60/70/80/90/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Malzahar .

