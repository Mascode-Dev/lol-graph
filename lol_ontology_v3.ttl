    lol:spellSlot "W" ;
    lol:spellId "RyzeW" ;
    lol:spellName "Rune Prison" ;
    lol:spellDescription "Ryze traps a target in a cage of runes, damaging them and slowing their movement. If the target has Flux on it, they are instead rooted." ;
    lol:spellTooltip "Ryze deals {{ wdamagecalc }} magic damage and Slows by {{ slowamount*100 }}% for {{ ccduration }} seconds. If the target has Flux, it is consumed and this Ability Roots instead of Slowing.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10.5/10/9.5/9" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "615" ;
    lol:belongsToChampion champ:Ryze .

