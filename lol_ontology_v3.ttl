    lol:spellSlot "Q" ;
    lol:spellId "JarvanIVDragonStrike" ;
    lol:spellName "Dragon Strike" ;
    lol:spellDescription "Jarvan IV extends his lance, dealing physical damage and lowering the Armor of enemies in its path. Additionally, this will pull Jarvan to his Demacian Standard, knocking up enemies in his path." ;
    lol:spellTooltip "Jarvan extends his lance, dealing {{ totaldamage }} physical damage and removing {{ e2 }}% Armor for {{ e3 }} seconds.If the lance connects with Demacian Standard, Jarvan will pull himself to it, Knocking Up those in his path for 0.75 seconds.{{ spellmodifierdescriptionappend }}" ;
