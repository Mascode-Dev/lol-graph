spell:Draven_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "DravenSpinning" ;
    lol:spellName "Spinning Axe" ;
    lol:spellDescription "Draven's next attack will deal bonus physical damage. This axe will ricochet off the target high up into the air. If Draven catches it, he automatically readies another Spinning Axe. Draven can have two Spinning Axes at once." ;
    lol:spellTooltip "Draven readies a Spinning Axe, causing his next Attack to deal an additional {{ totaldamage }} physical damage and ricochet into the air. If Draven catches it, he readies another Spinning Axe.Draven can hold two Spinning Axes at once.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "45" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Draven .

spell:Draven_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "DravenFury" ;
    lol:spellName "Blood Rush" ;
    lol:spellDescription "Draven gains increased Move Speed and Attack Speed. The Move Speed bonus decreases rapidly over its duration. Catching a Spinning Axe will refresh the cooldown of Blood Rush." ;
    lol:spellTooltip "Draven becomes Ghosted, gains {{ e2 }}% Move Speed decaying over {{ e3 }} seconds and {{ e4 }}% Attack Speed for {{ e5 }} seconds.When Draven catches a Spinning Axe, this Ability's Cooldown is refreshed.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "40/35/30/25/20" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000" ;
    lol:belongsToChampion champ:Draven .

spell:Draven_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "DravenDoubleShot" ;
    lol:spellName "Stand Aside" ;
    lol:spellDescription "Draven throws his axes, dealing physical damage to targets hit and knocking them aside. Targets hit are slowed." ;
    lol:spellTooltip "Draven chucks a sideways axe that deals {{ totaldamage }} physical damage, Knocks Back, and Slows by {{ e2 }}% for {{ e3 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/17/16/15/14" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1050" ;
    lol:belongsToChampion champ:Draven .

spell:Draven_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "DravenRCast" ;
    lol:spellName "Whirling Death" ;
    lol:spellDescription "Draven hurls two massive axes to deal physical damage to each unit struck. Whirling Death slowly reverses direction and returns to Draven after striking an enemy champion. Draven may also activate this ability while the axes are in flight to cause it to return early. Deals less damage for each unit hit and resets when the axes reverse direction. Executes enemies who have less health than Draven's number of Adoration stacks." ;
    lol:spellTooltip "Draven hurls two massive axes that deal {{ rcalculateddamage }} physical damage. Upon hitting a champion or Recasting, they reverse direction and return to Draven. The axes deal {{ rdamagereductionperhit*100 }}% less damage for each enemy hit, down to a minimum of {{ rmindamagepercent }}%.If Whirling Death would leave an enemy champion with less health than {{ rpassivestackscoefficient*100 }}% of Draven's current League of Draven stacks ({{ rpassivetruedamage }}), he will execute them.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/90/80" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "20000" ;
    lol:belongsToChampion champ:Draven .

spell:Draven_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "League of Draven" ;
    lol:spellDescription "Draven gains his fans' Adoration when he catches a Spinning Axe or kills a minion, monster, or tower. Killing enemy champions grants Draven bonus gold based on how much Adoration he has." ;
    lol:belongsToChampion champ:Draven .

