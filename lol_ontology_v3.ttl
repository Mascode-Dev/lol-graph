spell:Yorick_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "YorickQ" ;
    lol:spellName "Last Rites" ;
    lol:spellDescription "Yorick deals bonus damage on his next attack and heals himself. If the target is a champion or large monster or if the target dies, a grave will be dug." ;
    lol:spellTooltip "Yorick's next Attack deals an additional {{ bonusdamage }} physical damage and restores {{ qheal }} plus {{ missinghealthratio }}% of his missing Health, reduced by {{ healreduction }}% against non-Champions. If this Attack hits a Champion or large Monster or kills the target, it leaves a grave.When there are 3 or more graves nearby and this Ability has already been used, Yorick can Recast to raise Mist Walkers from all nearby graves.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "6/5.5/5/4.5/4" ;
    lol:costBurn "20" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Yorick .

spell:Yorick_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "YorickW" ;
    lol:spellName "Dark Procession" ;
    lol:spellDescription "Yorick summons a destructible wall at target location that will block enemy movement." ;
    lol:spellTooltip "Yorick summons a wall of spirits blocking enemies' path, but not allies'. The wall has {{ wallhealthtooltip }} Health and disappears after {{ circleduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "20/18/16/14/12" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Yorick .

spell:Yorick_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "YorickE" ;
    lol:spellName "Mourning Mist" ;
    lol:spellDescription "Yorick throws a globule of Black Mist that reduces armor, damages, slows and marks enemies. Summoned units gain move speed when moving towards marked targets." ;
    lol:spellTooltip "Yorick throws a globule of Black Mist that deals {{ calc_healthdamage }} max Health magic damage, Slows by {{ calc_slow }} for {{ slowduration }} seconds and marks champions and monsters for {{ markduration }} seconds. Marked enemies continuously Awaken nearby graves (but not exceeding the maximum of {{ spell.yorickpassive:yorickpassiveghoulmax }}) and suffer {{ armorshred*100 }}% reduced Armor.Yorick and his summoned units gain {{ hasteamount*100 }}% Move Speed toward the mark. Mist Walkers will leap once at marked enemies that get away from them.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:Yorick .

spell:Yorick_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "YorickR" ;
    lol:spellName "Eulogy of the Isles" ;
    lol:spellDescription "Yorick summons the Maiden of the Mist that causes Yorick's attacks against the Maiden's target to deal bonus damage. The Maiden will also automatically raise Walkers from dead enemies." ;
    lol:spellTooltip "Yorick summons the Maiden of the Mist with {{ yorickbigghoulhealth }} Health and {{ yorickbigghouldamage }} Magic Attack Damage plus {{ rghoulnumbers }} Mist Walkers. The Maiden automatically raises Mist Walkers from nearby enemy deaths and marks enemy Champions with her attacks. When Yorick damages the Maiden's target, he deals {{ rmarkdamagepercent }}% max Health magic damage.After 10 seconds, Yorick can Recast this Ability to free the Maiden, sending her down the nearest lane.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "160/130/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Yorick .

