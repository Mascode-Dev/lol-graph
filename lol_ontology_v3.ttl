    lol:spellSlot "W" ;
    lol:spellId "NilahW" ;
    lol:spellName "Jubilant Veil" ;
    lol:spellDescription "Nilah envelops herself in mist, increasing her movement speed and allowing her to gracefully dodge all incoming attacks. Any allies she touches during the mist's duration will also gain this effect." ;
    lol:spellTooltip "Nilah envelops herself in mist for {{ baseduration }} seconds, becoming Ghosted, gaining {{ movespeedpercent*100 }}% Move Speed, dodging Attacks, and reducing magic damage taken by {{ magicdamagereduction*100 }}%.While active, touching allied champions envelops them in mist, granting the same benefits for {{ sharebaseduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
