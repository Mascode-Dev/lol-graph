spell:Neeko_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "NeekoQ" ;
    lol:spellName "Blooming Burst" ;
    lol:spellDescription "Neeko throws a seed dealing magic damage. The seed blooms again on hitting champions or killing units." ;
    lol:spellTooltip "Neeko throws a seed that blooms to deal {{ explosiondamage }} magic damage. If it kills a unit or hits a champion or large monster, it will bloom again, dealing {{ seconddamage }} magic damage. Max 2 extra blooms.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.5/8/7.5/7" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
    lol:belongsToChampion champ:Neeko .

spell:Neeko_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "NeekoW" ;
    lol:spellName "Shapesplitter" ;
    lol:spellDescription "Neeko passively deals bonus magic damage every third attack, briefly increasing her move speed. Neeko can activate to send a clone in a direction and recast to change the direction of the clone." ;
    lol:spellTooltip "Passive: Every 3rd Attack deals an additional {{ passivebonusdamagecalc }} bonus magic damage and increases Neeko's Move Speed by {{ passivehaste }}% for {{ passivehasteduration }} second.Active: Neeko becomes invisible for {{ stealthduration }} seconds and projects a clone that lasts {{ cloneduration }} seconds. Neeko and the clone gain {{ haste }}% Move Speed for {{ hasteduration }} seconds. The clone can be controlled using the Move Pet Click hotkey or by Recasting this Ability.The clone mirrors her spellcasts, emotes, and recall.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/15/14/13/12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Neeko .

spell:Neeko_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "NeekoE" ;
    lol:spellName "Tangle-Barbs" ;
    lol:spellDescription "Neeko slings a tangle that damages and roots everything it passes through. If the tangle kills an enemy or passes through a champion, it becomes larger, faster, and roots for longer." ;
    lol:spellTooltip "Neeko slings a tangle that deals {{ basedamage }} magic damage and Roots for {{ minrootduration }} seconds.The tangle becomes empowered after hitting an enemy, growing larger, moving faster, and Rooting for {{ maxrootduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11.5/11/10.5/10" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000" ;
    lol:belongsToChampion champ:Neeko .

spell:Neeko_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "NeekoR" ;
    lol:spellName "Pop Blossom" ;
    lol:spellDescription "After a short preparation, Neeko leaps into the air, knocking up all nearby enemies. Upon landing, nearby enemies are damaged and stunned. The preparation is hidden if Neeko is disguised." ;
    lol:spellTooltip "After a delay Neeko leaps into the air, Knocking Up all nearby enemies for {{ delayuntilexplosion }} seconds. She then crashes down, dealing {{ totaldamage }} magic damage to all nearby enemies and Stunning them for {{ stunduration }} seconds.This Ability can be prepared in secret if Neeko is disguised. {{ delaybeforepassiveremoval }} seconds after casting this ability Neeko breaks her disguise.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/105/90" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Neeko .

spell:Neeko_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Inherent Glamour" ;
    lol:spellDescription "Neeko can look like an ally champion or as other units on the map. Receiving immobilizing crowd control, casting damaging spells, damaging enemy towers as a non-champion, or your disguise taking damage equal to its healthbar breaks the disguise." ;
    lol:belongsToChampion champ:Neeko .

