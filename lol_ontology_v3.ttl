    lol:spellId "MorganaW" ;
    lol:spellName "Tormented Shadow" ;
    lol:spellDescription "Morgana casts a cursed shadow on an area, damaging enemies who dare stand in her dark circle. They receive magic damage over time, which increases the lower health they are." ;
    lol:spellTooltip "Morgana ignites the ground for {{ wduration }} seconds, dealing {{ totalmindamage }} magic damage per second, increased by up to {{ totalmaxdamage }} based on the targets' missing Health.This Ability's Cooldown is reduced by {{ cdrefundpercent*100 }}% every time Morgana is healed by Soul Siphon.{{ spellmodifierdescriptionappend }}" ;
