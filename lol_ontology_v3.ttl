champ:Quinn a lol:Champion, owl:NamedIndividual ;
    lol:championId "Quinn" ;
    lol:championKey "133" ;
    lol:championName "Quinn" ;
    lol:championTitle "Demacia's Wings" ;
    lol:blurb "Quinn is an elite ranger-knight of Demacia, who undertakes dangerous missions deep in enemy territory. She and her legendary eagle, Valor, share an unbreakable bond, and their foes are often slain before they realize they are fighting not one, but two..." ;
    lol:lore "Quinn is an elite ranger-knight of Demacia, who undertakes dangerous missions deep in enemy territory. She and her legendary eagle, Valor, share an unbreakable bond, and their foes are often slain before they realize they are fighting not one, but two of the kingdom's greatest heroes. Nimble and acrobatic when required, Quinn takes aim with her crossbow while Valor marks their elusive targets from above, making them a deadly pair on the battlefield." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.01" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Attacking a " ;
    lol:allyTip "Vulnerable" ;
    lol:allyTip " target marked by Valor will put Harrier on cooldown. Quickly consuming Harrier marks will allow you to generate them faster." ;
    lol:allyTip "Vault is powerful but must be used with caution, as enemies can attack Quinn when she strikes them. Vault can sometimes be used to cross terrain if your back is to a wall." ;
    lol:allyTip "Use Behind Enemy Lines for traveling very long distances quickly, for farming minions around the map, or for chasing wounded targets." ;
    lol:enemyTip "After being marked, move away from Quinn so she can't take advantage of it." ;
    lol:enemyTip "Keep tabs on Quinn's position. Behind Enemy Lines can enable Valor to cross the map very quickly and attack you by surprise." ;
    lol:enemyTip "When Quinn is using Behind Enemy Lines, damaging her removes her Move Speed bonus temporarily." ;
    lol:hasRole role:Marksman ;
    lol:hasRole role:Assassin ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Demacia ;
    lol:playsPosition pos:Top ;
    lol:hasSpell spell:Quinn_Q ;
    lol:hasSpell spell:Quinn_W ;
    lol:hasSpell spell:Quinn_E ;
    lol:hasSpell spell:Quinn_R ;
    lol:hasPassive spell:Quinn_Passive ;
