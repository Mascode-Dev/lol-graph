    lol:spellSlot "Q" ;
    lol:spellId "SmolderQ" ;
    lol:spellName "Super Scorcher Breath" ;
    lol:spellDescription "Smolder breathes fire on an enemy. As he gains more stacks, this ability becomes more powerful." ;
    lol:spellTooltip "Smolder belches flame, dealing {{ totaldamage }} physical damage + {{ spell.smolderp:passive_qdamageincrease }} magic damage. If the target dies, Smolder refunds {{ manarestore }} Mana, once per cast.Based on stacks of Dragon Practice, this Ability evolves to gain the following effects:{{ stacktier1 }} Stacks: Damages all enemies surrounding the target.{{ stacktier2 }} Stacks: Sends {{ tier2_numberofblowback }} explosions beyond the target that deal {{ tier2_blowbackpercentagedamage }}% of this Ability's damage.{{ stacktier3 }} Stacks: Burns the target, dealing {{ tier3_burn }} max Health true damage over {{ tier3_dotlength }} seconds. Enemy champions that drop below {{ tier3_executethreshold }} total health while burning are killed instantly.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "5.5/5/4.5/4/3.5" ;
    lol:costBurn "25" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "550" ;
    lol:belongsToChampion champ:Smolder .

