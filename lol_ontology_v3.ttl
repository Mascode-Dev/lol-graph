    lol:spellSlot "R" ;
    lol:spellId "NocturneParanoia" ;
    lol:spellName "Paranoia" ;
    lol:spellDescription "Nocturne reduces the sight radius of all enemy champions and removes their ally vision in the process. He can then launch himself at a nearby enemy champion." ;
    lol:spellTooltip "Nocturne darkens the map, reducing the sight radius of all enemy champions and removing their vision of allies for {{ paranoiaduration }} seconds. Nocturne can Recast this Ability during the duration to launch himself at an enemy champion dealing {{ damage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
