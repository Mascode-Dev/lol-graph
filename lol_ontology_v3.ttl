    lol:belongsToChampion champ:Aurora .

spell:Aurora_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "AuroraR" ;
    lol:spellName "Between Worlds" ;
    lol:spellDescription "Aurora leaps in a direction of her choosing, releasing a shockwave that damages and slows any enemies it hits. Afterward, she creates an area that slows enemies within it and allows Aurora to teleport from one side of the area to the other." ;
    lol:spellTooltip "Leap in a direction. Upon landing, Aurora converges the realms, sending out a pulse of spirit energy that deals {{ damagecalc }} magic damage and Slows enemies hit by {{ slowpercent*-100 }}% for 2 seconds.The area of convergence stays active for {{ areaduration }} seconds, granting Aurora Realm Hopper for {{ rbuffduration }} seconds, allowing her to jump from one edge of the area to another.Enemies attempting to enter or leave the area are Slowed by {{ exitslowpercent*-100 }}% for {{ stunduration }} seconds.Aurora can Recast this Ability to end the effect early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/120/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "250" ;
    lol:belongsToChampion champ:Aurora .

