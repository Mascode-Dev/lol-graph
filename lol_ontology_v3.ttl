spell:Fiddlesticks_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "FiddleSticksQ" ;
    lol:spellName "Terrify" ;
    lol:spellDescription "Fiddlesticks damaging enemies with spells while unseen or targeting an enemy with Terrify's activation strikes a target unit with fear, causing it to flee in terror for a duration." ;
    lol:spellTooltip "Passive: While unseen and out of combat or impersonating an Effigy, damaging an enemy with an ability Fears them for {{ fearduration }} second(s).Active: Fear an enemy for {{ fearduration }} second(s) and deal {{ totalpercenthealthdamage }} current Health magic damage. If the target has recently been Feared by Fiddlesticks, instead deal {{ totalpercenthealthdamagefeared }} current Health magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "15/14.5/14/13.5/13" ;
    lol:costBurn "65" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "575" ;
    lol:belongsToChampion champ:Fiddlesticks .

