    lol:spellSlot "W" ;
    lol:spellId "IreliaW" ;
    lol:spellName "Defiant Dance" ;
    lol:spellDescription "Irelia charges a strike that deals more damage as she charges. She takes reduced physical damage during the charge." ;
    lol:spellTooltip "Begin Charging: Irelia enters a defensive stance for up to {{ maxduration }} seconds, becoming unable to act but reducing physical damage taken by {{ finalphysicaldr }}% and magic damage taken by {{ finalmagicdr }}%.Release: Irelia lashes out with her blades, dealing {{ mindamagecalc }} physical damage increased up to {{ maxdamagecalc }} based on charge time.{{ spellmodifierdescriptionappend }}" ;
