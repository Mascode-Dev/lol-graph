spell:Vladimir_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "VladimirQ" ;
    lol:spellName "Transfusion" ;
    lol:spellDescription "Vladimir steals life from the target enemy. When Vladimir's resource is full, Transfusion will benefit from massively increased damage and healing for a brief time." ;
    lol:spellTooltip "Vladimir drains his target's lifeforce, dealing {{ basedamagetooltip }} magic damage and restoring {{ basehealtooltip }} Health. After using this Ability twice, Vladimir gains {{ movementspeedonq2 }}% Move Speed for 0.5 seconds and empowers the next use of this Ability for {{ e8 }} seconds.The empowered version of this Ability deals {{ empowereddamagetooltip }} magic damage instead and restores an additional {{ empoweredhealtooltip }} plus {{ empoweredhealpercenttooltip }} missing Health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/7.9/6.8/5.7/4.6" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Vladimir .

spell:Vladimir_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "VladimirSanguinePool" ;
    lol:spellName "Sanguine Pool" ;
    lol:spellDescription "Vladimir sinks into a pool of blood, becoming untargetable for 2 seconds. Additionally, enemies on the pool are slowed and Vladimir siphons life from them." ;
    lol:spellTooltip "Vladimir sinks into a pool of blood for 2 seconds, gaining {{ hasteboost*100 }}% decaying Move Speed for {{ hasteduration }} second and becoming Untargetable and Ghosted while Slowing enemies in the pool by {{ movespeedmod*-100 }}%.Vladimir deals {{ totaldamage }} magic damage and restores {{ totalheal }} Health per enemy over the duration.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "28/25/22/19/16" ;
    lol:costBurn "0" ;
    lol:costType "% of current Health" ;
    lol:rangeBurn "350" ;
    lol:belongsToChampion champ:Vladimir .

spell:Vladimir_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "VladimirE" ;
    lol:spellName "Tides of Blood" ;
    lol:spellDescription "Vladimir pays his own health to charge up a reservoir of blood which, when released, deals damage in the area around him but can be blocked by enemy units." ;
    lol:spellTooltip "Begin Charging: Vladimir charges up a reservoir of blood, spending up to {{ chargehealthtooltip }} Health. While at full charge, Vladimir is Slowed by 20%.Release: Vladimir unleashes a torrent of blood missiles at surrounding enemies, dealing between {{ mindamagetooltip }} and {{ maxdamagetooltip }} magic damage based on charge time. If this Ability was charged for at least 1 second, it also Slows targets by {{ slowpercent }}% for 0.5 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "13/11/9/7/5" ;
    lol:costBurn "0" ;
    lol:costType "% of max Health ({{ chargehealthtooltip }})" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Vladimir .

spell:Vladimir_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "VladimirHemoplague" ;
    lol:spellName "Hemoplague" ;
    lol:spellDescription "Vladimir infects an area with a virulent plague. Affected enemies take increased damage for the duration. After a few seconds, Hemoplague deals magic damage to infected enemies and heals Vladimir for each enemy Champion hit." ;
    lol:spellTooltip "Vladimir creates a virulent plague, causing its victims to take {{ e2 }}% increased damage from all sources for {{ e4 }} seconds. After it expires, Vladimir deals {{ damage }} magic damage to all infected targets. Vladimir restores {{ damage }} Health if he hits a champion, and restores an additional {{ secondaryhealingtooltip }} Health for each champion beyond the first.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "625" ;
    lol:belongsToChampion champ:Vladimir .

