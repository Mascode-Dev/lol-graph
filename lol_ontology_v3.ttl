champ:Amumu a lol:Champion, owl:NamedIndividual ;
    lol:championId "Amumu" ;
    lol:championKey "32" ;
    lol:championName "Amumu" ;
    lol:championTitle "the Sad Mummy" ;
    lol:blurb "Legend claims that Amumu is a lonely and melancholy soul from ancient Shurima, roaming the world in search of a friend. Doomed by an ancient curse to remain alone forever, his touch is death, his affection ruin. Those who claim to have seen him describe..." ;
    lol:lore "Legend claims that Amumu is a lonely and melancholy soul from ancient Shurima, roaming the world in search of a friend. Doomed by an ancient curse to remain alone forever, his touch is death, his affection ruin. Those who claim to have seen him describe a living cadaver, small in stature and wrapped in creeping bandages. Amumu has inspired myths, songs, and folklore told and retold for generations—such that it is impossible to separate truth from fiction." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V25.18" ;
    lol:costBE "225"^^xsd:integer ;
    lol:costRP "260"^^xsd:integer ;
    lol:allyTip "Amumu is highly dependent on teammates, so try laning with your friends for maximum effectiveness." ;
    lol:allyTip "Cooldown Reduction on Amumu is very strong, but it's often difficult to itemize for it. Grab the Golem buff whenever possible to gain Cooldown Reduction without sacrificing stats." ;
    lol:allyTip "Despair is very effective against other tanks, so make sure you're in range of opponents with the highest Health." ;
    lol:enemyTip "Avoid bunching up with other allies when Amumu has his ultimate available." ;
    lol:enemyTip "Erratic movement, or hiding behind creep waves can make it difficult for Amumu to instigate a fight with Bandage Toss." ;
    lol:enemyTip "Amumu's Despair makes purchasing primarily Health items a risky proposition." ;
    lol:hasRole role:Tank ;
    lol:hasRole role:Support ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Shurima ;
    lol:playsPosition pos:Jungle ;
    lol:playsPosition pos:Support ;
