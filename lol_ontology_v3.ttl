    lol:spellSlot "Q" ;
    lol:spellId "ZileanQ" ;
    lol:spellName "Time Bomb" ;
    lol:spellDescription "Tosses a bomb to target area that sticks to units that come near it (prioritizes Champions). It detonates after 3 seconds, dealing area of effect damage. If a Time Bomb is detonated early by another Time Bomb, it also stuns enemies." ;
    lol:spellTooltip "Zilean tosses a time-delayed bomb that sticks to the first unit which comes within a small area around it. After {{ e2 }} seconds it detonates, dealing {{ totaldamage }} magic damage.Placing a second bomb on a unit that already has one detonates the first bomb immediately and Stuns enemies in the blast for {{ e4 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9.5/9/8.5/8" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Zilean .

