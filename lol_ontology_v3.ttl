    lol:spellSlot "E" ;
    lol:spellId "ThreshE" ;
    lol:spellName "Flay" ;
    lol:spellDescription "Thresh's attacks wind up, dealing more damage the longer he waits between attacks. When activated, Thresh sweeps his chain, knocking all enemies hit in the direction of the blow." ;
    lol:spellTooltip "Passive: Thresh's Attacks deal additional damage based on how long since he last Attacked. They deal between {{ pattackdamagemin }} and {{ pattackdamagemax }} magic damage.Active: Thresh whips his chains, Pulling or Pushing enemies in the direction of the swing. Enemies hit are also Slowed by {{ e2 }}% for {{ e4 }} second and take {{ totaldamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "13/12.25/11.5/10.75/10" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
