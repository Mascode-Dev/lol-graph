    lol:spellTooltip "Maokai transforms into a moving mass of roots, becoming Untargetable and dashing to an enemy. Upon arrival, he Roots the enemy for {{ e2 }} second(s) and deals {{ totaldamage }} magic damage. {{ spellmodifierdescriptionappend }}" ;
