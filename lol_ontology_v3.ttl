spell:LeBlanc_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "LeblancQ" ;
    lol:spellName "Sigil of Malice" ;
    lol:spellDescription "LeBlanc projects a sigil, dealing damage and marking the target for 3.5 seconds. Damaging the marked target with an ability detonates the sigil, dealing additional damage. If either part kills the target, Leblanc refunds the Mana cost and part of this spell's remaining Cooldown." ;
    lol:spellTooltip "LeBlanc projects a sigil to an enemy, dealing {{ damage }} magic damage and marking them for {{ markduration }} seconds.Damaging the marked enemy with an Ability detonates the sigil, dealing {{ markdamage }} magic damage.If either part kills the target, Leblanc refunds {{ manarefund*100 }}% of the Mana cost and {{ cooldownrefund*100 }}% of this spell's remaining Cooldown.The initial sigil deals an additional {{ bonusminiondamage }} damage to minions. {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "6" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:LeBlanc .

spell:LeBlanc_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "LeblancW" ;
    lol:spellName "Distortion" ;
    lol:spellDescription "LeBlanc dashes to a location, dealing damage to enemies near her destination. For the next 4 seconds, activate Distortion again to return LeBlanc to her starting location." ;
    lol:spellTooltip "LeBlanc dashes then deals {{ totaldamage }} magic damage to nearby enemies. For {{ e3 }} seconds after dashing, LeBlanc can Recast.Recast: LeBlanc returns to her starting location.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "15/13.75/12.5/11.25/10" ;
    lol:costBurn "60/70/80/90/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:LeBlanc .

spell:LeBlanc_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "LeblancE" ;
    lol:spellName "Ethereal Chains" ;
    lol:spellDescription "LeBlanc launches a chain that shackles the first enemy hit. If the target remains shackled for 1.5 seconds, LeBlanc roots them and deals additional damage." ;
    lol:spellTooltip "LeBlanc launches a chain that shackles the first enemy hit, dealing {{ initialdamage }} magic damage and granting True Sight.If they remain shackled for {{ e3 }} seconds, LeBlanc Roots them for {{ e4 }} seconds and deals an additional {{ delayeddamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13.25/12.5/11.75/11" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "925" ;
    lol:belongsToChampion champ:LeBlanc .

spell:LeBlanc_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "LeblancR" ;
    lol:spellName "Mimic" ;
    lol:spellDescription "LeBlanc casts a mimicked version of one of her basic spells." ;
    lol:spellTooltip "LeBlanc mimics her most recent Ability, using it again. The mimicked Ability deals increased damage.Mimicked Sigil of Malice deals {{ rq1damage }} magic damage when applied, and {{ rq2damage }} magic damage when consumed.Mimicked Distortion deals {{ rwdamage }} magic damage.Mimicked Ethereal Chains deals {{ re1damage }} magic damage when shackled and {{ re2damage }} magic damage when Rooting.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "45/35/25" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:LeBlanc .

