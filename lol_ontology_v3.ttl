champ:Sejuani a lol:Champion, owl:NamedIndividual ;
    lol:championId "Sejuani" ;
    lol:championKey "113" ;
    lol:championName "Sejuani" ;
    lol:championTitle "Fury of the North" ;
    lol:blurb "Sejuani is the brutal, unforgiving Iceborn warmother of the Winter's Claw, one of the most feared tribes of the Freljord. Her people's survival is a constant, desperate battle against the elements, forcing them to raid Noxians, Demacians, and Avarosans..." ;
    lol:lore "Sejuani is the brutal, unforgiving Iceborn warmother of the Winter's Claw, one of the most feared tribes of the Freljord. Her people's survival is a constant, desperate battle against the elements, forcing them to raid Noxians, Demacians, and Avarosans alike to survive the harsh winters. Sejuani herself spearheads the most dangerous of these attacks from the saddle of her drüvask boar Bristle, using her True Ice flail to freeze and shatter her enemies." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V25.24" ;
    lol:costBE "225"^^xsd:integer ;
    lol:costRP "260"^^xsd:integer ;
    lol:allyTip "Use Arctic Assault to escape bad situations, interupt channeled spells or chase runners." ;
    lol:allyTip "Melee allies can stack Frost for your Permafrost, keep an eye on who they are attacking." ;
    lol:allyTip "Save Glacial Prison for encounters where you have teammates present to take advantage of it." ;
    lol:enemyTip "Dodging Arctic Assault and Glacial Prison can give you a huge advantage." ;
    lol:enemyTip "Focus on avoiding the second swing of Winter's Wrath which carries the brunt of the damage." ;
    lol:enemyTip "Melee enemies can also stack Frost for Sejuani, be very careful around them." ;
    lol:hasRole role:Tank ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Freljord ;
    lol:playsPosition pos:Jungle ;
