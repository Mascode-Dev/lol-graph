    lol:spellSlot "W" ;
    lol:spellId "NamiW" ;
    lol:spellName "Ebb and Flow" ;
    lol:spellDescription "Unleashes a stream of water that bounces back and forth between allied and enemy champions, healing allies and damaging enemies." ;
    lol:spellTooltip "Nami unleashes a stream of water that bounces between allied and enemy champions. Each champion can only be hit once, and it hits up to {{ maxtargets }} targets.Restores {{ totalheal }} Health to allies and will bounce to a nearby enemy champion. Deals {{ totaldamage }} magic damage to enemies and will bounce to a nearby allied champion.The damage and healing value is modified by {{ bouncescaling }} each bounce. {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10" ;
    lol:costBurn "70/75/80/85/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "725" ;
    lol:belongsToChampion champ:Nami .

