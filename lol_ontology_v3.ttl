spell:Gwen_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "GwenQ" ;
    lol:spellName "Snip Snip!" ;
    lol:spellDescription "Gwen snips her scissors in a cone up to 6 times dealing magic damage. Gwen deals true damage to units in the center and applies her passive to them on each snip." ;
    lol:spellTooltip "Passive: Gwen gains 1 stack when she hits an enemy with an attack (max 4, lasts {{ buffduration }} seconds).Active: Consumes stacks. Gwen snips once for {{ miniswipedamage }} magic damage, snips again for each ammo consumed, and then snips a final time for {{ finalswipedamage }} magic damage. The center of each strikes converts {{ truedamageconversion*100 }}% of the damage into true damage instead and applies A Thousand Cuts to enemies hit.Deals {{ minionmod*100 }}% damage to minions.Minions below {{ executethreshold*100 }}% health take {{ executebonus }}% bonus damage instead of reduced damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "6.5/5.75/5/4.25/3.5" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "450" ;
    lol:belongsToChampion champ:Gwen .

spell:Gwen_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "GwenW" ;
    lol:spellName "Hallowed Mist" ;
    lol:spellDescription "Gwen summons mist that protects her from enemies outside of it. She can only be targeted by enemies who enter the mist." ;
    lol:spellTooltip "Gwen summons the Hallowed Mist, making her Untargetable to all enemies (except towers) outside the zone for {{ zoneduration }} seconds or until she leaves it. While in the Mist, Gwen gains {{ totalresists }} Armor and Magic Resist.Gwen can Recast this Ability once to call the Mist to her. This will automatically Recast the first time Gwen attempts to leave the zone.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/21/20/19/18" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Gwen .

spell:Gwen_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "GwenE" ;
    lol:spellName "Skip 'n Slash" ;
    lol:spellDescription "Gwen dashes a short distance then gains Attack Speed, attack range, and magic damage On-Hit for a few seconds. If she hits an enemy during that time, this Ability's cooldown is partially refunded." ;
    lol:spellTooltip "Gwen dashes and empowers her Attacks for {{ buffduration }} seconds.Empowered Attacks gain {{ bonusattackspeed }} Attack Speed, {{ onhitdamage }} magic damage %i:OnHit% On-Hit, {{ bonusattackrange }} range, and the first one to hit an enemy refunds {{ cdrefund*100 }}% of this Ability's Cooldown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "13/12.5/12/11.5/11" ;
    lol:costBurn "35" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Gwen .

spell:Gwen_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "GwenR" ;
    lol:spellName "Needlework" ;
    lol:spellDescription "Gwen hurls a needle that slows enemies hit, deals magic damage, and applies A Thousand Cuts to champions hit. This ability can be cast up to two more times, with each cast throwing additional needles and dealing more damage." ;
    lol:spellTooltip "First Cast: Hurl a needle that deals {{ totaldamage }} magic damage, Slows by {{ initialslow*-100 }}% for {{ debuffduration }} seconds, and applies A Thousand Cuts to all enemies hit. Gwen can Recast this ability up to 2 additional times within 6 seconds ({{ lockouttime }}s cooldown between casts).Second Cast: Fire three needles to deal {{ totaldamage3 }} magic damageThird Cast: Fire five needles to deal {{ totaldamage5 }} magic damage{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1200" ;
    lol:belongsToChampion champ:Gwen .

