champ:Bel_Veth a lol:Champion, owl:NamedIndividual ;
    lol:championId "Belveth" ;
    lol:championKey "200" ;
    lol:championName "Bel'Veth" ;
    lol:championTitle "the Empress of the Void" ;
    lol:blurb "A nightmarish empress created from the raw material of an entire devoured city, Bel'Veth is the end of Runeterra itself... and the beginning of a monstrous reality of her own design. Driven by epochs of repurposed history, knowledge, and memories from..." ;
    lol:lore "A nightmarish empress created from the raw material of an entire devoured city, Bel'Veth is the end of Runeterra itself... and the beginning of a monstrous reality of her own design. Driven by epochs of repurposed history, knowledge, and memories from the world above, she voraciously feeds an ever-expanding need for new experiences and emotions, consuming all that crosses her path. Yet her wants could never be sated by only one world as she turns her hungry eyes toward the Void's old masters..." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.03" ;
