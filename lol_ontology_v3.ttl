    lol:spellSlot "E" ;
    lol:spellId "AuroraE" ;
    lol:spellName "The Weirding" ;
    lol:spellDescription "Aurora converges the realms, sending out a blast of spirit magic that damages and slows enemies before Aurora hops backward to safety." ;
    lol:spellTooltip "Converge the realms, sending out a blast of spirit magic dealing {{ damagecalc }} magic damage to enemies in the area and Slowing them by {{ slowpercent*-100 }}% decaying over {{ slowduration }} second.Aurora hops backwards a short distance after casting.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
