spell:Skarner_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "SkarnerQ" ;
    lol:spellName "Shattered Earth / Upheaval" ;
    lol:spellDescription "Skarner rips a boulder from the earth that empowers his attacks and can be thrown as a powerful projectile." ;
    lol:spellTooltip "Skarner rips a boulder from the ground, empowering his next 3 Attacks with {{ attackspeed*100 }}% Attack Speed and dealing {{ abilitydamage }} physical damage to surrounding enemies. His final Attack will deal an additional {{ maxhppercent*100 }}% max Health physical damage and Slow affected foes by {{ slowpercent*100 }}% for {{ slowduration }}s.Recast: Skarner ends this Ability and throws his boulder, dealing {{ spell.skarnerq:abilitydamage }} + {{ spell.skarnerq:maxhppercent*100 }}% max Health physical damage, and additionally Slowing the first enemy hit — and any other surrounding enemies — by {{ spell.skarnerq:slowpercent*100 }}% for {{ spell.skarnerq:slowduration }}s.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/6.75/5.5/4.25/3" ;
    lol:costBurn "45" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Skarner .

