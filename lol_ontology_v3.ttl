spell:Darius_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "DariusCleave" ;
    lol:spellName "Decimate" ;
    lol:spellDescription "Darius winds up and swings his axe in a wide circle. Enemies struck by the blade take more damage than those struck by the handle. Darius heals based on enemy champions and large monsters hit by the blade." ;
    lol:spellTooltip "Darius hefts his axe then swings it around, dealing {{ bladedamage }} physical damage with the edge and {{ handledamage }} damage with the handle. Enemies hit with the handle do not take a Hemorrhage stack.Darius restores {{ e5 }}% missing Health per enemy champion and large jungle monster hit with the edge, up to a max of {{ e7 }}%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8/7/6/5" ;
    lol:costBurn "25/30/35/40/45" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1" ;
    lol:belongsToChampion champ:Darius .

spell:Darius_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "DariusNoxianTacticsONH" ;
    lol:spellName "Crippling Strike" ;
    lol:spellDescription "Darius's next attack strikes an enemy's crucial artery. As they bleed out, their Move Speed is slowed." ;
    lol:spellTooltip "Darius' next Attack deals {{ empoweredattackdamage }} physical damage and Slows by {{ e2 }}% for {{ e5 }} second.This Ability refunds its Mana cost and reduces its Cooldown by {{ e3 }}% if it kills the target.This Ability triggers spell effects upon dealing damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "5" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Darius .

spell:Darius_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "DariusAxeGrabCone" ;
    lol:spellName "Apprehend" ;
    lol:spellDescription "Darius hones his axe, passively causing his physical damage to ignore a percentage of his target's Armor. When activated, Darius sweeps up his enemies with his axe's hook and pulls them to him." ;
    lol:spellTooltip "Passive: Darius gains {{ e1 }}% Armor Penetration.Active: Darius hooks with his axe, Pulling, and Knocking Up and Slowing by {{ e2 }}% for {{ e3 }} second.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "26/23.5/21/18.5/16" ;
    lol:costBurn "70/60/50/40/30" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "535" ;
    lol:belongsToChampion champ:Darius .

spell:Darius_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "DariusExecute" ;
    lol:spellName "Noxian Guillotine" ;
    lol:spellDescription "Darius leaps to an enemy champion and strikes a lethal blow, dealing true damage. This damage is increased for each stack of Hemorrhage on the target. If Noxian Guillotine is a killing blow, its cooldown is refreshed for a brief duration." ;
    lol:spellTooltip "Darius leaps to an enemy and strikes a lethal blow, dealing {{ damage }} true damage. For each Hemorrhage on the target, this Ability deals an additional {{ rdamagepercentperhemostack*100 }}% damage, up to a max of {{ maximumdamage }} damage.If this kills the target, Darius may Recast this Ability once within {{ rrecastduration }} seconds. At rank 3, this Ability has no Mana cost and kills refresh the Cooldown completely.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "100/100/0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "460" ;
    lol:belongsToChampion champ:Darius .

spell:Darius_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Hemorrhage" ;
    lol:spellDescription "Darius' attacks and damaging abilities cause enemies to bleed for physical damage over 5 seconds, stacking up to 5 times. Darius enrages and gains massive Attack Damage when his target reaches max stacks." ;
    lol:belongsToChampion champ:Darius .

