spell:Tahm_Kench_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "TahmKenchQ" ;
    lol:spellName "Tongue Lash" ;
    lol:spellDescription "Tahm Kench lashes out with his tongue, damaging and slowing the first unit hit and healing himself if he strikes an enemy champion.Applies a stack of  An Acquired Taste to enemy champions. If the champion already has 3 stacks of An Acquired Taste, they are stunned and the stacks are consumed." ;
    lol:spellTooltip "Deals {{ totaldamage }} magic damage to the first enemy hit and Slows them by {{ slowamount*100 }}% for {{ slowduration }} seconds. On champion hit, heals Tahm for {{ baseheal }} +{{ percenthealthhealing*100 }}% of his missing Health and applies a stack of An Acquired Taste dealing {{ spell.tahmkenchpassive:totaldamage }} extra magic damage. If that champion already had 3 stacks of An Acquired Taste, they will also be Stunned for {{ stunduration }} seconds, consuming the stacks.Activate Devour while your tongue is in midair to devour enemy champions who already have 3 stacks of An Acquired Taste from a distance when you hit them.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "7/6.5/6/5.5/5" ;
    lol:costBurn "50/46/42/38/34" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Tahm_Kench .

spell:Tahm_Kench_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "TahmKenchW" ;
    lol:spellName "Abyssal Dive" ;
    lol:spellDescription "Dive down and then re-appear at target location, damaging and knocking up all enemies in an area." ;
    lol:spellTooltip "Dive down and then re-appear at target location, dealing {{ totaldamage }} magic damage and Knock Up all enemies in an area for {{ knockupduration }} second. Hitting at least one enemy champion refunds {{ champrefund*100 }}% of the Cooldown and Mana cost. Devoured allies can be taken along for the ride (but can always hop out early).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "21/20/19/18/17" ;
    lol:costBurn "60/75/90/105/120" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000/1050/1100/1150/1200" ;
    lol:belongsToChampion champ:Tahm_Kench .

spell:Tahm_Kench_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "TahmKenchE" ;
    lol:spellName "Thick Skin" ;
    lol:spellDescription "Passive: Tahm Kench stores a percent of the damage he takes and heals based on it while out of combat.Active: Convert all stored damage into a temporary shield." ;
    lol:spellTooltip "Passive: {{ greyhealthratio*100 }}% of damage Tahm Kench takes is stored by his Thick Skin, increased to {{ greyhealthratioenhanced*100 }}% if there are at least {{ enhancedthreshold }} nearby enemy champions. If Kench has not taken damage within {{ ooctimer }} seconds, Thick Skin will rapidly be consumed to heal Tahm for {{ greyhealthhealingratio }} of its value.Active: Convert all your stored Thick Skin into a Shield, lasting {{ shieldduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "3" ;
    lol:costBurn "0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "2400" ;
    lol:belongsToChampion champ:Tahm_Kench .

spell:Tahm_Kench_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "TahmKenchRWrapper" ;
    lol:spellName "Devour" ;
    lol:spellDescription "Tahm Kench devours a champion for a few seconds, dealing magic damage if they are an enemy, or shielding them if they are an ally." ;
    lol:spellTooltip "Tahm Kench devours a champion for a few seconds. He can Recast to spit them out.Enemy Champions: Require 3 stacks of An Acquired Taste. Are devoured for up to {{ enemyduration }} seconds and take {{ basedamage }} (+{{ percenthpdamage }} of their Max Health) magic damage. Tahm Kench is Slowed by {{ slowamount*100 }}% and Grounded during this effect.Ally Champions: Are devoured for up to {{ allyduration }} seconds and are granted {{ totalshield }} Shield which decays gradually after being spit out. Allies can also choose to exit early. Tahm Kench is Grounded during this effect, but can cast Abyssal Dive and gains {{ allyspeedamount*100 }}% Move Speed for {{ allyduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "0" ;
    lol:costBurn "100" ;
    lol:costType " Mana" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Tahm_Kench .

spell:Tahm_Kench_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "An Acquired Taste" ;
    lol:spellDescription "Tahm Kench puts the heft of his immense body behind his attacks, gaining extra damage based on his total health. Damaging enemy champions builds stacks of An Acquired Taste. At three stacks, he can use Devour on an enemy champion." ;
    lol:belongsToChampion champ:Tahm_Kench .

