    lol:spellId "TalonW" ;
    lol:spellName "Rake" ;
    lol:spellDescription "Talon sends out a volley of daggers that then return back to him, dealing physical damage every time it passes through an enemy. The returning blades deal bonus damage and slow units hit." ;
    lol:spellTooltip "Talon tosses a volley of blades, dealing {{ totalinitialdamage }} physical damage. The blades then return to him, dealing {{ totalreturndamage }} physical damage and Slowing by {{ movespeedslow*100 }}% for {{ slowduration }} second.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
