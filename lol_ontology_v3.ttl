champ:Lux a lol:Champion, owl:NamedIndividual ;
    lol:championId "Lux" ;
    lol:championKey "99" ;
    lol:championName "Lux" ;
    lol:championTitle "the Lady of Luminosity" ;
    lol:blurb "Luxanna Crownguard hails from Demacia, an insular realm where magical abilities are viewed with fear and suspicion. Able to bend light to her will, she grew up dreading discovery and exile, and was forced to keep her power secret, in order to preserve..." ;
    lol:lore "Luxanna Crownguard hails from Demacia, an insular realm where magical abilities are viewed with fear and suspicion. Able to bend light to her will, she grew up dreading discovery and exile, and was forced to keep her power secret, in order to preserve her family's noble status. Nonetheless, Lux's optimism and resilience have led her to embrace her unique talents, and she now covertly wields them in service of her homeland." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.04" ;
    lol:costBE "225"^^xsd:integer ;
    lol:costRP "260"^^xsd:integer ;
    lol:allyTip "Lux has great zone control abilities. Try to set up Lucent Singularity to prevent an enemy's advance or escape." ;
    lol:allyTip "If you have trouble landing Prismatic Barrier, remember that it returns to you after it reaches max range. Try positioning yourself to hit your allies with its return trip." ;
    lol:allyTip "Lucent Singularity is a great scouting tool. Try throwing it into brush before walking into it to check for ambushes." ;
    lol:enemyTip "Lux has powerful zone control abilities. Try to spread out and attack from different directions so she cannot lock down a specific area." ;
    lol:enemyTip "When retreating with low health, be prepared to dodge Lux's Final Spark, a red targeting beam fires prior to the main beam, so try to move to the side if possible." ;
    lol:hasRole role:Mage ;
    lol:hasRole role:Support ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Demacia ;
    lol:playsPosition pos:Support ;
    lol:playsPosition pos:Middle ;
