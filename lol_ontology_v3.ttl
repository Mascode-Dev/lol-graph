    lol:spellDescription "A prison of walls that slow and deal damage if broken." ;
    lol:spellTooltip "Thresh creates a prison of spectral walls, Slowing champions by {{ e3 }}% for {{ e2 }} seconds and dealing {{ totaldamage }} magic damage. Walls break after one collision, and after one is broken, the rest deal no damage and Slow for half duration.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
