spell:Urgot_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "UrgotW" ;
    lol:spellName "Purge" ;
    lol:spellDescription "Urgot slows himself while he unloads his weapon on nearby enemies. Prioritizes enemy champions Urgot has recently struck with other abilities and triggers Echoing Flames." ;
    lol:spellTooltip "Passive: Urgot's other Abilities mark the last champion hit for 5 seconds.Active: Urgot begins firing his chain gun at the closest enemy, prioritizing marked enemies. He Attacks them {{ e8 }} times a second dealing {{ damagepershot }} physical damage per shot. Urgot can move while firing and has {{ e2 }}% Slow resistance, but loses {{ e5 }} Move Speed.At max rank, this Ability lasts indefinitely and can be Toggled on and off.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/9/6/3/0" ;
    lol:costBurn "40/30/20/10/0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "490" ;
    lol:belongsToChampion champ:Urgot .

spell:Urgot_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "UrgotE" ;
    lol:spellName "Disdain" ;
    lol:spellDescription "Urgot charges in a direction, shielding himself and trampling non-champion enemies. If he catches an enemy champion, he will stop and hurl them out of his way." ;
    lol:spellTooltip "Urgot charges forward, gaining {{ etotalshieldhealth }} Shield for {{ eshieldduration }} seconds. The first champion hit is Stunned for {{ stunduration }} seconds and thrown behind Urgot. All enemies Urgot collides with take {{ edamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/15.5/15/14.5/14" ;
    lol:costBurn "60/70/80/90/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "475" ;
    lol:belongsToChampion champ:Urgot .

spell:Urgot_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "UrgotR" ;
    lol:spellName "Fear Beyond Death" ;
    lol:spellDescription "Urgot fires a chem-drill that impales the first enemy champion hit. If that champion falls below a health threshold, Urgot judges them weak and can execute them." ;
    lol:spellTooltip "Urgot fires a chem-drill, impaling the first champion hit, dealing {{ rcalculateddamage }} physical damage and Slowing for {{ rslowduration }} seconds by 1% per 1% missing Health, up to {{ rmovespeedmod }}%.If the impaled victim falls below {{ rhealththreshold }}% Health, Urgot can Recast this Ability, Suppressing the victim and dragging them to himself. On reaching Urgot, they are killed and nearby enemies are Feared for {{ rfearduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/85/70" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "2500" ;
    lol:belongsToChampion champ:Urgot .

