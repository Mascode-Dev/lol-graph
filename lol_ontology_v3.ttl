spell:Kalista_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KalistaW" ;
    lol:spellName "Sentinel" ;
    lol:spellDescription "Gain bonus damage when Kalista and her Oathsworn strike the same target. Activate to send a soul to scout out the path, revealing the area in front of it." ;
    lol:spellTooltip "Passive: When Kalista and her Oathsworn both Attack the same target, she deals {{ maxhealthdamage*100 }}% max Health magic damage. This effect has a {{ pertargetcooldown }} second Cooldown per target and a cap of {{ maximummonsterdamage }} to non-champions.Active: Kalista sends a ghost to patrol an area for three laps. Champions spotted are revealed for 4 seconds. This ability has 2 charges ({{ ammorechargetooltip }} second refresh).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
