    lol:rangeBurn "375" ;
    lol:belongsToChampion champ:Warwick .

spell:Warwick_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "WarwickR" ;
    lol:spellName "Infinite Duress" ;
    lol:spellDescription "Warwick leaps in a direction (scaling with his bonus Move Speed), suppressing the first champion he collides with for 1.5 seconds." ;
    lol:spellTooltip "Warwick leaps a huge distance that scales with his Move Speed, Suppressing the first champion he collides with while he channels for {{ rduration }} seconds. He attacks that champion 3 times over the duration, dealing {{ damagecumulative }} magic damage. Warwick heals for 100% of all damage dealt during the channel.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
