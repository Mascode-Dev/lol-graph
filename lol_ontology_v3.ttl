    lol:spellSlot "W" ;
    lol:spellId "SkarnerW" ;
    lol:spellName "Seismic Bastion" ;
    lol:spellDescription "Skarner gains a shield and creates an earthquake whose shockwave damages and slows foes." ;
    lol:spellTooltip "Skarner gains {{ initialshield }} Shield for {{ shieldduration }}s and triggers an earthquake that deals {{ damage }} magic damage and Slows nearby enemies by {{ sloweffect*-100 }}% for {{ slowduration }}s.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9/8/7/6" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:Skarner .

spell:Skarner_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "SkarnerE" ;
    lol:spellName "Ixtal's Impact" ;
    lol:spellDescription "Skarner charges forward and passes through terrain. If he collides with a champion or large monster, he'll slam them into the next wall he hits to damage and stun them." ;
    lol:spellTooltip "Skarner charges forward, steering toward the chosen direction and ignoring terrain. If he runs into a champion or large monster, Skarner drags them along for the rest of his charge.Colliding into a wall with an enemy in tow deals {{ pindamage }} physical damage to the enemy and Stuns them for {{ stunduration }}s.Skarner can Recast this Ability to end his charge early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/21/20/19/18" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1700" ;
    lol:belongsToChampion champ:Skarner .

spell:Skarner_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "SkarnerR" ;
    lol:spellName "Impale" ;
    lol:spellDescription "Skarner's tails lash forward to suppress enemy champions. Once suppressed, the victims will be dragged along by Skarner as he moves around." ;
    lol:spellTooltip "Skarner's tails lash forward, dealing {{ damage }} magic damage and Suppressing the first 3 champions he hits for {{ duration }}s. Those hit are dragged along by Skarner for the duration of this Ability.If Skarner hits at least one champion he gains {{ speedboostamount*100 }}% Move Speed for {{ speedboostduration }} seconds.If Shattered Earth is active, Skarner will cast Upheaval first.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/105/90" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "625" ;
    lol:belongsToChampion champ:Skarner .

