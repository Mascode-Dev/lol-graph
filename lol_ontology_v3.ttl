champ:Akali a lol:Champion, owl:NamedIndividual ;
    lol:championId "Akali" ;
    lol:championKey "84" ;
    lol:championName "Akali" ;
    lol:championTitle "the Rogue Assassin" ;
    lol:blurb "Abandoning the Kinkou Order and her title of the Fist of Shadow, Akali now strikes alone, ready to be the deadly weapon her people need. Though she holds onto all she learned from her master Shen, she has pledged to defend Ionia from its enemies, one..." ;
    lol:lore "Abandoning the Kinkou Order and her title of the Fist of Shadow, Akali now strikes alone, ready to be the deadly weapon her people need. Though she holds onto all she learned from her master Shen, she has pledged to defend Ionia from its enemies, one kill at a time. Akali may strike in silence, but her message will be heard loud and clear: fear the assassin with no master." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.05" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
    lol:allyTip "Akali excels at killing fragile champions. Let your team initiate and then strike at the people in the back." ;
    lol:allyTip "Twilight Shroud offers safety in even the most dangerous situations. Use that time to save up energy for a quick strike later." ;
    lol:enemyTip "Akali can still be hit by area effect spells while obscured inside Twilight Shroud. Doing so will briefly reveal her position." ;
    lol:enemyTip "Akali's Five Point Strike is powerful when used at maximum range and energy. Engage on her when she has low energy to maximize your chance of winning trades." ;
    lol:enemyTip "Return to base if your Health is low and Akali has her ultimate available." ;
    lol:hasRole role:Assassin ;
    lol:hasResourceType res:Energy ;
