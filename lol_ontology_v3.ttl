    lol:spellName "A Thousand Cuts" ;
    lol:spellDescription "Gwen's attacks deal bonus magic damage based on the targets health. She heals for a portion of the damage dealt to champions by this effect." ;
    lol:belongsToChampion champ:Gwen .

