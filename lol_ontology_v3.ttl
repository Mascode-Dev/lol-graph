spell:Ekko_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "EkkoQ" ;
    lol:spellName "Timewinder" ;
    lol:spellDescription "Ekko throws a temporal grenade that expands into a time-distortion field upon hitting an enemy champion, slowing and damaging anyone caught inside. After a delay, the grenade rewinds back to Ekko, dealing damage on its return." ;
    lol:spellTooltip "Ekko throws a device dealing {{ initialdamage }} magic damage. On hitting a champion or reaching the end of its range, it expands into a field that Slows enemies inside by {{ e2 }}%. After it expands, Ekko recalls it, dealing {{ recalldamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.5/8/7.5/7" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1075" ;
    lol:belongsToChampion champ:Ekko .

spell:Ekko_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "EkkoW" ;
    lol:spellName "Parallel Convergence" ;
    lol:spellDescription "Ekko's basic attacks deal bonus magic damage to low health enemies. He can cast Parallel Convergence to split the timeline, creating an anomaly after a few seconds that slows enemies caught inside. If Ekko enters the anomaly, he gains shielding and stuns enemies by suspending them in time." ;
    lol:spellTooltip "Passive: Ekko's Attacks against enemies below 30% Health deal {{ missinghealthpercent }} missing Health magic damage.Active: Ekko launches a chronosphere lasting 1.5 seconds after a delay that Slows enemies inside by {{ e0 }}%. If Ekko enters the sphere, he detonates it, Stunning for {{ e2 }} seconds and gaining {{ totalshield }} Shield.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/20/18/16/14" ;
    lol:costBurn "30/35/40/45/50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1600" ;
    lol:belongsToChampion champ:Ekko .

spell:Ekko_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "EkkoE" ;
    lol:spellName "Phase Dive" ;
    lol:spellDescription "Ekko rolls evasively while charging up his Z-Drive. His next attack deals bonus damage and warps reality, teleporting him to his target." ;
    lol:spellTooltip "Ekko dashes and empowers his next Attack to have bonus range, teleport him to his target, and deal an additional {{ totaldamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.5/8/7.5/7" ;
    lol:costBurn "40/45/50/55/60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Ekko .

spell:Ekko_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "EkkoR" ;
    lol:spellName "Chronobreak" ;
    lol:spellDescription "Ekko shatters his timeline, becoming untargetable and rewinding to a more favorable point in time. He returns to whenever he was a few seconds ago, and heals for a percentage of the damage received in that duration. Enemies near his arrival zone take massive damage." ;
    lol:spellTooltip "Ekko turns back time, entering Stasis while teleporting to where he was 4 seconds ago and dealing {{ totaldamage }} magic damage to nearby enemies. In addition, Ekko restores {{ totalbaseheal }} Health, increased by {{ percenthealampperpercentmissinghealth }}% for each 1% Health he lost in last 4 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "110/80/50" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Ekko .

spell:Ekko_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Z-Drive Resonance" ;
    lol:spellDescription "Every third attack or damaging spell on the same target deals bonus magic damage, and grants Ekko a burst of speed if the target is a champion." ;
    lol:belongsToChampion champ:Ekko .

