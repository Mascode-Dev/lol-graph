    lol:spellName "The Equalizer" ;
    lol:spellDescription "Rumble fires off a group of rockets, creating a wall of flames that damages and slows enemies." ;
    lol:spellTooltip "Rumble launches a line of rockets, creating a burning trail that lasts {{ trailduration }} seconds, Slowing by {{ slowamount }}% and dealing {{ damagepersecond }} magic damage per second.Rumble can control the direction of the trail by clicking and dragging while casting this Ability.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
