champ:Diana a lol:Champion, owl:NamedIndividual ;
    lol:championId "Diana" ;
    lol:championKey "131" ;
    lol:championName "Diana" ;
    lol:championTitle "Scorn of the Moon" ;
    lol:blurb "Bearing her crescent moonblade, Diana fights as a warrior of the Lunari—a faith all but quashed in the lands around Mount Targon. Clad in shimmering armor the color of winter snow at night, she is a living embodiment of the silver moon's power. Imbued..." ;
    lol:lore "Bearing her crescent moonblade, Diana fights as a warrior of the Lunari—a faith all but quashed in the lands around Mount Targon. Clad in shimmering armor the color of winter snow at night, she is a living embodiment of the silver moon's power. Imbued with the essence of an Aspect from beyond Targon's towering summit, Diana is no longer wholly human, and struggles to understand her power and purpose in this world." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.03" ;
    lol:costBE "225"^^xsd:integer ;
    lol:costRP "260"^^xsd:integer ;
    lol:allyTip "Landing Crescent Strike is critically important, but don't be afraid to miss. The cooldown is short and the mana cost is low." ;
    lol:allyTip "Consider when to cast Lunar Rush without Moonlight and when to wait for another Crescent Strike." ;
    lol:allyTip "Use Moonfall and Lunar Rush to stay on targets and activate Moonsilver Blade for extra damage." ;
    lol:enemyTip "Dodge Crescent Strike, or move to safety if you are affected by Moonlight." ;
    lol:enemyTip "Pale Cascade orbs only last a few seconds. Avoid Diana and engage her after the shield dissipates." ;
    lol:enemyTip "Diana can play very aggressively if she uses Lunar Rush without Moonlight, but you can punish her by slowing or stunning her when she has no way to get back into position." ;
    lol:hasRole role:Fighter ;
    lol:hasRole role:Assassin ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Targon ;
    lol:playsPosition pos:Jungle ;
    lol:playsPosition pos:Middle ;
    lol:hasSpell spell:Diana_Q ;
    lol:hasSpell spell:Diana_W ;
    lol:hasSpell spell:Diana_E ;
    lol:hasSpell spell:Diana_R ;
    lol:hasPassive spell:Diana_Passive ;
