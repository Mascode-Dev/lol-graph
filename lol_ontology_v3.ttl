    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Fiora .

spell:Fiora_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "FioraW" ;
    lol:spellName "Riposte" ;
    lol:spellDescription "Fiora parries all incoming damage and disables for a short time, then stabs in a direction. This stab slows the first enemy champion hit, or stuns them if Fiora blocked an immobilizing effect with this ability." ;
    lol:spellTooltip "Fiora parries all incoming damage, disables, and negative effects for {{ parryduration }} seconds, then stabs. The stab deals {{ stabdamage }} magic damage to the first champion hit and Slows Move Speed by {{ msslowpercent*-100 }}% and Attack Speed by {{ attackslowpercent*-100 }}%  for {{ ccduration }} seconds. If Fiora parries an Immobilizing effect, the stabbed enemy is Stunned rather than Slowed.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "24/22/20/18/16" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Fiora .

