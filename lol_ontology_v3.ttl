spell:Rek_Sai_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "RekSaiW" ;
    lol:spellName "Burrow / Un-burrow" ;
    lol:spellDescription "Rek'Sai burrows into the ground, gaining new abilities and increased Move Speed. Her vision range is reduced and she cannot use basic attacks.While Burrowed, Rek'Sai may cast Unburrow to knock up and damage nearby enemies." ;
    lol:spellTooltip "Unburrowed: Rek'Sai burrows into the ground, gaining access to new Abilities but cannot Attack. She gains {{ burrowedmovespeed }} Move Speed, {{ visionradiusmod*-100 }}% reduced vision range, and nearby enemies that move and are otherwise unseen will have their positions revealed to Rek'sai and her allies.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
