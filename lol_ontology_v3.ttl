spell:Hwei_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "HweiQ" ;
    lol:spellName "Subject: Disaster" ;
    lol:spellDescription "Hwei envisions a series of disasters, allowing him to paint a devastating blow.This ability replaces Hwei's abilities with damaging abilities: Devastating Fire, Severing Bolt, and Molten Fissure." ;
    lol:spellTooltip "Hwei paints visions of disaster that deal large damage to enemies.Devastating FireHwei launches a blazing fast fireball that explodes on the first enemy hit, dealing {{ tooltip_qqdamage }} plus {{ tooltip_qqbonusdamage }}% max health magic damage.Severing BoltHwei strikes over far distances with a delayed lightning bolt, dealing {{ tooltip_qwdamage }} magic damage. Hitting an Isolated or Immobilized target increases the damage up to {{ tooltip_qwbonusdamage }} magic damage, based on the target's missing health.Molten FissureHwei unleashes a path of eruptions, dealing {{ tooltip_qedamage }} magic damage in an area and leaving behind pools of lava that Slow enemies by {{ spell.hweiqe:slowpercent }}% and deal {{ tooltip_qedamagepersecond }} magic damage per second for {{ spell.hweiqe:duration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9/8/7/6" ;
    lol:costBurn "80/90/100/110/120" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Hwei .

spell:Hwei_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "HweiW" ;
    lol:spellName "Subject: Serenity" ;
    lol:spellDescription "Hwei envisions a series of serenities, allowing him to paint invigorating settings.This ability replaces Hwei's abilities with utility abilities: Fleeting Current, Pool of Reflection, and Stirring Lights." ;
    lol:spellTooltip "Hwei paints visions of serenity that provide utility for himself and allied champions.Fleeting CurrentHwei launches a current of swift waters in a line that grants allies {{ tooltip_wqmovespeed }} Move Speed.Pool of ReflectionHwei forms a protective pool that grants {{ tooltip_wwshieldamount }} Shields over time to allied champions inside reduced by {{ spell.hweiww:tooltipallymod*100 }}% for allies.Stirring LightsHwei creates three swirling lights that empower his next three Abilities or Attacks to deal an additional {{ tooltip_weonhitdamage }} magic damage and restore {{ tooltip_weonhitmanarestore }} Mana each.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/17.5/17/16.5/16" ;
    lol:costBurn "90/95/100/105/110" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Hwei .

spell:Hwei_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "HweiE" ;
    lol:spellName "Subject: Torment" ;
    lol:spellDescription "Hwei envisions a series of torments, allowing him to paint controlling visages.This ability replaces Hwei's abilities with crowd control abilities: Grim Visage, Gaze of the Abyss, and Crushing Maw." ;
    lol:spellTooltip "Hwei paints visions of torment that control enemies.Grim VisageHwei launches a terrifying face that causes the first enemy hit to Flee for {{ tooltip_eqfleeduration }} second(s) and take {{ tooltip_eqdamage }} magic damage.Gaze of the AbyssHwei forms an eye that lingers and provides vision locking onto the first enemy champion that enters and launching a homing missile that Roots the first enemy hit for {{ tooltip_ewrootduration }} seconds dealing {{ tooltip_ewdamage }} magic damage.Crushing MawHwei paints a set of jaws at a target location that Drags enemies to the center dealing {{ tooltip_eedamage }} magic damage and Slowing enemies caught by {{ tooltip_eeslowamount }}% decaying over 1.25 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "13/12.5/12/11.5/11" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
