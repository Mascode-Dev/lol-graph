champ:Aphelios a lol:Champion, owl:NamedIndividual ;
    lol:championId "Aphelios" ;
    lol:championKey "523" ;
    lol:championName "Aphelios" ;
    lol:championTitle "the Weapon of the Faithful" ;
    lol:blurb "Emerging from moonlight's shadow with weapons drawn, Aphelios kills the enemies of his faith in brooding silence—speaking only through the certainty of his aim, and the firing of each gun. Though fueled by a poison that renders him mute, he is guided by..." ;
    lol:lore "Emerging from moonlight's shadow with weapons drawn, Aphelios kills the enemies of his faith in brooding silence—speaking only through the certainty of his aim, and the firing of each gun. Though fueled by a poison that renders him mute, he is guided by his sister Alune. From her distant temple sanctuary, she pushes an arsenal of moonstone weapons into his hands. For as long as the moon shines overhead, Aphelios will never be alone." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.04" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Each of Aphelios' weapons have different strengths, so try to find the right situation for your current weapons. " ;
    lol:enemyTip "Each of Aphelios' weapons have different weaknesses, try to exploit the ones that work best for your champion. Watch out for the purple Gravity gun, it can root you." ;
    lol:hasRole role:Marksman ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Targon ;
    lol:playsPosition pos:Bot_ADC ;
