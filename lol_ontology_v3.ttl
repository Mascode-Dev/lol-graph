    lol:spellName "Assassin's Path" ;
    lol:spellDescription "Talon vaults over any terrain or structure, up to a max distance. This ability has a low cooldown, but puts the used terrain on a long cooldown." ;
    lol:spellTooltip "Talon vaults over the nearest terrain or structure. Talon cannot dash over the same terrain more than once every {{ wallcd }} seconds.{{ spellmodifierdescriptionappend }}" ;
