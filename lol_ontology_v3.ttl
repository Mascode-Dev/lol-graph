    lol:spellName "Command: Attack" ;
    lol:spellDescription "Orianna commands her Ball to fire toward a target location, dealing magic damage to targets along the way (deals less damage to subsequent targets). Her Ball remains at the target location after." ;
    lol:spellTooltip "Orianna commands her Ball to move to an area, dealing {{ totaldamagetooltip }} magic damage to surrounding enemies and to enemies it passes through. Deals {{ e2 }}% less damage to all enemies after the first.{{ spellmodifierdescriptionappend }}" ;
