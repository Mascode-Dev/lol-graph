    lol:spellId "MalzaharR" ;
    lol:spellName "Nether Grasp" ;
    lol:spellDescription "Malzahar channels the essence of the Void to suppress an enemy champion over a zone of damaging negative energy." ;
    lol:spellTooltip "Malzahar Suppresses an enemy champion and deals {{ totaldamagetooltip }} magic damage over {{ e4 }} seconds. A zone of negative energy is created around his target dealing {{ zonedamagetooltip }} max Health magic damage over {{ e3 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/110/80" ;
