spell:K_Sante_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "KSanteQ" ;
    lol:spellName "Ntofo Strikes" ;
    lol:spellDescription "K'Sante strikes, damaging and slowing enemies in a short line.On hit, grants a stack of Ntofo Strikes. At 2 stacks, K'Sante fires a shockwave that pulls enemies in.When All Out, cooldown is reduced." ;
    lol:spellTooltip "K'Sante slams his weapon, dealing {{ basedamage }} physical damage and Slowing enemies by {{ slowpercent*100 }}% for {{ slowduration }}s. If he hits, he gains a stack of Ntofo Strikes for {{ recastwindow }} seconds. At 2 stacks, he instead fires a shockwave that Stuns and Pulls enemies for {{ stunduration }} second.All Out: Cooldown is reduced by {{ rcooldownreduction.0*100 }}%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "3.5" ;
    lol:costBurn "20" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "450" ;
    lol:belongsToChampion champ:K_Sante .

spell:K_Sante_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KSanteW" ;
    lol:spellName "Path Maker" ;
    lol:spellDescription "K'Sante charges up, taking reduced damage, then dashes, knocking back and stunning enemies.When All Out, deals increased damage and no longer knocks back or stuns." ;
    lol:spellTooltip "K'Sante raises his weapons defensively for {{ mindurationtooltip }}-{{ maxduration.1 }}s, becoming Unstoppable and reducing incoming damage by {{ damagereduction*100 }}%. Then, he rams forward, dealing {{ basedamage }} + {{ totalmaxhealthdamage }} max Health physical damage. Enemies hit are Knocked Back and Stunned for {{ minknockbackduration }}-{{ maxknockbackduration }}s (based on charge time).All Out: Cooldown is refreshed. Deals an additional {{ rdamageincreasemin*100 }}-{{ rdamageincreasemax*100 }}% damage as true damage (based on charge time), damage reduction is increased to {{ rdamagereduction*100 }}% and dash speed is increased, but no longer Knocks Back or Stuns.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13/12/11/10" ;
    lol:costBurn "40/45/50/55/60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:K_Sante .

spell:K_Sante_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "KSanteE" ;
    lol:spellName "Footwork" ;
    lol:spellDescription "K'Sante dashes and gains a shield. If targeting an ally, K'Sante dashes to the ally with increased range and both gain a shield.When All Out, cooldown is reduced and speed is increased." ;
    lol:spellTooltip "K'Sante dashes, gaining {{ totalshield }} Shield for {{ shieldduration }} seconds. If dashing to an ally, the distance of the dash is significantly increased and the ally is also Shielded.All Out: Cooldown is decreased by {{ cooldownmodao*100 }}% and dash speed is increased.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9.5/9/8.5/8" ;
    lol:costBurn "45/50/55/60/65" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "525" ;
    lol:belongsToChampion champ:K_Sante .

spell:K_Sante_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "KSanteR" ;
    lol:spellName "All Out" ;
    lol:spellDescription "K'Sante knocks an enemy back, launching them through any wall in their path. Then, K'Sante goes All Out and dashes after them, gaining increased damage, healing, and transformed abilities at the cost of reduced defenses." ;
    lol:spellTooltip "K'Sante shatters his ntofos to Knock Back an enemy champion, dealing {{ basedamage }} physical damage, then dashes behind them and goes All Out for {{ alloutduration }}s. If the enemy would hit a wall, they are Knocked Back through the wall and K'Sante strikes them again for {{ totaldamageslamdown }} physical damage.While All Out, K'Sante's Abilities are upgraded and he gains {{ attackspeed*100 }}% Attack Speed, {{ armorpenpercent*100 }}% Bonus Armor Penetration, and {{ omnivamp*100 }}% Omnivamp, but loses {{ healthlost*100 }}% max Health, {{ defenseslost*100 }}% Bonus Armor, and {{ defenseslost*100 }}% Bonus Magic Resistance.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "250" ;
    lol:belongsToChampion champ:K_Sante .

