spell:Shyvana_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "ShyvanaDoubleAttack" ;
    lol:spellName "Twin Bite" ;
    lol:spellDescription "Shyvana strikes twice on her next attack and grants herself Attack Speed for her next attacks. Basic attacks reduce the cooldown of Twin Bite by 0.5 seconds.Dragon Form: Twin Bite cleaves all units in front of Shyvana." ;
    lol:spellTooltip "Shyvana's next Attack strikes twice, dealing {{ firsthitdamagecalc }} then {{ secondhitdamagecalc }} physical damage. Her next 2 Attacks gain {{ bonusas }}% Attack Speed.Attacks reduce this Ability's Cooldown by {{ cdreductiononhit }} seconds.Dragon Form: The empowered Attacks hit all units in front of Shyvana.This Ability triggers spell effects upon dealing damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7.5/7/6.5/6" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Shyvana .

spell:Shyvana_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "ShyvanaImmolationAura" ;
    lol:spellName "Burnout" ;
    lol:spellDescription "Shyvana surrounds herself in fire, dealing magic damage per second to nearby enemies and moving faster for 3 seconds, part of this damage is applied again when Shyvana basic attacks an enemy with Burnout active. The Move Speed reduces over the duration of the spell. Basic attacks extend the duration of Burnout. Dragon Form: Burnout grows in size." ;
    lol:spellTooltip "Shyvana summons a flame storm around her, gaining {{ finalmsperc }} decaying Move Speed and dealing {{ damagepertickcalc }} magic damage per second for {{ baseduration }} seconds. The flame storm also causes Shyvana's Attacks to deal an additional {{ damageonhitcalc }} magic damage to surrounding enemies and extend this Ability's duration by {{ bonusdurationonhit }} second.Dragon Form: The size of the flame storm is increased.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Shyvana .

spell:Shyvana_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "ShyvanaFireball" ;
    lol:spellName "Flame Breath" ;
    lol:spellDescription "Shyvana unleashes a fireball that deals damage to all enemies it encounters and leaves cinders on the target, marking them for 5 seconds. Shyvana's basic attacks on marked targets deal a percentage of their maximum Health as damage on-hit.Dragon Form: Flame Breath explodes on impact or at target location, dealing bonus damage and scorching the earth for a short duration." ;
    lol:spellTooltip "Shyvana unleashes a fireball that deals {{ damagecalc }} magic damage and marks for {{ markduration }} seconds. The fireball stops on the first champion hit.Shyvana's Attacks against marked targets deal an additional {{ percenthpdamageonhit }}% max Health magic damage.Dragon Form: The fireball explodes once it ends, dealing an additional {{ dragonexplosioncalc }} magic damage and scorching the earth, dealing {{ dragondamagetotalcalc }} magic damage over 4 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "925" ;
    lol:belongsToChampion champ:Shyvana .

spell:Shyvana_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "ShyvanaTransformCast" ;
    lol:spellName "Dragon's Descent" ;
    lol:spellDescription "Shyvana transforms into a dragon and takes flight to a target location. Enemies along her path take damage and are knocked toward her target location.Shyvana passively gains Fury per second and gains 2 Fury on basic attack." ;
    lol:spellTooltip "Passive: Shyvana generates {{ furygainpertick }} Fury every second, and Attacks generate an extra {{ furygainonhit }} Fury.Active: Shyvana transforms into Dragon Form, gaining {{ bonushp }} max Health and flying forward, dealing {{ damagecalc }} magic damage and Knocking enemies toward her target location.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "0" ;
    lol:costBurn "0" ;
    lol:costType " Fury a Second" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Shyvana .

