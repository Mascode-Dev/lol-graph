    lol:spellSlot "E" ;
    lol:spellId "TeemoE" ;
    lol:spellName "Toxic Shot" ;
    lol:spellDescription "Each of Teemo's attacks will poison the target, dealing damage on impact and each second after for 4 seconds." ;
    lol:spellTooltip "Passive: Teemo's Attacks apply poison, dealing an additional {{ impactcalculateddamage }} magic damage plus {{ totaldotdamage }} magic damage over {{ poisonduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
