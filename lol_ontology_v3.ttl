    lol:spellSlot "E" ;
    lol:spellId "RenektonSliceAndDice" ;
    lol:spellName "Slice and Dice" ;
    lol:spellDescription "Renekton dashes, dealing damage to units along the way. Empowered, Renekton deals bonus damage and reduces the Armor of units hit." ;
    lol:spellTooltip "Renekton dashes, dealing {{ basicdamage }} physical damage. He generates {{ minionragegeneration }} Fury per non-champion and {{ championragegeneration }} Fury per champion hit. Hitting at least one enemy allows Renekton to Recast this Ability once for {{ dicetimer }} seconds. Fury Bonus: The Recast dash deals {{ empdamage }} physical damage instead and removes {{ enragedarmorshred }}% Armor for {{ shredtimer }} seconds. Does not generate Fury.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/14.5/13/11.5/10" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "450" ;
