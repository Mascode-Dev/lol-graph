    lol:spellName "Umbra Blades" ;
    lol:spellDescription "Every few seconds, Nocturne's next attack strikes surrounding enemies for bonus physical damage and heals himself. Nocturne's basic attacks reduce this cooldown." ;
    lol:belongsToChampion champ:Nocturne .

