spell:Urgot_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "UrgotQ" ;
    lol:spellName "Corrosive Charge" ;
    lol:spellDescription "Fires an explosive charge at the target location, dealing physical damage and slowing enemies caught in the explosion." ;
    lol:spellTooltip "Urgot fires an explosive charge, dealing {{ totaldamage }} physical damage and Slowing by {{ slowamount*100 }}% for {{ slowduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
