    lol:spellSlot "E" ;
    lol:spellId "TryndamereE" ;
    lol:spellName "Spinning Slash" ;
    lol:spellDescription "Tryndamere slices toward a target unit, dealing damage to enemies in his path." ;
    lol:spellTooltip "Tryndamere spins through his enemies, dealing {{ totaldamage }} physical damage and generating {{ nonchampfurygain }} Fury per enemy hit, increased to {{ champfurygain }} Fury against enemy champions.This Ability's Cooldown is reduced by {{ nonchampcdrefund }} seconds when Tryndamere critically strikes, and reduced by {{ champcdrefund }} seconds when critically striking a champion.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Tryndamere .

spell:Tryndamere_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "UndyingRage" ;
    lol:spellName "Undying Rage" ;
    lol:spellDescription "Tryndamere's lust for battle becomes so strong that he is unable to die, no matter how wounded he becomes." ;
    lol:spellTooltip "Tryndamere becomes completely immune to death for {{ e3 }} seconds, refusing to be reduced below {{ e2 }} Health, and instantly gains {{ e1 }} Fury.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Tryndamere .

