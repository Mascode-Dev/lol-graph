spell:Ornn_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "OrnnW" ;
    lol:spellName "Bellows Breath" ;
    lol:spellDescription "Ornn advances, breathing fire. Enemies hit by the final gout of flame become Brittle." ;
    lol:spellTooltip "Ornn stomps forward Unstoppably while breathing fire, dealing {{ maxpercenthpperticktooltip }}% max Health magic damage over {{ breathduration }} seconds. Enemies hit by the final bout of flame become Brittle for {{ brittleduration }} seconds.Immobilizing effects on Brittle targets have their duration increased by 30% and deal an additional {{ brittlepercentmaxhpcalc }} max Health magic damage. Ornn's Attacks against Brittle targets Knock them Back, dealing the additional damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11.5/11/10.5/10" ;
    lol:costBurn "45/50/55/60/65" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Ornn .

spell:Ornn_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "OrnnE" ;
    lol:spellName "Searing Charge" ;
    lol:spellDescription "Ornn charges, dealing damage to enemies he passes through. If Ornn collides with terrain while charging, the impact creates a shockwave around him which deals damage and knocks up enemies." ;
    lol:spellTooltip "Ornn charges, dealing {{ totaldamage }} physical damage. If Ornn rams into terrain, he creates a shockwave that Knocks Up enemies for {{ knockupduration }} seconds and applies the same damage to those not hit by the charge.Ornn's charge destroys magma pillars and terrain created by enemies.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13.5/13/12.5/12" ;
    lol:costBurn "35/40/45/50/55" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "450" ;
    lol:belongsToChampion champ:Ornn .

spell:Ornn_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "OrnnR" ;
    lol:spellName "Call of the Forge God" ;
    lol:spellDescription "Ornn summons a massive elemental at a location which travels toward him with increasing speed. Enemies run over by the elemental take damage, are slowed and are made Brittle. Ornn can recast the ability to charge into the elemental, redirecting it in the direction he hits it, causing the elemental to affect any enemies it runs over to be knocked up, dealing the same damage and re-applying Brittle." ;
    lol:spellTooltip "Ornn summons a massive lava elemental, which stampedes towards him, dealing {{ rdamagecalc }} magic damage, applying Brittle to, and Slowing enemies hit by {{ rslowpercentbasepremath }}% for {{ brittledurationtooltiponly }} seconds.Ornn can Recast to dash with a headbutt. If he dashes into the elemental, he redirects and empowers it, causing it to Knock Up the first champion for {{ rstunduration }} second and subsequent champions for {{ minstun }} seconds. The elemental also deals {{ rdamagecalc }} magic damage and reapplies Brittle.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/120/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "2500" ;
    lol:belongsToChampion champ:Ornn .

spell:Ornn_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Living Forge" ;
    lol:spellDescription "Ornn gains an additional bonus Armor and Magic Resist from all sources.Ornn can spend gold to forge non-consumable items anywhere.Additionally, he can create masterwork items for himself and for his allies." ;
    lol:belongsToChampion champ:Ornn .

