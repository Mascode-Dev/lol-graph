spell:Evelynn_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "EvelynnQ" ;
    lol:spellName "Hate Spike" ;
    lol:spellDescription "Evelynn strikes out with her Lasher, dealing damage to the first unit hit. Then, Evelynn can shoot a line of spikes at nearby foes a few times." ;
    lol:spellTooltip "Evelynn strikes with her Lasher, dealing {{ missiledamage }} magic damage to the first enemy hit and causing Evelynn's next 3 Attacks or Abilities on that unit to deal an additional {{ totalbonusdamage }} magic damage. Evelynn can Recast this Ability up to {{ qstackcount }} times.Recast: Evelynn fires spikes through the nearest enemy, dealing {{ missiledamage }} magic damage to all enemies hit.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "40/45/50/55/60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
    lol:belongsToChampion champ:Evelynn .

spell:Evelynn_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "EvelynnW" ;
    lol:spellName "Allure" ;
    lol:spellDescription "Evelynn curses her target, causing her next attack or spell after a delay to charm her target and reduce their magic resist." ;
    lol:spellTooltip "Evelynn marks a champion or monster for 5 seconds. If Evelynn hits the target with an Attack or Ability, she will expunge the mark, refund its cost, and Slow the target by {{ slowamount*100 }}% for {{ slowduration }} seconds.If the mark lasts at least 2.5 seconds, expunging it has extra effects:Against champions: Charms them for {{ charmduration }} second(s) and removes {{ mrshred*100 }}% Magic Resist for {{ shredduration }} seconds.Against monsters: Charms them for {{ monstercharm }} seconds and deals {{ monsterdamagetotaltooltip }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "15/14/13/12/11" ;
    lol:costBurn "60/70/80/90/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1200/1300/1400/1500/1600" ;
    lol:belongsToChampion champ:Evelynn .

spell:Evelynn_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "EvelynnE" ;
    lol:spellName "Whiplash" ;
    lol:spellDescription "Evelynn whips her target with her Lasher, dealing damage. She then gains Move Speed for a short duration." ;
    lol:spellTooltip "Evelynn whips an enemy, dealing {{ basedamage }} plus {{ percenthealthbasetooltip }} max Health magic damage. Evelynn gains {{ speedamount*100 }}% Move Speed for {{ speedduration }} seconds.Entering Demon Shade refreshes this Ability's cooldown and empowers it. When this Ability is empowered, Evelynn dashes to the target and deals {{ empowereddamage }} plus {{ percenthealthempoweredtooltip }} max Health magic damage to her target and everyone she passes through instead.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8" ;
    lol:costBurn "40/45/50/55/60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "210" ;
    lol:belongsToChampion champ:Evelynn .

spell:Evelynn_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "EvelynnR" ;
    lol:spellName "Last Caress" ;
    lol:spellDescription "Evelynn briefly goes untargetable and decimates the area in front of her before warping backwards a long distance." ;
    lol:spellTooltip "Evelynn unleashes her demonic energy, dealing heavy damage, becoming Untargetable and teleporting backwards. She deals {{ damage }} magic damage, increased to {{ critdamage }} against enemies below 30% Health. Upon cast, set Demon Shade to a 1.25 second cooldown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Evelynn .

spell:Evelynn_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Demon Shade" ;
    lol:spellDescription "When out of combat, Evelynn enters Demon Shade. Demon Shade heals Evelynn when she is low on health and grants Camouflage after level 6." ;
