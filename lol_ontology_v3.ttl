    lol:spellName "Tidal Wave" ;
    lol:spellDescription "Summons a massive Tidal Wave that knocks up, slows, and damages enemies. Allies hit gain double the effect of Surging Tides." ;
    lol:spellTooltip "Nami summons a tidal wave, Knocking Up for 0.5 seconds, Slowing by {{ e4 }}%, and dealing {{ totaldamage }} magic damage. The duration of the Slow increases based on distance the wave traveled, up to {{ e5 }} seconds.Allies hit by the wave gain double the effect of Surging Tides.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
