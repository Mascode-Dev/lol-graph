spell:Annie_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "AnnieR" ;
    lol:spellName "Summon: Tibbers" ;
    lol:spellDescription "Annie wills her bear Tibbers to life, dealing damage to units in the area. Tibbers can attack and also burns enemies that stand near him." ;
    lol:spellTooltip "Passive: Annie gains {{ rpercentpenbuff*100 }}% Magic Penetration.Annie summons her bear Tibbers, dealing {{ initialburstdamage }} magic damage. For the next {{ tibberslifetime }} seconds, Tibbers burns nearby enemies for {{ tibbersauradamage }} magic damage per second.Tibbers becomes enraged when summoned, if Annie stuns an enemy champion, and if Annie dies. When enraged, Tibbers gains 275% Attack Speed and 100% Move Speed decaying over 3 seconds.Recast: Manually issue orders to Tibbers.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "130/115/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Annie .

