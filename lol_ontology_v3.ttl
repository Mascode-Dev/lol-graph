spell:Viego_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "ViegoQ" ;
    lol:spellName "Blade of the Ruined King" ;
    lol:spellDescription "Viego's spectral blade passively deals bonus percent current Health damage On-Hit and strikes twice vs. enemies he recently hit with an Ability, stealing Health.Viego can activate this Ability to thrust his zweihander forward, impaling enemies in front of him." ;
    lol:spellTooltip "Passive: Viego's Attacks deal an additional {{ totalpercenthealthonhit }} current Health physical damage. His first Attack against an enemy he has recently damaged with an Ability hits a second time, dealing {{ secondattackdamage }} physical damage and restoring {{ healmodvschamps*100 }}% of damage dealt as Health. These bonuses are kept during Possession.Active: Viego stabs forward, dealing {{ totaldamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "5/4.5/4/3.5/3" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Viego .

spell:Viego_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "ViegoW" ;
    lol:spellName "Spectral Maw" ;
    lol:spellDescription "Viego charges up before dashing forward, releasing a ball of concentrated Black Mist that stuns the first enemy hit." ;
    lol:spellTooltip "Begin Charging: Viego begins gathering Mist, Slowing himself by {{ selfslowpercent*100 }}%.Release: Viego dashes forward and hurls the gathered Mist. Deals {{ totaldamage }} magic damage and Stuns the first enemy hit for {{ stunduration }} to {{ maxstuntt }} seconds based on charge time.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Viego .

spell:Viego_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "ViegoE" ;
    lol:spellName "Harrowed Path" ;
    lol:spellDescription "Viego commands the Black Mist to haunt and surround a piece of terrain. Viego can hide in the Mist as a wraith, gaining camouflage, Move Speed, and Attack Speed." ;
    lol:spellTooltip "Viego sends forth a spectre to haunt the first terrain hit, surrounding it with Mist for {{ mistduration }} seconds. Viego gains Camouflage, {{ totalmovespeed }} Move Speed, and {{ attackspeed*100 }}% Attack Speed while inside the Mist.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/12/10/8/6" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Viego .

spell:Viego_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "ViegoR" ;
    lol:spellName "Heartbreaker" ;
    lol:spellDescription "Viego teleports to a nearby location and executes an enemy champion on arrival, piercing their heart and causing a destructive shockwave around them that knocks away their allies." ;
    lol:spellTooltip "Viego discards any souls he is currently Possessing and teleports. On arrival he Attacks the champion with the lowest percent Health, briefly Slowing them by {{ slowpercent*100 }}% and dealing {{ totaldamage }} + {{ totalpercenthealth }}% missing Health physical damage. Other nearby enemies are Knocked Back and take {{ totaldamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Viego .

spell:Viego_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Sovereign's Domination" ;
    lol:spellDescription "Enemies who fall before Viego become wraiths. By attacking a wraith, Viego temporarily seizes control of the dead enemy's body, healing for a percentage of his target's max health and gaining access to their basic abilities and items. He replaces their Ultimate with a free cast of his own." ;
    lol:belongsToChampion champ:Viego .

