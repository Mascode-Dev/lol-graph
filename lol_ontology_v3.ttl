    lol:spellId "SejuaniE" ;
    lol:spellName "Permafrost" ;
    lol:spellDescription "Sejuani freezes and stuns an enemy champion that has maximum Frost stacks." ;
    lol:spellTooltip "Passive: Nearby melee allied champions' Attacks apply a stack to champions and jungle monsters.Active: Sejuani deals {{ totaldamage }} magic damage to target enemy with 4 stacks and Stuns them for {{ e1 }} second. {{ spellmodifierdescriptionappend }}" ;
