spell:Garen_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "GarenQ" ;
    lol:spellName "Decisive Strike" ;
    lol:spellDescription "Garen gains a burst of Move Speed, breaking free of all slows affecting him. His next attack strikes a vital area of his foe, dealing bonus damage and silencing them." ;
    lol:spellTooltip "Garen removes all Slowing effects on him and gains {{ movementspeedamount*100 }}% Move Speed for {{ movementspeedduration }} second(s).His next Attack Silences for {{ silenceduration }} seconds and does {{ totaldamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Garen .

spell:Garen_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "GarenW" ;
    lol:spellName "Courage" ;
    lol:spellDescription "Garen passively increases his Armor and Magic Resist by killing enemies. He may also activate this ability to give him a shield and tenacity for a brief moment followed by a lesser amount of damage reduction for a longer duration." ;
    lol:spellTooltip "Passive: Garen has {{ resistsfortooltip }} bonus Armor and {{ resistsfortooltip }} bonus Magic Resist. Killing units permanently grants {{ resistgainonkilltooltip }} resists, up to a max of {{ resistmax }}.Active: Garen steels his courage for {{ drduration }} seconds, reducing incoming damage by {{ drpercent*100 }}%. He also gains {{ totalshield }} Shield and {{ upfronttenacity*100 }}% Tenacity for {{ upfrontduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/19.5/17/14.5/12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Garen .

spell:Garen_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "GarenE" ;
    lol:spellName "Judgment" ;
    lol:spellDescription "Garen rapidly spins his sword around his body, dealing physical damage to nearby enemies." ;
    lol:spellTooltip "Garen rapidly spins his sword for {{ duration }} seconds, dealing {{ totaldamage }} physical damage {{ f1 }} times over the duration. The nearest enemy takes {{ nearestenemybonus*100 }}% increased damage. Champions hit by {{ stackstoshred }} strikes lose {{ shredamount*100 }}% Armor for {{ shredduration }} seconds.Recast: Garen ends this Ability early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.25/7.5/6.75/6" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Garen .

