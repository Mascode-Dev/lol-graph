spell:Gragas_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "GragasQ" ;
    lol:spellName "Barrel Roll" ;
    lol:spellDescription "Gragas rolls his cask to a location, which can be activated to explode or will explode on its own after 4 seconds. The potency of the explosion increases over time. Enemies struck by the blast have their Move Speed slowed." ;
    lol:spellTooltip "Gragas rolls a cask that explodes after {{ e4 }} seconds, dealing between {{ mindamage }} magic damage and {{ maxdamage }} magic damage and Slowing for between {{ e2 }} and {{ effect2amount*1.5 }}% for {{ e3 }} seconds. The damage and Slow increase with time the cask spent before exploding. Gragas can Recast to detonate the cask early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9/8/7/6" ;
    lol:costBurn "80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Gragas .

spell:Gragas_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "GragasW" ;
    lol:spellName "Drunken Rage" ;
    lol:spellDescription "Gragas samples his latest brew for 1 second. After finishing, he becomes boisterous and belligerent, dealing magic damage to all nearby enemies on his next basic attack and reducing damage received." ;
    lol:spellTooltip "Gragas samples his brew, reducing incoming damage by {{ damagereduction }} for {{ defenseduration }} seconds and empowering his next Attack to deal an additional {{ totaldamage }} plus {{ maxhppercentdamage }}% max Health magic damage to the target and surrounding enemies.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "5" ;
    lol:costBurn "30" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "20" ;
    lol:belongsToChampion champ:Gragas .

