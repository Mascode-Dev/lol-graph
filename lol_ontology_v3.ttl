    lol:spellSlot "Q" ;
    lol:spellId "ZacQ" ;
    lol:spellName "Stretching Strikes" ;
    lol:spellDescription "Zac stretches an arm, grabbing an enemy. Attacking a different enemy will cause him to throw both targets towards each other." ;
    lol:spellTooltip "Zac stretches his arm out, attaching it to the first enemy hit to deal {{ totaldamage }} magic damage and briefly Slow them. Zac's next Attack gains increased range and applies the same damage and Slow. If Zac hits a different enemy with this Attack, he Knocks Up both towards each other. If they collide, they and surrounding enemies take {{ totaldamage }} magic damage and are briefly Slowed.{{ spellmodifierdescriptionappend }}" ;
