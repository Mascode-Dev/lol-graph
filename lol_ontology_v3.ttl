spell:Gnar_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "GnarQ" ;
    lol:spellName "Boomerang Throw / Boulder Toss" ;
    lol:spellDescription "Gnar throws a boomerang that damages and slows enemies it hits before returning to him. If he catches the boomerang its cooldown is reduced.Mega Gnar instead throws a boulder that stops on the first unit hit, damaging and slowing everything nearby. It can then be picked up to reduce the cooldown." ;
    lol:spellTooltip "Mini Gnar: Gnar throws a boomerang that deals {{ spell.gnarq:minitotaldamage }} physical damage and Slows by {{ spell.gnarq:slowamount*100 }}% for {{ spell.gnarq:slowduration }} seconds. The boomerang returns after hitting an enemy, dealing reduced damage to subsequent targets. Each enemy can only be hit once. Catching the boomerang reduces its Cooldown by {{ spell.gnarq:minicdrefund*100 }}%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/14.5/13/11.5/10" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "1100" ;
    lol:belongsToChampion champ:Gnar .

spell:Gnar_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "GnarW" ;
    lol:spellName "Hyper / Wallop" ;
    lol:spellDescription "Gnar's attacks and spells hype him up, dealing bonus damage and granting him Move Speed.Mega Gnar is too enraged to be hyper and instead can rear up on his hind legs and smash down on the area in front of him, stunning enemies in an area." ;
    lol:spellTooltip "Mini Gnar Passive: Every third Attack or Ability on the same enemy deals an additional {{ spell.gnarw:minitotaldamage }} plus {{ spell.gnarw:minipercenthpdamage*100 }}% max Health magic damage and grants {{ spell.gnarr:rhypermovementspeedpercent }}% Move Speed decaying over {{ spell.gnarw:minihasteduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "7" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Gnar .

spell:Gnar_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "GnarE" ;
    lol:spellName "Hop / Crunch" ;
    lol:spellDescription "Gnar leaps to a location and bounces off the head of any unit he lands on, traveling further.Mega Gnar is too large to bounce and instead lands with earth-shattering force, dealing damage in an area around him." ;
    lol:spellTooltip "Mini Gnar: Gnar leaps, gaining {{ spell.gnare:minibas*100 }}% Attack Speed for {{ spell.gnare:miniasduration }} seconds. If Gnar lands on a unit he will bounce off it, traveling further. Bouncing off an enemy deals {{ spell.gnare:minitotaldamage }} physical damage and briefly Slows by {{ spell.gnare:movespeedmod*-100 }}%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/19.5/17/14.5/12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "475" ;
    lol:belongsToChampion champ:Gnar .

spell:Gnar_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "GnarR" ;
    lol:spellName "GNAR!" ;
    lol:spellDescription "Mega Gnar throws everything around him in a chosen direction, dealing damage and slowing them.  Any enemy that hits a wall is stunned and takes bonus damage." ;
    lol:spellTooltip "Mini Gnar Passive: Increase Hyper's Move Speed.Mega Gnar: Gnar tosses nearby enemies, dealing {{ damage }} physical damage, Knocking Back, and Slowing them by {{ rslowpercent }}% for {{ rccduration }} seconds. Enemies that hit a wall instead take {{ walldamage }} physical damage and are Stunned.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "90/60/30" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "590" ;
    lol:belongsToChampion champ:Gnar .

spell:Gnar_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Rage Gene" ;
    lol:spellDescription "While in combat Gnar generates Rage. At maximum Rage his next ability will transform him into Mega Gnar, granting increased survivability and access to new spells." ;
    lol:belongsToChampion champ:Gnar .

