    lol:spellTooltip "Renekton surrounds himself with dark energies for {{ buffduration }} seconds, gaining {{ healthgain }} max Health and {{ furyoncast }} Fury. While active, he deals {{ totaldamagepersecond }} magic damage and gains {{ furypersecond }} Fury per second.{{ spellmodifierdescriptionappend }}" ;
