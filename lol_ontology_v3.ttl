spell:Ambessa_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "AmbessaQ" ;
    lol:spellName "Cunning Sweep / Sundering Slam" ;
    lol:spellDescription "Ambessa sweeps her twin drakehounds in a semicircle in front of her, dealing bonus damage to enemies hit by the blades. Striking an enemy will transform the next cast of this ability for a short period of time, causing her to slam her twin drakehounds down in a line in front of her, dealing bonus damage to the first enemy hit." ;
    lol:spellTooltip "Cunning Sweep: Ambessa sweeps her blades forward, dealing {{ calc_damage_1_max }} + {{ calc_damage_1_percent_max }} max Health physical damage to enemies at the edge of the strike. All other enemies take {{ calc_damage_1_min_ratio }} damage. Striking an enemy readies a Sundering Slam.Sundering Slam: Ambessa slams her blades down, dealing {{ calc_damage_2_max }} + {{ calc_damage_2_percent_max }} max Health physical damage against the first enemy hit. All other enemies take {{ calc_damage_2_min_ratio }} damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13/12/11/10" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Ambessa .

