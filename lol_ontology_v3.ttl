    lol:spellSlot "E" ;
    lol:spellId "NocturneUnspeakableHorror" ;
    lol:spellName "Unspeakable Horror" ;
    lol:spellDescription "Nocturne plants a nightmare into his target's mind, dealing damage each second and applying fear to the target if they do not get out of range by the end of the duration." ;
    lol:spellTooltip "Passive: Nocturne gains {{ tooltipfearms*100 }}% Move Speed toward Feared enemies.Active: Nocturne plants a nightmare tether into his target, dealing {{ totaldamage }} magic damage over {{ e3 }} seconds. If the tether remains unbroken, the target is Feared for {{ e2 }} second(s).{{ spellmodifierdescriptionappend }}" ;
