spell:Janna_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "HowlingGale" ;
    lol:spellName "Howling Gale" ;
    lol:spellDescription "By creating a localized change in pressure and temperature, Janna is able to create a small storm that grows in size with time. She can activate the spell again to release the storm. On release this storm will fly towards the direction it was cast in, dealing damage and knocking away any enemies in its path." ;
    lol:spellTooltip "Janna summons a tornado that grows stronger over {{ maxduration }} seconds then blows along its path. It deals {{ minimumdamage }} - {{ maxdamage }} magic damage and Knocks Up for {{ baseknockup }} - {{ maxknockup }} seconds. The distance, damage, and Knock Up duration increase based on how much the tornado grew. Janna can Recast to send the tornado early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14" ;
    lol:costBurn "90/95/100/105/110" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1075" ;
    lol:belongsToChampion champ:Janna .

spell:Janna_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "SowTheWind" ;
    lol:spellName "Zephyr" ;
    lol:spellDescription "Janna summons an air elemental that passively increases her Move Speed and enables her to pass through units. She may also activate this ability to deal damage and slow an enemy's Move Speed." ;
    lol:spellTooltip "Passive: Janna gains {{ totalms }} Move Speed and is Ghosted.Active: Janna's elemental strikes an enemy, Slowing them by {{ totalslow }} for {{ slowduration }} seconds, and dealing {{ totaldamage }} + {{ spell.tailwindself:bonusdamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7.5/7/6.5/6" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "4294967295" ;
    lol:belongsToChampion champ:Janna .

spell:Janna_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "EyeOfTheStorm" ;
    lol:spellName "Eye Of The Storm" ;
    lol:spellDescription "Janna conjures a defensive gale that shields an ally champion or turret from incoming damage and increases their Attack Damage." ;
    lol:spellTooltip "Janna grants an ally champion or turret {{ totalshield }} Shield for {{ shieldduration }} seconds. While shielded, they gain {{ totalad }} Attack Damage.Janna refunds {{ ecdrefundforcc*100 }}% of the cooldown whenever she impairs an enemy champion's movement with an Ability.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/15/14/13/12" ;
    lol:costBurn "70/75/80/85/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
    lol:belongsToChampion champ:Janna .

spell:Janna_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "ReapTheWhirlwind" ;
    lol:spellName "Monsoon" ;
    lol:spellDescription "Janna surrounds herself in a magical storm, throwing enemies back. After the storm has settled, soothing winds heal nearby allies while the ability is active." ;
    lol:spellTooltip "Janna summons a magical monsoon, Knocking Back nearby enemies then healing nearby allies for {{ totalheal }} Health over {{ e3 }} seconds. Moving or using an Ability ends the monsoon early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "130/115/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "725" ;
    lol:belongsToChampion champ:Janna .

