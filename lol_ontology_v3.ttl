spell:Shen_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "ShenQ" ;
    lol:spellName "Twilight Assault" ;
    lol:spellDescription "Shen recalls his spirit blade to attack with it, dealing damage based on the target's max health. The attacks are greatly empowered if it collides with an enemy champion, and all collided enemies are slowed while running away from Shen." ;
    lol:spellTooltip "Shen recalls his Spirit Blade. Enemies hit by the pull are Slowed by {{ e4 }}% while moving away from Shen for the next {{ e5 }} seconds.Additionally, Shen's next {{ e3 }} Attacks deal an additional {{ baseflatdamage }} plus {{ basepercenthealth }} max Health magic damage. If Shen hit an enemy champion with the Spirit Blade, the damage is increased to {{ baseflatdamage }} plus {{ emppercenthealth }} max Health magic damage and he gains {{ e9 }}% Attack Speed for those Attacks.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7.25/6.5/5.75/5" ;
    lol:costBurn "140/130/120/110/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Shen .

