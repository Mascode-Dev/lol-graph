    lol:spellSlot "W" ;
    lol:spellId "ThreshW" ;
    lol:spellName "Dark Passage" ;
    lol:spellDescription "Thresh throws out a lantern that shields nearby allied Champions from damage. Allies can click the lantern to dash to Thresh." ;
    lol:spellTooltip "Thresh throws his lantern, allowing an ally to click on it to dash to Thresh.The lantern also grants {{ totalshield }} Shield for {{ shieldduration }} seconds to Thresh and the first ally champion to come in contact with it.{{ spellmodifierdescriptionappend }}" ;
