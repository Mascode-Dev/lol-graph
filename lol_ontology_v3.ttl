spell:Kha_Zix_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "KhazixQ" ;
    lol:spellName "Taste Their Fear" ;
    lol:spellDescription "Deals physical damage to the target. Damage increased on Isolated targets. If he chooses to Evolve Reaper Claws, this refunds a percent of it's cooldown against Isolated targets. Kha'Zix also gains increased range on his basic attacks and Taste Their Fear." ;
    lol:spellTooltip "Kha'Zix slashes a nearby enemy, dealing {{ spell.khazixq:basedamage }} physical damage. This deals {{ spell.khazixq:isodamage }} damage instead to enemies Isolated from their allies. {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "20" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Kha_Zix .

spell:Kha_Zix_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KhazixW" ;
    lol:spellName "Void Spike" ;
    lol:spellDescription "Kha'Zix fires exploding spikes that deal physical damage to enemies hit. Kha'Zix is healed if he is also within the explosion radius. If he chooses to Evolve Spike Racks, Void Spike now fires three spikes in a cone, slow enemies hit, and reveals enemy champions hit for 2 seconds. Isolated targets are slowed for extra." ;
    lol:spellTooltip "Kha'Zix fires a spike dealing {{ basedamage }} physical damage to the first enemy hit in a small area. If Kha'Zix is inside the area, he restores {{ healamount }} Health{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9" ;
    lol:costBurn "55/60/65/70/75" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000" ;
    lol:belongsToChampion champ:Kha_Zix .

spell:Kha_Zix_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "KhazixE" ;
    lol:spellName "Leap" ;
    lol:spellDescription "Kha'Zix leaps to an area, dealing physical damage upon landing. If he chooses to Evolve Wings, Leap's range increases by 200 and the cooldown resets on champion kill or assist." ;
    lol:spellTooltip "Kha'Zix leaps, dealing {{ totaldamage }} physical damage upon landing.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "20/18/16/14/12" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:Kha_Zix .

spell:Kha_Zix_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "KhazixR" ;
    lol:spellName "Void Assault" ;
    lol:spellDescription "Each rank allows Kha'Zix to evolve one of his abilities, giving it a unique additional effect. When activated, Kha'Zix becomes Invisible, triggering Unseen Threat and increasing Move Speed. If he chooses to Evolve Adaptive Cloaking, Void Assault gains increased Invisibility duration, and an additional use." ;
    lol:spellTooltip "Active: Kha'Zix becomes Invisible for {{ stealthduration }} seconds and gains {{ bonusmovementspeedpercent*100 }}% Move Speed. Kha'zix may Recast this Ability once within {{ recastwindow }} seconds.Passive: Leveling up this Ability allows Kha'zix to Evolve one of his Abilities, granting it additional effects.Taste Their Fear: Gain Ability range, Attack range, and lowers Cooldown by {{ spell.khazixq:effect4amount }}% against Isolated targets.Void Spike: Fires 3 spikes and Slows by {{ spell.khazixw:effect3amount }}%, increased against Isolated targets.Leap: Increased range and refreshes Cooldown on champion takedown.Void Assault: Invisibility duration lasts {{ evolvedstealthduration }} seconds and gains second Recast.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/85/70" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Kha_Zix .

spell:Kha_Zix_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Unseen Threat" ;
    lol:spellDescription "Nearby enemies that are Isolated from their allies are marked. Kha'Zix's abilities have interactions with Isolated targets.When Kha'Zix is not visible to the enemy team, he gains Unseen Threat, causing his next basic attack against an enemy champion to deal bonus magic damage and slow them for a few seconds." ;
    lol:belongsToChampion champ:Kha_Zix .

