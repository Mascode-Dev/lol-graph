spell:Swain_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "SwainW" ;
    lol:spellName "Vision of Empire" ;
    lol:spellDescription "Swain opens a demon eye that deals damage and slows enemies. Champions hit are revealed and also grant Swain a Soul Fragment." ;
    lol:spellTooltip "Swain opens a demon eye, revealing a location for 1.5 seconds, then deals {{ totaldamage }} magic damage and Slows by {{ slow*-100 }}% for {{ slowduration }} seconds.Champions hit grant Swain a Soul Fragment and are revealed for {{ revealduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/21/20/19/18" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "5500/6000/6500/7000/7500" ;
    lol:belongsToChampion champ:Swain .

spell:Swain_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "SwainE" ;
    lol:spellName "Nevermove" ;
    lol:spellDescription "Swain launches a wave of demonic power forward. It then returns to Swain and roots enemies it hits. Swain can then choose to pull all rooted champions closer. This ability has a shorter cooldown during Demonic Ascension." ;
    lol:spellTooltip "Swain launches a wave of demonic power that returns, detonating on the first enemy hit to deal {{ secondarydamage }} magic damage and Root enemies in the area for {{ rootduration }} seconds.Rooting a champion allows Swain to reactivate this ability to pull all champions Rooted by Nevermove toward him, gaining a Soul Fragment for each.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11.5/11/10.5/10" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Swain .

spell:Swain_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "SwainR" ;
    lol:spellName "Demonic Ascension" ;
    lol:spellDescription "Swain transforms into a demon and drains health from nearby enemy champions, minions, and neutral monsters. Swain can cast Demonflare to decimate and slow nearby enemies with a nova of soulfire. This form is indefinite as long as Swain drains enemy champions." ;
    lol:spellTooltip "Swain frees the demon, which deals {{ damagecalc }} magic damage and drains {{ healingcalc }} Health per second from nearby enemies. His Demonic Energy depletes over time but can be recharged indefinitely by draining enemy Champions and is fully restored on Champion takedowns.After {{ demonflarecastdelay }} seconds and every {{ demonflarecooldowntooltip }} seconds thereafter, Swain can cast Demonflare while transformed, which deals {{ demonflaredamagetotal }} magic damage and Slows enemies by {{ demonflareslowamount*100 }}%, decaying over {{ demonflareslowduration }}s.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Swain .

