    lol:spellSlot "E" ;
    lol:spellId "YoneE" ;
    lol:spellName "Soul Unbound" ;
    lol:spellDescription "Yone's spirit leaves his body behind, gaining Move Speed. When this ability ends, Yone's spirit is forced back to his body and he repeats a portion of the damage he dealt as a spirit." ;
    lol:spellTooltip "Yone enters a spirit form for {{ returntimer }} seconds, leaving his body behind for the duration and gaining {{ startingms*100 }}% to {{ movementspeed*100 }}% ramping Move Speed. When the spirit form ends, Yone snaps back to his body and repeats {{ deathmarkpercent*100 }}% of all Attack and Ability damage he dealt to champions during this time. You may Recast this ability during spirit form.Recast: End spirit form early.{{ spellmodifierdescriptionappend }}" ;
