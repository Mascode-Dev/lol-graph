champ:Wukong a lol:Champion, owl:NamedIndividual ;
    lol:championId "MonkeyKing" ;
    lol:championKey "62" ;
    lol:championName "Wukong" ;
    lol:championTitle "the Monkey King" ;
    lol:blurb "Wukong is a vastayan trickster who uses his strength, agility, and intelligence to confuse his opponents and gain the upper hand. After finding a lifelong friend in the warrior known as Master Yi, Wukong became the last student of the ancient martial..." ;
    lol:lore "Wukong is a vastayan trickster who uses his strength, agility, and intelligence to confuse his opponents and gain the upper hand. After finding a lifelong friend in the warrior known as Master Yi, Wukong became the last student of the ancient martial art known as Wuju. Armed with an enchanted staff, Wukong seeks to prevent Ionia from falling to ruin." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V25.20" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
    lol:allyTip "Decoy and Nimbus Strike work well together to quickly strike your enemy and get out before they can retaliate." ;
    lol:allyTip "Try using Decoy near brush to make an enemy overreact to your movement." ;
    lol:enemyTip "Wukong will often use Decoy after Nimbus Strike. Try delaying your abilities by a short amount of time to ensure that you're hitting the real Wukong." ;
    lol:enemyTip "Wukong becomes tougher to kill when surrounded by his enemies. Try to isolate him to gain an advantage." ;
