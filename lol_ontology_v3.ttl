champ:Corki a lol:Champion, owl:NamedIndividual ;
    lol:championId "Corki" ;
    lol:championKey "42" ;
    lol:championName "Corki" ;
    lol:championTitle "the Daring Bombardier" ;
    lol:blurb "The yordle pilot Corki loves two things above all others: flying, and his glamorous mustache... though not necessarily in that order. After leaving Bandle City, he settled in Piltover and fell in love with the wondrous machines he found there. He..." ;
    lol:lore "The yordle pilot Corki loves two things above all others: flying, and his glamorous mustache... though not necessarily in that order. After leaving Bandle City, he settled in Piltover and fell in love with the wondrous machines he found there. He dedicated himself to the development of flying contraptions, leading an aerial defense force of seasoned veterans known as the Screaming Yipsnakes. Calm under fire, Corki patrols the skies around his adopted home, and has never encountered a problem that a good missile barrage couldn't solve." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.01" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
    lol:allyTip "Phosphorus Bomb can be used to reveal enemy units that might be hiding in a nearby patch of brush." ;
    lol:allyTip "Valkyrie can be used defensively as well, so try using it for a quick escape." ;
    lol:allyTip "Corki can continue to attack while using Gatling Gun. Maximizing Gatling Gun is key to mastering Corki." ;
    lol:enemyTip "Watch out for Corki's Missile Barrage. They deal splash damage, so you can get hit even when hiding behind minions." ;
    lol:enemyTip "Corki is vulnerable after he uses his Valkyrie or Special Delivery, so try switching focus to him if he uses them to enter a fight." ;
    lol:hasRole role:Marksman ;
    lol:hasRole role:Mage ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Bandle_City ;
    lol:playsPosition pos:Bot_ADC ;
    lol:playsPosition pos:Middle ;
