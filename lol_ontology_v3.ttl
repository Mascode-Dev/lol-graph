    lol:spellSlot "W" ;
    lol:spellId "FiddleSticksW" ;
    lol:spellName "Bountiful Harvest" ;
    lol:spellDescription "Fiddlesticks drains health from nearby enemies, dealing bonus execute damage at the end of the duration." ;
    lol:spellTooltip "Fiddlesticks channels and drains the souls of nearby enemies, dealing {{ draindamagecalc }} magic damage per second for 2 seconds, plus {{ percentfortooltip }}% missing Health magic damage at the end. Fiddlesticks restores {{ vamppercentage }}% of damage as Health.If Fiddlesticks ends the channel without interruption, the remaining Cooldown is reduced by 60%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9.5/9/8.5/8" ;
    lol:costBurn "60/65/70/75/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Fiddlesticks .

