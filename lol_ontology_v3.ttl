    lol:spellDescription "Taliyah causes an area of ground to erupt and throws enemies within it in a direction of her choosing." ;
    lol:spellTooltip "Taliyah quakes the earth, Knocking enemies in an area in the chosen direction.{{ spellmodifierdescriptionappend }}" ;
