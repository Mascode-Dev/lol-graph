champ:Orianna a lol:Champion, owl:NamedIndividual ;
    lol:championId "Orianna" ;
    lol:championKey "61" ;
    lol:championName "Orianna" ;
    lol:championTitle "the Lady of Clockwork" ;
    lol:blurb "Once a curious girl of flesh and blood, Orianna is now a technological marvel comprised entirely of clockwork. She became gravely ill after an accident in the lower districts of Zaun, and her failing body had to be replaced with exquisite artifice..." ;
    lol:lore "Once a curious girl of flesh and blood, Orianna is now a technological marvel comprised entirely of clockwork. She became gravely ill after an accident in the lower districts of Zaun, and her failing body had to be replaced with exquisite artifice, piece by piece. Accompanied by an extraordinary brass sphere she built for companionship and protection, Orianna is now free to explore the wonders of Piltover, and beyond." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.05" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Command: Protect can be used on yourself to return the Ball back to you quickly. Combine this with Command: Attack for a quick harassment." ;
    lol:allyTip "Command: Dissonance is a very powerful escape tool if Orianna has the Ball. The combination of speed and leaving a slowing obstacle can be quite powerful." ;
    lol:allyTip "Command: Shockwave can be used to drag enemies towards you or away from you if you position the Ball properly." ;
    lol:enemyTip "Orianna can only affect the area the Ball is around. Use this to your advantage." ;
    lol:enemyTip "Watch out for Orianna's Ball returning to her due to leashing. This may cause some unexpected situations." ;
    lol:hasRole role:Mage ;
    lol:hasRole role:Support ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Piltover ;
    lol:playsPosition pos:Middle ;
