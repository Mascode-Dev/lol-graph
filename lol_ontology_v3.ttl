    lol:spellId "DefensiveBallCurl" ;
    lol:spellName "Defensive Ball Curl" ;
    lol:spellDescription "Rammus goes into a defensive formation, vastly increasing his Armor and Magic Resistance, and returning damage to enemies that attack him." ;
    lol:spellTooltip "Rammus enters a defensive formation for {{ buffduration }} seconds, gaining {{ bonusarmortooltip }} Armor and {{ bonusmrtooltip }} Magic Resist and dealing {{ returndamagecalc }} magic damage to enemies that Attack him.Recast: Rammus ends this Ability early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
