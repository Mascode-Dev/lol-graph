    lol:spellName "Adaptive Defenses" ;
    lol:spellDescription "Basic attacks on champions grant a shield equal to a percentage of Camille's maximum health against their damage type (Physical or Magic) for a brief duration." ;
    lol:belongsToChampion champ:Camille .

