spell:Tryndamere_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "TryndamereQ" ;
    lol:spellName "Bloodlust" ;
    lol:spellDescription "Tryndamere thrives on the thrills of combat, increasing his Attack Damage as he is more and more wounded. He can cast Bloodlust to consume his Fury and heal himself." ;
    lol:spellTooltip "Passive: Tryndamere thirsts for blood, gaining up to {{ maximumbonusad }} Attack Damage based on his missing Health.Active: Tryndamere consumes his Fury, restoring {{ baseheal }} plus {{ healperfury }} Health per Fury (max: {{ maximumheal }}). {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Tryndamere .

spell:Tryndamere_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "TryndamereW" ;
    lol:spellName "Mocking Shout" ;
    lol:spellDescription "Tryndamere lets out an insulting cry, decreasing surrounding champions' Attack Damage. Enemies with their backs turned to Tryndamere also have their Move Speed reduced." ;
    lol:spellTooltip "Tryndamere hurls insults, reducing champions' Attack Damage by {{ adreduction*-1 }} for {{ reductionduration }} seconds and Slowing by {{ slowpotency*-100 }}% while cowering from him for {{ slowduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Tryndamere .

