    lol:spellId "TristanaR" ;
    lol:spellName "Buster Shot" ;
    lol:spellDescription "Tristana loads a massive cannonball into her weapon and fires it at an enemy unit. This deals Magic Damage and knocks the target back. If the target is carrying the Explosive Charge bomb, the bomb detonation radius is doubled." ;
    lol:spellTooltip "Tristana fires a massive cannonball, dealing {{ damagecalc }} magic damage to the target, Knocking Back and Stunning them and surrounding enemies for {{ stunduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
