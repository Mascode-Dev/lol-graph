    lol:spellSlot "W" ;
    lol:spellId "ZacW" ;
    lol:spellName "Unstable Matter" ;
    lol:spellDescription "Zac explodes outward towards nearby enemies, dealing a percentage of their maximum health as magic damage." ;
    lol:spellTooltip "Zac's body erupts, dealing {{ basedamage }} + {{ displaypercentdamage }} max Health magic damage to nearby enemies.Absorbing Goo reduces this Ability's Cooldown by 1 second.{{ spellmodifierdescriptionappend }}" ;
