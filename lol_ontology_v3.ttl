    lol:spellDescription "Malzahar summons Voidlings to attack nearby enemies." ;
    lol:spellTooltip "Passive: Malzahar's other Abilities give him a stack when cast (max {{ stackcap }}).Active: Malzahar summons a Voidling plus an additional Voidling per stack. Voidlings last {{ voidlingduration }} seconds and deal {{ voidlingbonusdamagetooltip }} magic damage each hit.{{ spellmodifierdescriptionappend }}" ;
