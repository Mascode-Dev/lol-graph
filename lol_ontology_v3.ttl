    lol:spellTooltip "Passive: Kog'Maw gains {{ attackspeed*100 }}% Attack Speed.Active: Kog'Maw vomits a corrosive projectile that deals {{ totaldamage }} magic damage to the first enemy hit and shreds {{ shredamount }}% Armor and Magic Resist for {{ shredduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
