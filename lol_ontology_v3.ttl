champ:Lillia a lol:Champion, owl:NamedIndividual ;
    lol:championId "Lillia" ;
    lol:championKey "876" ;
    lol:championName "Lillia" ;
    lol:championTitle "the Bashful Bloom" ;
    lol:blurb "Intensely shy, the fae fawn Lillia skittishly wanders Ionia's forests. Hiding just out of sight of mortals—whose mysterious natures have long captivated, but intimidated, her—Lillia hopes to discover why their dreams no longer reach the ancient Dreaming..." ;
    lol:lore "Intensely shy, the fae fawn Lillia skittishly wanders Ionia's forests. Hiding just out of sight of mortals—whose mysterious natures have long captivated, but intimidated, her—Lillia hopes to discover why their dreams no longer reach the ancient Dreaming Tree. She now travels Ionia with a magical branch in hand, in an effort to find people's unrealized dreams. Only then can Lillia herself bloom and help others untangle their fears to find the sparkle within. Eep!" ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.05" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
