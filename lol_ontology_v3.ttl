spell:Kayle_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "KayleQ" ;
    lol:spellName "Radiant Blast" ;
    lol:spellDescription "Kayle conjures a portal, summoning a celestial sword that pierces through enemies, slowing, damaging, and reducing the resistances of all hit." ;
    lol:spellTooltip "Kayle fires a celestial sword that stops on the first enemy hit, dealing {{ totaldamage }} magic damage, Slowing by {{ slowpercent }}% for {{ slowduration }} seconds, and removing {{ shredpercent }}% Armor and Magic Resist for {{ shredduration }} seconds from the target and enemies behind them.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "60/70/80/90/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Kayle .

spell:Kayle_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KayleW" ;
    lol:spellName "Celestial Blessing" ;
    lol:spellDescription "Blessed by the divine, Kayle heals and grants Move Speed to herself and the nearest ally." ;
    lol:spellTooltip "Kayle infuses herself and an allied champion with light, restoring {{ totalheal }} Health and granting {{ totalhaste }} Move Speed for {{ hasteduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "15" ;
    lol:costBurn "70/75/80/85/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Kayle .

spell:Kayle_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "KayleE" ;
    lol:spellName "Starfire Spellblade" ;
    lol:spellDescription "Passive: Kayle's celestial sword, Virtue, deals bonus magic damage to enemies she attacks.Active: Kayle's next attack smites her target with celestial fire, dealing bonus damage proportionate to their missing health." ;
    lol:spellTooltip "Passive: Attacks deal an additional {{ epassivetotaldamage }} magic damage.Active: Kayle's next attack becomes ranged and deals an additional {{ activetotalexecutedamage }} missing Health magic damage. This attack upgrades when Kayle reaches Level {{ spell.kaylepassive:levelforpassiverank2 }}, causing it to explode when it hits the target, dealing damage to nearby enemies.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7.5/7/6.5/6" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "550" ;
    lol:belongsToChampion champ:Kayle .

spell:Kayle_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "KayleR" ;
    lol:spellName "Divine Judgment" ;
    lol:spellDescription "Kayle makes an ally invulnerable and calls upon former Aspects of Justice to purify the area around her target with a holy rain of swords." ;
    lol:spellTooltip "Kayle makes an allied champion Invulnerable for {{ invulnduration }} seconds and then purifies the area around them, dealing {{ totaldamage }} magic damage to nearby enemies.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "160/120/80" ;
    lol:costBurn "100/50/0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Kayle .

spell:Kayle_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Divine Ascent" ;
    lol:spellDescription "Kayle's attacks are empowered by the heavens as she levels up and spends skill points. Her wings are lit aflame as she progressively gains Attack Speed, Move Speed, Attack Range, and waves of fire on her attacks." ;
    lol:belongsToChampion champ:Kayle .

