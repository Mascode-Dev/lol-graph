    lol:spellTooltip "Smolder lets out an adorable flaming sneeze, dealing {{ initialdamage }} physical damage and Slowing by {{ slowamount*100 }}% for {{ slowduration }} seconds.Hitting champions causes an explosion, dealing {{ explosiondamage }} physical + {{ spell.smolderp:passive_wdamageincrease }} magic damage.{{ spellmodifierdescriptionappend }}" ;
