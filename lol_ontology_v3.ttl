champ:Nautilus a lol:Champion, owl:NamedIndividual ;
    lol:championId "Nautilus" ;
    lol:championKey "111" ;
    lol:championName "Nautilus" ;
    lol:championTitle "the Titan of the Depths" ;
    lol:blurb "A lonely legend as old as the first piers sunk in Bilgewater, the armored goliath known as Nautilus roams the dark waters off the coast of the Blue Flame Isles. Driven by a forgotten betrayal, he strikes without warning, swinging his enormous anchor to..." ;
    lol:lore "A lonely legend as old as the first piers sunk in Bilgewater, the armored goliath known as Nautilus roams the dark waters off the coast of the Blue Flame Isles. Driven by a forgotten betrayal, he strikes without warning, swinging his enormous anchor to save the wretched, and drag the greedy to their doom. It is said he comes for those who forget to pay the “Bilgewater tithe”, pulling them down beneath the waves with him—an iron-clad reminder that none can escape the depths." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V25.16" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "While ganking, consider aiming Dredge Line at nearby terrain and following it up with Riptide for a higher hit rate." ;
    lol:allyTip "Riptide has a delayed blast timing on activation - you can use this while running away or when enemies are incoming to serve as a deterrent." ;
    lol:enemyTip "If Nautilus uses Riptide right next to you, hold in place until the ripple effect finishes before running. Running early will run straight into the secondary explosions, causing you to take additional damage and slow." ;
    lol:enemyTip "While Nautilus is shielded, he is capable of dealing large amounts of area of effect damage with his basic attacks - consider taking down the shield if you have time." ;
    lol:hasRole role:Tank ;
    lol:hasRole role:Support ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Bilgewater ;
    lol:playsPosition pos:Support ;
