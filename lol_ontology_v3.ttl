champ:Hwei a lol:Champion, owl:NamedIndividual ;
    lol:championId "Hwei" ;
    lol:championKey "910" ;
    lol:championName "Hwei" ;
    lol:championTitle "the Visionary" ;
    lol:blurb "Hwei is a brooding painter who creates brilliant art in order to confront Ionia's criminals and comfort their victims. Beneath his melancholy roils a torn, emotional mind—haunted by both the vibrant visions of his imagination and the gruesome memories..." ;
    lol:lore "Hwei is a brooding painter who creates brilliant art in order to confront Ionia's criminals and comfort their victims. Beneath his melancholy roils a torn, emotional mind—haunted by both the vibrant visions of his imagination and the gruesome memories of his temple's massacre. Hwei seeks to understand this light and dark, which drives him inevitably toward the artist who unraveled him. With paintbrush and palette, Hwei shapes endless possibilities as he draws ever closer to earning closure or embracing despair." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.04" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Calm down, breathe, and focus." ;
    lol:allyTip "Each stroke requires precision and intention." ;
    lol:enemyTip "Hwei needs to predict your positioning and take time to cast, catch him by surprise." ;
    lol:enemyTip "Hwei's lightning is deadly but slow; it deals more damage when you are alone or unable to move." ;
    lol:enemyTip "After Hwei paints a Torment spell he is vulnerable to being rushed down." ;
    lol:hasRole role:Mage ;
    lol:hasRole role:Support ;
    lol:hasResourceType res:Mana ;
