champ:Kennen a lol:Champion, owl:NamedIndividual ;
    lol:championId "Kennen" ;
    lol:championKey "85" ;
    lol:championName "Kennen" ;
    lol:championTitle "the Heart of the Tempest" ;
    lol:blurb "More than just the lightning-quick enforcer of Ionian balance, Kennen is the only yordle member of the Kinkou. Despite his small, furry stature, he is eager to take on any threat with a whirling storm of shuriken and boundless enthusiasm. Alongside his..." ;
    lol:lore "More than just the lightning-quick enforcer of Ionian balance, Kennen is the only yordle member of the Kinkou. Despite his small, furry stature, he is eager to take on any threat with a whirling storm of shuriken and boundless enthusiasm. Alongside his master Shen, Kennen patrols the spirit realm, employing devastating electrical energy to strike down his enemies." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V26.04" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "You can stun your opponents by inflicting 3 Marks of the Storm upon them." ;
    lol:allyTip "Lightning Rush can be used to initiate fights with its Energy return component, allowing him to use other abilities afterward." ;
    lol:allyTip "You can land an initial Mark of the Storm debuff on an opponent with Thundering Shuriken, and then add to it with Electrical Surge." ;
    lol:enemyTip "Consider playing a bit more cautiously around Kennen when you have a Mark of the Storm debuff. If he hits you with 3 Marks of the Storm, you will get stunned." ;
    lol:enemyTip "Kennen is flimsy by nature - turn and attack him if he gets careless with Lightning Rush." ;
    lol:hasRole role:Mage ;
    lol:hasResourceType res:Energy ;
    lol:isFromRegion region:Bandle_City ;
    lol:playsPosition pos:Top ;
    lol:hasSpell spell:Kennen_Q ;
