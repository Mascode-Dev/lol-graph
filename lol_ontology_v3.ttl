spell:Master_Yi_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "AlphaStrike" ;
    lol:spellName "Alpha Strike" ;
    lol:spellDescription "Master Yi teleports across the battlefield with blinding speed, dealing physical damage to multiple units in his path, while simultaneously becoming untargetable. Alpha Strike can critically strike and deals bonus physical damage to monsters. Basic attacks reduce Alpha Strike's cooldown." ;
    lol:spellTooltip "Master Yi becomes Untargetable and teleports to rapidly strike enemies near his target, dealing {{ totaldamage }} physical damage to all enemies hit after {{ alphastrikebounces }} hits. This Ability can strike the same enemy repeatedly if there are no other targets, dealing {{ subsequenthitmultiplier*100 }}% damage for subsequent hits ({{ subesquentdamage }}), for a maximum single target total of {{ singletotaldamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "20/19.5/19/18.5/18" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Master_Yi .

spell:Master_Yi_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "Meditate" ;
    lol:spellName "Meditate" ;
    lol:spellDescription "Master Yi rejuvenates his body by focus of mind, restoring Health and taking reduced damage for a short time. In addition, Master Yi will gain stacks of Double Strike and pause the remaining duration on Wuju Style and Highlander for each second he channels." ;
    lol:spellTooltip "Master Yi channels, restoring {{ totalheal }} Health over {{ healduration }} seconds. This healing is increased by up to {{ maxmissinghealthpercent*100 }}% based on Master Yi's missing Health.While channeling and for {{ drlinger }} seconds afterwards, he takes {{ initialdr }} reduced damage, decreased to {{ damagereduction*100 }}% after the first {{ initialextradrduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10" ;
    lol:costBurn "40" ;
    lol:costType " Mana (+{{ percentmanacostpersecond*100 }}% Max Mana per second)" ;
    lol:rangeBurn "20" ;
    lol:belongsToChampion champ:Master_Yi .

spell:Master_Yi_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "WujuStyle" ;
    lol:spellName "Wuju Style" ;
    lol:spellDescription "Grants bonus true damage on basic attacks." ;
    lol:spellTooltip "Master Yi's Attacks deal an additional {{ totaldamage }} true damage for {{ duration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "20" ;
    lol:belongsToChampion champ:Master_Yi .

spell:Master_Yi_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "Highlander" ;
    lol:spellName "Highlander" ;
    lol:spellDescription "Master Yi moves with unparalleled agility, temporarily increasing his Move Speed and Attack Speed as well as making him immune to all slowing effects. While active, Champion kills or assists extend Highlander's duration. Passively reduces cooldown for his other abilities on a kill or assist." ;
    lol:spellTooltip "Passive: Champion takedowns reduce the remaining Cooldown of Master Yi's basic Abilities by {{ rcooldownrefund*100 }}%.Active: Master Yi enters a trance, gaining {{ rmsbonus }}% Move Speed, {{ rasbonus }}% Attack Speed, and immunity to Slows for {{ rduration }} seconds. Champion takedowns extend the duration of this Ability by {{ rkillassistextension }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "85" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1" ;
    lol:belongsToChampion champ:Master_Yi .

