    lol:spellSlot "W" ;
    lol:spellId "PykeW" ;
    lol:spellName "Ghostwater Dive" ;
    lol:spellDescription "Pyke enters Camouflage and gains significant Move Speed that decays over time." ;
    lol:spellTooltip "Pyke gains Camouflage and {{ movespeed }}% Move Speed decaying over {{ e0 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
