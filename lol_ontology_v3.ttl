spell:Talon_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "TalonQ" ;
    lol:spellName "Noxian Diplomacy" ;
    lol:spellDescription "Talon stabs the target unit. If they are within melee range, this attack deals critical damage. If they are outside melee range, Talon will leap at his target before stabbing them. Talon refunds some health and cooldown if this ability kills the target." ;
    lol:spellTooltip "Talon leaps to a target and deals {{ leapdamage }} physical damage. If used in melee range, this Ability instead critically strikes for {{ criticaldamage }} physical damage.If this Ability kills the target, Talon restores {{ totalhealing }} Health and refunds {{ cooldownrefund*100 }}% of its Cooldown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7.5/7/6.5/6" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "575" ;
    lol:belongsToChampion champ:Talon .

