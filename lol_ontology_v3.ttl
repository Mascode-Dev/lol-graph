spell:Jax_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "JaxE" ;
    lol:spellName "Counter Strike" ;
    lol:spellDescription "Jax's combat prowess allows him to dodge all incoming attacks for a short duration and then quickly counterattack, stunning all surrounding enemies." ;
    lol:spellTooltip "Jax enters a defensive stance for up to {{ dodgeduration }} seconds, dodging incoming Attacks and taking {{ aoedamagereduction }}% less damage from area of effect Abilities. After {{ dodgeduration }} seconds or Recasting, Jax deals {{ totaldamage }} + {{ percenthealthdamage }}% max Health magic damage and Stuns nearby enemies for {{ stunduration }} second. The damage is increased by {{ percentincreasedperdodge*100 }}% per Attack dodged, up to a maximum of {{ maxdamage }} + {{ maxpercenthealthdamage }}% max Health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "17/15/13/11/9" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Jax .

spell:Jax_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "JaxR" ;
    lol:spellName "Grandmaster-at-Arms" ;
    lol:spellDescription "Every third consecutive attack deals additional Magic Damage. Additionally, Jax can activate this ability to deal damage around himself and strengthen his resolve, increasing his Armor and Magic Resist for a short duration." ;
    lol:spellTooltip "Passive: Every third Attack within {{ passivefallofftime }} seconds deals an additional {{ onhitdamage }} magic damage.Active: Jax slams his lantern down, dealing {{ swingdamagetotal }} magic damage to nearby enemies. If he hits a champion he gains {{ basearmor }} Armor and {{ basemr }} Magic Resist plus {{ bonusarmor }} Armor and {{ bonusmr }} Magic Resist per additional champion hit for {{ duration }} seconds. During this time every second Attack deals additional magic damage instead of every third.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "110/100/90" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "260" ;
    lol:belongsToChampion champ:Jax .

