spell:Sion_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "SionQ" ;
    lol:spellName "Decimating Smash" ;
    lol:spellDescription "Sion charges a powerful swing in an area in front of himself that will deal damage to enemies when released. If he charges for enough time, enemies hit by the swing will also be knocked up and stunned." ;
    lol:spellTooltip "Begin Charging: Sion charges a heavy blow for up to 2 seconds.Release: Sion slams his axe down, briefly Slowing and dealing between {{ mindamagetotal }} and {{ maxdamagetotal }} physical damage based on charge time. If Sion charged for at least 1 second, enemies are Knocked Up and Stunned for between {{ basestuntime }} and 2.25 seconds based on charge time.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9/8/7/6" ;
    lol:costBurn "45" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "10000" ;
    lol:belongsToChampion champ:Sion .

spell:Sion_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "SionW" ;
    lol:spellName "Soul Furnace" ;
    lol:spellDescription "Sion shields himself and can reactivate after 3 seconds to deal Magic Damage to enemies nearby. When Sion kills enemies, he passively gains maximum Health." ;
    lol:spellTooltip "Passive: Sion gains {{ hpperkill }} max Health when he kills a unit, or {{ hpperchampkill }} for champion takedowns, large minions and large monsters.Active: Sion gains {{ totalshield }} Shield for 6 seconds. After {{ e7 }} seconds if the shield still holds, Sion can Recast to detonate the shield to deal {{ totaldamage }} plus {{ e4 }}% max Health magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "15/14/13/12/11" ;
    lol:costBurn "65/70/75/80/85" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Sion .

spell:Sion_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "SionE" ;
    lol:spellName "Roar of the Slayer" ;
    lol:spellDescription "Sion fires a short range shockwave that damages and slows and reduces the Armor of the first enemy hit. If the shockwave hits a minion or monster, it will be knocked back, damaging, slowing, and reducing the Armor of all enemies that it passes through." ;
    lol:spellTooltip "Sion fires a shockwave, dealing {{ totaldamage }} magic damage, Slowing them by {{ slowamount }}% for {{ slowduration }} seconds and removing {{ armorshred }}% Armor for {{ armorshredduration }} seconds. Non-champions hit are Knocked Back. Enemies hit by a Knocked Back unit take the same damage and effects.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/11/10/9/8" ;
    lol:costBurn "35/40/45/50/55" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
    lol:belongsToChampion champ:Sion .

spell:Sion_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "SionR" ;
    lol:spellName "Unstoppable Onslaught" ;
    lol:spellDescription "Sion charges in a direction, ramping up speed over time. He can steer his charge slightly with the mouse cursor location. When he collides with an enemy he deals damage and knocks them up based on the distance he has charged." ;
    lol:spellTooltip "Sion charges Unstoppably in a direction for 8 seconds, turning towards the mouse cursor. Sion stops on colliding with an enemy champion or wall or on Recasting this Ability.  At the end of the charge, Sion deals between {{ mindamagetotal }} and {{ maxdamagetotal }} physical damage based on distance travelled. Enemies close to Sion are Stunned for between {{ minstunduration }} and {{ maxstunduration }} seconds based on distance travelled. Enemies in a larger area are Slowed by {{ slowamount }}% for 3 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/100/60" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "7500" ;
    lol:belongsToChampion champ:Sion .

spell:Sion_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Glory in Death" ;
    lol:spellDescription "After being killed, Sion will temporarily reanimate with rapidly decaying Health. His attacks become very rapid, heal him, and deal bonus damage based on his target's maximum Health." ;
    lol:belongsToChampion champ:Sion .

