    lol:spellDescription "Garen calls upon the might of Demacia to attempt to execute an enemy champion." ;
    lol:spellTooltip "Garen calls upon the might of Demacia to slay his enemy, dealing {{ basedamage }} plus {{ executedamage*100 }}% missing Health true damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
