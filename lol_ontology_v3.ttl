spell:Sett_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "SettW" ;
    lol:spellName "Haymaker" ;
    lol:spellDescription "Sett passively stores damage he takes as Grit. On cast, Sett expends all stored Grit to gain a shield and punch an area, dealing true damage in the center and physical damage on the sides." ;
    lol:spellTooltip "Passive: Sett stores {{ damagestored*100 }}% of damage taken as Grit, up to {{ maxgrit }}. Grit decays quickly {{ adrenalinestoragewindow }} seconds after the damage was taken.Active: Sett consumes all Grit, gaining a {{ shieldconversion*100 }}% Grit consumed Shield decaying over {{ shieldmaxduration }} seconds. Sett then delivers a massive punch, dealing {{ damagecalc }} plus {{ damageconversion }} Grit consumed true damage to enemies in the center (max {{ f1 }} damage). Enemies not in the center instead take physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/16.5/15/13.5/12" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Sett .

spell:Sett_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "SettE" ;
    lol:spellName "Facebreaker" ;
    lol:spellDescription "Sett pulls in all enemies on opposite sides of him, dealing damage and stunning them. If enemies were only on one side, they are slowed instead of stunned." ;
    lol:spellTooltip "Sett smashes enemies on either side of him into each other, dealing {{ damagecalc }} physical damage and Slowing them by {{ slowamount*100 }}% for {{ slowduration }} seconds. If Sett grabbed at least one enemy on each side, all enemies are Stunned for {{ stunduration }} second.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/14.5/13/11.5/10" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "490" ;
    lol:belongsToChampion champ:Sett .

spell:Sett_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "SettR" ;
    lol:spellName "The Show Stopper" ;
    lol:spellDescription "Sett carries an enemy champion through the air and slams them into the ground, dealing damage and slowing all enemies near where they land." ;
    lol:spellTooltip "Sett grabs an enemy champion and Suppresses them as he carries them forward, then slams them into the ground, dealing {{ damagecalc }} plus {{ maxhealthdamage*100 }}% of the grabbed enemy's bonus Health physical damage to surrounding enemies and Slowing them by {{ slowamount*100 }}% for {{ slowduration }} second. Enemies take less damage the further they are from where Sett lands.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
