    lol:spellSlot "Q" ;
    lol:spellId "SettQ" ;
    lol:spellName "Knuckle Down" ;
    lol:spellDescription "Sett's next two attacks deal additional damage based off of the target's max health. Sett also gains Move Speed while moving towards enemy champions." ;
    lol:spellTooltip "Sett itches for a fight, gaining {{ msamount*100 }}% Move Speed towards enemy champions for {{ msduration }} seconds.Additionally Sett's next two Attacks deal an additional {{ basedamage }} plus {{ maxhealthdamagecalc }} max Health physical damage.{{ spellmodifierdescriptionappend }}" ;
