    lol:spellSlot "E" ;
    lol:spellId "IreliaE" ;
    lol:spellName "Flawless Duet" ;
    lol:spellDescription "Irelia sends out two blades which converge on each other. Enemies caught in between are damaged, stunned and Marked." ;
    lol:spellTooltip "Irelia throws a blade into the ground and can Recast for up to {{ buffduration }} seconds. Recast: Irelia throws a second blade, then they fly towards each other Stunning for {{ stunduration }} seconds and dealing {{ totaldamage }} magic damage. Champions and large jungle monsters become Unsteady for {{ markduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/14.5/13/11.5/10" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Irelia .

