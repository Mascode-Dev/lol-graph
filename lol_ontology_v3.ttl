    lol:spellId "LeonaSolarFlare" ;
    lol:spellName "Solar Flare" ;
    lol:spellDescription "Leona calls down a beam of solar energy, dealing damage to enemies in an area. Enemies in the center of the area are stunned, while enemies on the outside are slowed." ;
    lol:spellTooltip "Leona calls down a radiant beam of solar energy dealing {{ explosioncalculateddamage }} magic damage and Slowing by {{ slowpercent }}% for {{ ccduration }} seconds. Enemies in the center of the flare are Stunned instead of Slowed.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
