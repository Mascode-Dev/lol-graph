spell:Udyr_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "UdyrQ" ;
    lol:spellName "Wilding Claw" ;
    lol:spellDescription "Udyr gains attack speed and his next two attacks deal bonus physical damage. Recast: Gain even more attack speed, and the next two attacks call lightning to strike the target." ;
    lol:spellTooltip "Claw Stance: Udyr gains {{ attackspeedbase*100 }}% Attack Speed and his Attacks deal {{ onhitdamage }} physical damage %i:OnHit% On-Hit for {{ attackspeeddurationbase }} seconds. Additionally, Udyr's next two Attacks in this stance deal a bonus {{ maxhponhit1 }} max Health physical damage and gain {{ attackrange }} range.Awaken: Increase bonus Attack Speed to {{ empoweredtotalas }} and max Health damage to {{ q2totalonhithpdamage }}. Additionally, Udyr's next two Attacks call lightning six times, dealing a total of {{ empoweredlightningbonusmax }} max Health magic damage to isolated targets (strikes bounce to other nearby targets when possible).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "6"^^xsd:integer ;
    lol:cooldownBurn "6" ;
    lol:costBurn "20" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Udyr .

