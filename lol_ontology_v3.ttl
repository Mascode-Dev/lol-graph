    lol:spellSlot "Q" ;
    lol:spellId "NasusQ" ;
    lol:spellName "Siphoning Strike" ;
    lol:spellDescription "Nasus strikes his foe, dealing damage and increasing the power of his future Siphoning Strikes if he slays his target." ;
    lol:spellTooltip "Nasus' next Attack deals {{ totaldamage }} physical damage. Killing an enemy with this Attack permanently increases its damage by {{ basicstacks }}, increased to {{ bigstacks }} against champions, large minions and large jungle monsters.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
