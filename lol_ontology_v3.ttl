spell:Poppy_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "PoppyQ" ;
    lol:spellName "Hammer Shock" ;
    lol:spellDescription "Poppy swings her hammer, dealing damage and creating a zone that will slow enemies and explode after a delay." ;
    lol:spellTooltip "Poppy smashes the ground, dealing {{ basedamage }} plus {{ healthdamagepercent }}% max Health physical damage and making the ground unstable. The unstable area Slows enemies by {{ e3 }}% and erupts after {{ e4 }} second, dealing {{ basedamage }} plus {{ healthdamagepercent }}% max Health physical damage again.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "8/7/6/5/4" ;
    lol:costBurn "35/40/45/50/55" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "430" ;
    lol:belongsToChampion champ:Poppy .

spell:Poppy_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "PoppyW" ;
    lol:spellName "Steadfast Presence" ;
    lol:spellDescription "Poppy passively gains Armor and Magic Resist. This bonus increases when she is low on Health. Poppy can activate Steadfast Presence to gain Move Speed and stop enemy dashes around her. If a dash is stopped, the enemy is slowed and grounded." ;
    lol:spellTooltip "Passive: Poppy gains {{ bonusarmor }} Armor and {{ bonusmr }} Magic Resist. This bonus is doubled if Poppy is below {{ passiveempoweredhealthpercent*100 }}% Health.Active: Poppy gains {{ e2 }}% Move Speed and projects a field around her for {{ e1 }} seconds that stops enemy dashes. Enemies who are stopped by the field are Grounded and Slowed by {{ slowamount*-100 }}% for {{ groundingduration }} seconds and take {{ interruptdamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "20/18/16/14/12" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Poppy .

spell:Poppy_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "PoppyE" ;
    lol:spellName "Heroic Charge" ;
    lol:spellDescription "Poppy dashes to the target and pushes it back. If the target is pushed into a wall, it is stunned." ;
    lol:spellTooltip "Poppy tackles an enemy, dealing {{ tackledamage }} physical damage and carrying them forward. If Poppy tackles them into terrain, the enemy is Stunned for {{ e3 }} seconds and take an additional {{ tackledamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13/12/11/10" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "475" ;
    lol:belongsToChampion champ:Poppy .

spell:Poppy_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "PoppyR" ;
    lol:spellName "Keeper's Verdict" ;
    lol:spellDescription "Poppy channels a hammer strike that knocks enemies very far away." ;
    lol:spellTooltip "Begin Casting: Poppy begins charging her hammer for up to {{ channelmaxduration }} seconds, Slowing herself by {{ selfslow }}%.Release: Poppy smashes the ground, creating a shockwave that deals {{ damage }} physical damage to the first champion hit and surrounding enemies, Knocks them Back towards their Nexus, and makes them Untargetable while they fly. The range and Knock Back distance increase with charge duration.An uncharged swing deals {{ halfdamage }} physical damage and Knocks Up for {{ knockupdurationsnap }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/120/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Poppy .

