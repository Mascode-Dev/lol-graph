spell:Swain_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "SwainQ" ;
    lol:spellName "Death's Hand" ;
    lol:spellDescription "Swain unleashes several bolts of eldritch power that pierce through enemies. Enemies hit take more damage for each bolt they are struck by." ;
    lol:spellTooltip "Swain unleashes 5 eldritch bolts, dealing {{ initialdamage }} magic damage plus {{ extraboltdamage }} magic damage per bolt past the first (max {{ maxdamage }} magic damage).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "7/6/5/4/3" ;
