    lol:spellName "Tempered Fate" ;
    lol:spellDescription "Bard sends spirit energy arcing to a location, putting all champions, minions, monsters, and turrets hit into stasis for a brief time." ;
    lol:spellTooltip "Bard hurls magical protective energy to an area, placing all units and structures hit into Stasis for {{ rstasisduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
