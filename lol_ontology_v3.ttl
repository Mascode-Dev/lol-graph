spell:Rengar_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "RengarR" ;
    lol:spellName "Thrill of the Hunt" ;
    lol:spellDescription "Rengar's predatory instincts take over, Camouflaging him and revealing the nearest enemy champion in a large radius around him. During Thrill of the Hunt, Rengar gains Move Speed and he can leap to the tracked enemy without being in brush, reducing their armor." ;
    lol:spellTooltip "Passive: Rengar will also leap Attack when Camouflaged.Active: Rengar gains {{ stealthms }}% Move Speed and True Sight in a small area around the nearest enemy champion for {{ stealthduration }} seconds.After {{ fadetime }} seconds, Rengar becomes Camouflaged and can leap without being in Brush. Leaping to the nearest champion deals an additional {{ bonusdamage }} physical damage, shreds {{ armorshred }} Armor for {{ armorshredduration }} seconds, and ends this Ability.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/90/80" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "2500/3000/3500" ;
    lol:belongsToChampion champ:Rengar .

