    lol:spellSlot "E" ;
    lol:spellId "FioraE" ;
    lol:spellName "Bladework" ;
    lol:spellDescription "Fiora has increased attack speed for the next two attacks. The first attack slows the target, and the second attack will critically strike." ;
    lol:spellTooltip "Fiora gains {{ aspercent*100 }}% Attack Speed for her next two Attacks. The first Attack Slows by {{ slowpercent*-100 }}% for {{ slowduration }} second. The second Attack always critically strikes for {{ attacktwopercenttad*100 }}% damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "425" ;
    lol:belongsToChampion champ:Fiora .

spell:Fiora_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "FioraR" ;
    lol:spellName "Grand Challenge" ;
    lol:spellDescription "Fiora reveals all four Vitals on an enemy champion and gains Move Speed while near them. If Fiora hits all four Vitals or if the target dies after she has hit at least one, Fiora and her allies in the area are healed over the next few seconds." ;
    lol:spellTooltip "Passive: Duelist's Dance Move Speed bonus is increased to {{ percentms*100 }}%.Active: Fiora reveals all four Vitals on a champion for a max of {{ spell.fiorapassive:rdamagetotal }} max Health true damage and gains Duelist's Dance's Move Speed bonus while near the target.If Fiora strikes all four Vitals within {{ markduration }} seconds or if the target dies after she has hit at least one, Fiora restores {{ healpersecondcalc }} Health per second to surrounding allied champions for {{ healduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "110/90/70" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Fiora .

