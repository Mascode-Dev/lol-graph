    lol:spellSlot "Q" ;
    lol:spellId "KalistaMysticShot" ;
    lol:spellName "Pierce" ;
    lol:spellDescription "Throw a fast moving spear that passes through enemies it kills." ;
    lol:spellTooltip "Kalista hurls a spear, dealing {{ totaldamage }} physical damage to the first target hit. If this kills the target, the spear continues onward, carrying any Rend stacks to the next target hit.Kalista can dash after using this Ability using Martial Poise.{{ spellmodifierdescriptionappend }}" ;
