    lol:spellSlot "E" ;
    lol:spellId "LeonaZenithBlade" ;
    lol:spellName "Zenith Blade" ;
    lol:spellDescription "Leona projects a solar image of her sword, dealing magic damage to all enemies in a line. When the image fades, the last enemy champion struck will be briefly immobilized and Leona will dash to them." ;
    lol:spellTooltip "Leona thrusts with a sword of light, dealing {{ totaldamagetooltip }} magic damage. The last champion struck will be Rooted for {{ e2 }} seconds and Leona will dash to them.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/10.5/9/7.5/6" ;
