    lol:spellSlot "R" ;
    lol:spellId "GravesChargeShot" ;
    lol:spellName "Collateral Damage" ;
    lol:spellDescription "Graves fires an explosive shell dealing heavy damage to the first champion it hits. After hitting a champion or reaching the end of its range, the shell explodes dealing damage in a cone." ;
    lol:spellTooltip "Graves fires an explosive cartridge, blasting himself backwards. The cartridge deals {{ damage }} physical damage to the first enemy hit. After hitting an enemy champion or reaching the end of its range, the cartridge explodes outward, dealing {{ falloffdamage }} physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
