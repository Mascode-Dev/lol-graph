spell:Leona_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "LeonaSolarBarrier" ;
    lol:spellName "Eclipse" ;
    lol:spellDescription "Leona raises her shield to gain Damage Reduction, Armor, and Magic Resist. When the duration first ends, if there are nearby enemies, she will deal magic damage to them and prolong the duration of the effect." ;
    lol:spellTooltip "Leona raises her shield, reducing incoming damage by {{ flatdamagereduction }} and gaining {{ bonusarmortooltip }} Armor and {{ bonusmrtooltip }} Magic Resist for {{ e3 }} seconds. Afterwards, her shield detonates, dealing {{ totaldamagetooltip }} magic damage to nearby enemies. If she hits at least one, she retains the Armor and Magic Resist bonuses for an additional {{ e3 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13/12/11/10" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "450" ;
    lol:belongsToChampion champ:Leona .

