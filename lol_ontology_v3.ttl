spell:Zoe_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "ZoeQ" ;
    lol:spellName "Paddle Star!" ;
    lol:spellDescription "Zoe fires a missile that she can redirect in flight. Deals more damage the longer it flies in a straight line." ;
    lol:spellTooltip "Zoe fires a star that deals increasing damage the further it travels to the first enemy hit and surrounding enemies -- between {{ totaldamagetooltip }} to {{ maxdamagetooltip }} magic damage.Zoe can Recast this Ability to redirect the missile to a new position near Zoe.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
