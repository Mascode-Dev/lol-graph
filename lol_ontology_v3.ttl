    lol:spellSlot "Q" ;
    lol:spellId "PowerBall" ;
    lol:spellName "Powerball" ;
    lol:spellDescription "Rammus accelerates in a ball towards his enemies, dealing damage and slowing targets affected by the impact." ;
    lol:spellTooltip "Rammus curls into a ball, gaining {{ minimummovespeed }} Move Speed, accelerating up to {{ maximummovespeed }} Move Speed over {{ rollduration }} seconds. Rammus stops after colliding with an enemy, dealing {{ powerballdamage }} magic damage, Knocking Back, and Slowing nearby enemies by {{ slowpercent }}% for {{ slowduration }} second.Recast: Rammus ends this Ability early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12/10.5/9/7.5/6" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Rammus .

