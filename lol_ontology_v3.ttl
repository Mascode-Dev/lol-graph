    lol:spellName "Charm" ;
    lol:spellDescription "Ahri blows a kiss that damages and charms an enemy it encounters, instantly stopping movement abilities and causing them to walk harmlessly towards her." ;
    lol:spellTooltip "Ahri blows a kiss that Charms the first enemy hit for {{ charmduration }} seconds and deals {{ totaldamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
