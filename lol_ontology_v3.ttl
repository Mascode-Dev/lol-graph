spell:Karma_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "KarmaQ" ;
    lol:spellName "Inner Flame" ;
    lol:spellDescription "Karma sends forth a ball of spirit energy that explodes and deals damage upon hitting an enemy unit.Mantra Bonus: In addition to the explosion, Mantra increases the destructive power of her Inner Flame, creating a cataclysm which deals damage after a short delay." ;
    lol:spellTooltip "Karma fires a blast of energy, dealing {{ totaldamage }} magic damage to the first target hit and surrounding enemies, and Slowing them by {{ slowamount*-100 }}% for {{ slowduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8/7/6/5" ;
    lol:costBurn "40/50/60/70/80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "950" ;
    lol:belongsToChampion champ:Karma .

spell:Karma_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KarmaSpiritBind" ;
    lol:spellName "Focused Resolve" ;
    lol:spellDescription "Karma creates a tether between herself and a targeted enemy, dealing damage and revealing them. If the tether is not broken, the enemy will be rooted and damaged again.Mantra Bonus: Karma strengthens the link, healing herself and extending the root duration." ;
    lol:spellTooltip "Karma tethers herself to a champion or jungle monster, dealing {{ initialdamage }} magic damage and revealing them for {{ tetherduration }}s. If the tether remains unbroken, the target takes {{ initialdamage }} magic damage again and is Rooted for {{ rootduration }}s.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "675" ;
    lol:belongsToChampion champ:Karma .

spell:Karma_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "KarmaSolKimShield" ;
    lol:spellName "Inspire" ;
    lol:spellDescription "Karma summons a protective shield that absorbs incoming damage and increases the Move Speed of the protected ally.Mantra Bonus: Energy radiates out from her target, strengthening the initial shield and applying Inspire to nearby allied champions." ;
    lol:spellTooltip "Karma grants an allied champion {{ totalshield }} Shield for {{ shieldduration }}s and {{ movespeed*100 }}% Move Speed for {{ movespeedduration }}s.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "10/9.5/9/8.5/8" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
    lol:belongsToChampion champ:Karma .

spell:Karma_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "KarmaMantra" ;
    lol:spellName "Mantra" ;
    lol:spellDescription "Karma empowers her next ability to do an additional effect. Mantra is available at level 1 and does not require a skill point." ;
    lol:spellTooltip "Karma empowers her next Ability used within 8 seconds.Inner Flame: Deals an additional {{ rqimpactdamage }} magic damage and leaves behind a circle of flame, Slowing enemies and dealing an additional {{ rqfielddamage }} magic damage.Focused Resolve: Karma will restore {{ rwhealamount }} missing Health at the beginning and end of the tether, and Root for {{ rwbonusroot }}s longer.Inspire: Karma shields her target for {{ rebonusshield }} more Shield, and also shields allies near her target, granting them {{ rebonusshieldarea }} Shield and {{ removespeed*100 }}% Move Speed.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "4"^^xsd:integer ;
    lol:cooldownBurn "40/38/36/34" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "1100" ;
    lol:belongsToChampion champ:Karma .

