    lol:spellId "AmbessaW" ;
    lol:spellName "Repudiation" ;
    lol:spellDescription "Ambessa gains a shield, briefly braces herself, and then slams the ground to damage nearby enemies. If she blocked any non-minion damage while bracing herself, this ability will deal increased damage." ;
    lol:spellTooltip "Ambessa gains {{ calc_shield }} Shield for {{ shield_duration }} seconds and braces herself for {{ buff_duration }} seconds. She then slams the ground, dealing {{ calc_damage_low }} physical damage to nearby enemies, which increases to {{ calc_damage_high }} physical damage if she braced herself from damage from an enemy champion, large monster, or structure.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/17/16/15/14" ;
