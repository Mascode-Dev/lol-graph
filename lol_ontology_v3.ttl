    lol:rangeBurn "850" ;
    lol:belongsToChampion champ:Illaoi .

spell:Illaoi_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "IllaoiW" ;
    lol:spellName "Harsh Lesson" ;
    lol:spellDescription "Illaoi leaps to her target, dealing physical damage and causing nearby Tentacles to also swing at the target." ;
    lol:spellTooltip "Illaoi's next Attack causes her to leap at the target, dealing an additional {{ healthpercenttotal }} max Health physical damage. When she strikes, nearby Tentacles will Slam at the target.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "30" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
