champ:Soraka a lol:Champion, owl:NamedIndividual ;
    lol:championId "Soraka" ;
    lol:championKey "16" ;
    lol:championName "Soraka" ;
    lol:championTitle "the Starchild" ;
    lol:blurb "A wanderer from the celestial dimensions beyond Mount Targon, Soraka gave up her immortality to protect the mortal races from their own more violent instincts. She endeavors to spread the virtues of compassion and mercy to everyone she meets—even..." ;
    lol:lore "A wanderer from the celestial dimensions beyond Mount Targon, Soraka gave up her immortality to protect the mortal races from their own more violent instincts. She endeavors to spread the virtues of compassion and mercy to everyone she meets—even healing those who would wish harm upon her. And, for all Soraka has seen of this world's struggles, she still believes the people of Runeterra have yet to reach their full potential." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V25.20" ;
    lol:costBE "225"^^xsd:integer ;
    lol:costRP "260"^^xsd:integer ;
    lol:allyTip "Soraka is a powerful ally in battle, using her strong healing to keep the party moving forward." ;
    lol:allyTip "You can use Wish on your allies from across the map to save them from otherwise fatal events." ;
    lol:allyTip "Equinox can be used as a powerful zoning tool to keep enemies at bay." ;
    lol:enemyTip "Focus on attacking Soraka when she ever ventures to the frontline to heal her allies." ;
    lol:enemyTip "Take advantage of Soraka's long cooldown on Equinox if she uses it to harass." ;
    lol:enemyTip "It's easier to focus Soraka than the ally she is healing." ;
