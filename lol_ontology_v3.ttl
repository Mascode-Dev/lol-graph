    lol:spellSlot "W" ;
    lol:spellId "NocturneShroudofDarkness" ;
    lol:spellName "Shroud of Darkness" ;
    lol:spellDescription "Nocturne empowers his blades, passively gaining Attack Speed. Activating Shroud of Darkness allows Nocturne to fade into the shadows, creating a magical barrier which blocks a single enemy ability and doubles his passive Attack Speed if successful." ;
    lol:spellTooltip "Passive: Nocturne gains {{ e1 }}% Attack Speed.Active: Nocturne creates a shadow barrier for 1.5 seconds that blocks the next enemy Ability. If an Ability is blocked, this Ability's passive effect is increased to {{ e1 }}% Attack Speed for {{ e4 }} seconds.{{ spellmodifierdescriptionappend }}" ;
