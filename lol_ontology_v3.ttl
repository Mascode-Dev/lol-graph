spell:Pyke_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "PykeR" ;
    lol:spellName "Death From Below" ;
    lol:spellDescription "Pyke blinks to and executes low health enemies, allowing him to cast this spell again and granting additional gold to an ally who assists." ;
    lol:spellTooltip "Pyke strikes all enemy champions in an X, teleporting to and executing targets below {{ rdamage }} Health. Champions above the threshold and non-champions instead take physical damage equal to {{ reduceddamage*100 }}% of that amount ({{ reduceddamagefinal }}). When an enemy champion dies inside the X, Pyke can Recast this Ability for free within {{ rrecastduration }} seconds. If he executed that champion, the last assisting ally will also get kill gold. If he did not, he will still get kill gold as if he did.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/85/70" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Pyke .

spell:Pyke_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Gift of the Drowned Ones" ;
    lol:spellDescription "When Pyke is hidden from enemies, he regenerates damage that he has recently taken from champions. Pyke also cannot gain extra Maximum Health from any source, and instead gains Bonus AD." ;
    lol:belongsToChampion champ:Pyke .

