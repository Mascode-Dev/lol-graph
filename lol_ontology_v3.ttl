spell:Yasuo_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "YasuoQ1Wrapper" ;
    lol:spellName "Steel Tempest" ;
    lol:spellDescription "Thrusts forward, damaging all enemies in a line.On hit, grants a stack of Gathering Storm for a few seconds. At 2 stacks, Steel Tempest fires a whirlwind that knocks Airborne.Steel Tempest is treated as a basic attack and scales with all the same things." ;
    lol:spellTooltip "Yasuo thrusts, dealing {{ totaldamage }} physical damage. If he hits, he gains a stack for {{ gatheringstormduration }} seconds. While he has 2 stacks, his next use of this Ability fires a whirlwind from range, dealing the same damage and Knocking Up for {{ knockupdurationtooltiponly }} second.If used while dashing, this Ability strikes in a circle rather than a stab.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "475" ;
    lol:belongsToChampion champ:Yasuo .

spell:Yasuo_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "YasuoW" ;
    lol:spellName "Wind Wall" ;
    lol:spellDescription "Creates a moving wall that blocks all enemy projectiles for 4 seconds." ;
    lol:spellTooltip "Yasuo creates a drifting wall of wind that blocks all enemy projectiles for 4 seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "25/23/21/19/17" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Yasuo .

spell:Yasuo_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "YasuoE" ;
    lol:spellName "Sweeping Blade" ;
    lol:spellDescription "Dashes through target enemy, dealing magic damage. Each cast increases subsequent dash's damage, up to a max amount.Cannot be re-cast on the same enemy for a few seconds.If Steel Tempest is cast while dashing, it will strike as a circle." ;
    lol:spellTooltip "Yasuo dashes through a target, dealing {{ totaldamage }} magic damage. Each use of this Ability grants {{ bonusdamageperstack }} bonus damage to subsequent uses for {{ stackduration }} seconds, stacking up to {{ maxstacks }} times.This Ability has a {{ e2 }} second per-target Cooldown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "0.5/0.4/0.3/0.2/0.1" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "475" ;
    lol:belongsToChampion champ:Yasuo .

spell:Yasuo_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "YasuoR" ;
    lol:spellName "Last Breath" ;
    lol:spellDescription "Blinks to an Airborne enemy champion, dealing physical damage and holding all Airborne enemies in the area in the air. Grants maximum Flow but resets all stacks of Gathering Storm.For a moderate time afterwards, Yasuo's critical strikes gain significant Bonus Armor Penetration." ;
    lol:spellTooltip "Yasuo teleports to an Airborne enemy champion, dealing {{ damage }} physical damage and holding all nearby Airborne enemies up for an additional {{ rknockupduration }} second. Yasuo also gains maximum Flow, but loses all Steel Tempest stacks.Afterwards, Yasuo's critical strikes ignore {{ rpercentarmorpen }}% bonus Armor for {{ rbuffduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "70/50/30" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "1400" ;
    lol:belongsToChampion champ:Yasuo .

spell:Yasuo_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Way of the Wanderer" ;
    lol:spellDescription "Yasuo's Critical Strike Chance is increased. Additionally, Yasuo builds toward a shield whenever he is moving. The shield triggers when he takes damage from a champion or monster." ;
    lol:belongsToChampion champ:Yasuo .

