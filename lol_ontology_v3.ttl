    lol:spellSlot "W" ;
    lol:spellId "BardW" ;
    lol:spellName "Caretaker's Shrine" ;
    lol:spellDescription "Reveals a Health shrine which powers up over a short time, disappearing after healing and speeding up the first ally that touches it." ;
    lol:spellTooltip "Bard creates a Health shrine that grants {{ calc_movespeed }} Move Speed decaying over {{ movespeed_duration }} seconds and restores at least {{ initialheal }} Health to the first ally to enter. The shrine grows to restore {{ maxheal }} Health after existing for {{ chargeuptime }} seconds.Bard can have up to {{ maxpacks }} shrines at once. If an enemy champion enters a shrine, it is destroyed.This ability has {{ ammo_limit }} charges.Current Active Shrines: {{ f1 }} / {{ f2 }}{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "0" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "800" ;
