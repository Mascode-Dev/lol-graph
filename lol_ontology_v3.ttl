    lol:spellName "Tailwind" ;
    lol:spellDescription "Janna's allies gain Move Speed moving towards her.Janna deals a portion of bonus Move Speed as bonus magic damage on hit and with Zephyr." ;
    lol:belongsToChampion champ:Janna .

