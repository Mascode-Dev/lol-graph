    lol:spellName "Spirit Fire" ;
    lol:spellDescription "Nasus unleashes a spirit flame at a location, dealing damage and reducing the Armor of enemies who stand on it." ;
    lol:spellTooltip "Nasus ignites a spirit flame, dealing {{ initialdamage }} magic damage. Enemies in the area lose {{ e2 }}% Armor and take {{ totaldotdamage }} magic damage over {{ e3 }} seconds.{{ spellmodifierdescriptionappend }}" ;
