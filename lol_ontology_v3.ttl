spell:Aphelios_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "ApheliosQ_ClientTooltipWrapper" ;
    lol:spellName "Weapon Abilites" ;
    lol:spellDescription "Aphelios has 5 different activated abilities, based on his main-hand weapon:Calibrum (Rifle): Long range shot that marks its target for a long-range follow-up attack.Severum (Scythe Pistol): Run fast while attacking nearby enemies with both weapons.Gravitum (Cannon): Root all enemies slowed by this weapon.Infernum (Flamethrower): Blast enemies in a cone and attack them with your off-hand weapon.Crescendum (Chakram): Deploy a sentry that shoots your off-hand weapon." ;
    lol:spellTooltip "{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "6"^^xsd:integer ;
    lol:cooldownBurn "9" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1450" ;
    lol:belongsToChampion champ:Aphelios .

spell:Aphelios_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "ApheliosW" ;
    lol:spellName "Phase" ;
    lol:spellDescription "Aphelios swaps his main-hand gun with his off-hand gun, replacing his basic attack and activated ability." ;
    lol:spellTooltip "Swap main-hand and off-hand weapons, equipping Gravitum.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "6"^^xsd:integer ;
    lol:cooldownBurn "0.8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "250" ;
    lol:belongsToChampion champ:Aphelios .

spell:Aphelios_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "ApheliosE_ClientTooltipWrapper" ;
    lol:spellName "Weapon Queue System" ;
    lol:spellDescription "Aphelios has no third ability. This slot shows the next weapon Alune will give him. Weapon order begins fixed but may change over game time -- when a weapon is out of ammo it goes to the end of the order." ;
    lol:spellTooltip "{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "6"^^xsd:integer ;
    lol:cooldownBurn "0" ;
    lol:costBurn "0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000" ;
    lol:belongsToChampion champ:Aphelios .

spell:Aphelios_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "ApheliosR" ;
    lol:spellName "Moonlight Vigil" ;
    lol:spellDescription "Fire a concentrated blast of moonlight that explodes on enemy champions. Applies the unique effect of Aphelios' main-hand gun." ;
    lol:spellTooltip "Aphelios fires a concentrated blast of moonlight that explodes when it hits a champion, dealing {{ maxdamage }} physical damage to surrounding enemies.Then, Aphelios attacks all champions hit with his main-hand weapon. {{ Spell_ApheliosR_WeaponMod_{{ f1 }} }}{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/110/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1300" ;
    lol:belongsToChampion champ:Aphelios .

spell:Aphelios_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "The Hitman and the Seer" ;
    lol:spellDescription "Aphelios wields 5 Lunari Weapons made by his sister Alune. He has access to two at a time: one main-hand and one off-hand. Each weapon has a unique Basic Attack and Ability. Attacks and abilities consume a weapon's ammo. When out of ammo, Aphelios discards the weapon and Alune summons the next of the 5." ;
    lol:belongsToChampion champ:Aphelios .

