    lol:spellName "Scrap Shield" ;
    lol:spellDescription "Rumble pulls up a shield, protecting him from damage and granting him a quick burst of speed. While in Danger Zone, the shield strength and speed bonus is increased." ;
    lol:spellTooltip "Rumble tosses up a barrier, gaining {{ totalshield }} Shield for {{ shieldduration.1 }} seconds and {{ movespeed*100 }}% Move Speed for {{ movespeedduration }} second.Danger Zone: The barrier grants {{ empoweredshield }} Shield and {{ empoweredms }} Move Speed instead.{{ spellmodifierdescriptionappend }}" ;
