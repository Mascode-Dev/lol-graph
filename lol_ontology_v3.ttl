spell:Aurora_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "AuroraQ" ;
    lol:spellName "Twofold Hex" ;
    lol:spellDescription "Aurora sends out a missile that curses any enemies it hits. She can then recast the ability to draw active curses back toward herself, damaging foes who are hit along the way." ;
    lol:spellTooltip "Fire cursed energy in a direction, dealing {{ damage }} magic damage to enemies and cursing them for {{ markduration }} seconds.Recast: End the curse, drawing back part of the enemy's spirit to Aurora, dealing up to {{ q2damagemax }} magic damage to enemies passed through based on their missing Health. Damage beyond the first hit is reduced to 20%.If the duration runs out, Aurora will automatically Recast the Ability.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.5/8/7.5/7" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Aurora .

spell:Aurora_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "AuroraW" ;
    lol:spellName "Across the Veil" ;
    lol:spellDescription "Aurora leaps in a direction of her choosing, entering the spirit realm upon landing, becoming invisible, and gaining Move Speed for a short duration of time." ;
    lol:spellTooltip "Hop in a direction. Upon landing, enter the spirit realm, becoming Invisible for {{ invisduration }} seconds and entering Realm Hopper, gaining {{ movespeedbonus }}% Move Speed.Scoring a takedown on an enemy champion resets this Ability's Cooldown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/21/20/19/18" ;
    lol:costBurn "80" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:Aurora .

