    lol:spellName "Flamespitter" ;
    lol:spellDescription "Rumble torches opponents in front of him, dealing magic damage in a cone for 3 seconds. While in Danger Zone this damage is increased." ;
    lol:spellTooltip "Rumble ignites his flamethrower, dealing {{ flatdamage }} plus {{ healthdamage*100 }}% max Health magic damage over {{ flamespitterduration }} seconds, reduced to {{ minionmod*100 }}% against minions.Danger Zone: Damage is increased to {{ empowereddamage }} plus {{ empoweredhealth }} max Health.Percent damage is limited to {{ monstercap }} damage on Monsters. {{ spellmodifierdescriptionappend }}" ;
