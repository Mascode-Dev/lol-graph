    lol:spellSlot "Q" ;
    lol:spellId "LeonaShieldOfDaybreak" ;
    lol:spellName "Shield of Daybreak" ;
    lol:spellDescription "Leona uses her shield to perform her next basic attack, dealing bonus magic damage and stunning the target." ;
    lol:spellTooltip "Leona's next Attack Stuns for {{ e1 }} seconds and deals an additional {{ totaldamagetooltip }} magic damage.{{ spellmodifierdescriptionappend }}" ;
