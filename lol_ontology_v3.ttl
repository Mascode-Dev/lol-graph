    lol:spellSlot "R" ;
    lol:spellId "SejuaniR" ;
    lol:spellName "Glacial Prison" ;
    lol:spellDescription "Sejuani throws her bola that freezes and stuns the first champion hit and creates an ice storm that slows other enemies." ;
    lol:spellTooltip "Sejuani throws her True Ice bola, Stunning and revealing the first enemy champion hit for {{ e2 }} second and dealing {{ minordamagetooltip }} magic damage.If the bola travels at least 25% of its range, it Stuns and reveals for {{ e6 }} seconds instead. It then also creates an ice storm that Slows surrounding enemies by {{ e4 }}% for {{ e3 }} seconds. All affected enemies take {{ totaldamagetooltip }} magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/105/90" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1300" ;
    lol:belongsToChampion champ:Sejuani .

spell:Sejuani_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Fury of the North" ;
    lol:spellDescription "After being out of combat, Sejuani gains Frost Armor which grants Armor and Magic Resist and immunity to slows. Frost Armor persists for a short time after Sejuani takes damage.  Sejuani can damage a stunned enemy to shatter it, dealing massive magic damage." ;
    lol:belongsToChampion champ:Sejuani .

