    lol:spellId "NamiE" ;
    lol:spellName "Tidecaller's Blessing" ;
    lol:spellDescription "Empowers an allied champion for a short duration. The ally's basic attacks and spells deal bonus magic damage and slow the target." ;
    lol:spellTooltip "Nami empowers an allied champion's next {{ hitcount }} Attacks and Abilities for {{ buffduration }} seconds, causing them to Slow their targets by {{ totalslow }} for {{ slowduration }}s and deal an additional {{ totaldamage }} magic damage. {{ spellmodifierdescriptionappend }}" ;
