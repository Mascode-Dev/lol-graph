    lol:spellName "Molten Shield" ;
    lol:spellDescription "Grants Annie or an ally a shield, a burst of Move Speed, and damages enemies who strike her with attacks or spells." ;
    lol:spellTooltip "Annie grants an ally champion {{ shieldblocktotal }} Shield for {{ shieldduration }} seconds and {{ movespeedcalc }} Decaying Move Speed for {{ movementspeedduration }} seconds. While the shield holds, enemies who hit the shielded ally with an Attack or Ability receive {{ damagereturn }} magic damage once per shield.Tibbers always gains the effects of Molten Shield when summoned.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
