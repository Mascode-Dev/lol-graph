    lol:spellName "Fury of the Dragonborn" ;
    lol:spellDescription "Shyvana deals bonus damage to dragons and gains Armor and Magic Resistance. As Shyvana and her allies slay more dragons, she gains more bonus Armor and Magic Resistance." ;
    lol:belongsToChampion champ:Shyvana .

