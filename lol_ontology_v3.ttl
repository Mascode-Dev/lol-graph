champ:Ornn a lol:Champion, owl:NamedIndividual ;
    lol:championId "Ornn" ;
    lol:championKey "516" ;
    lol:championName "Ornn" ;
    lol:championTitle "The Fire below the Mountain" ;
    lol:blurb "Ornn is the Freljordian spirit of forging and craftsmanship. He works in the solitude of a massive smithy, hammered out from the lava caverns beneath the volcano Hearth-Home. There he stokes bubbling cauldrons of molten rock to purify ores and fashion..." ;
    lol:lore "Ornn is the Freljordian spirit of forging and craftsmanship. He works in the solitude of a massive smithy, hammered out from the lava caverns beneath the volcano Hearth-Home. There he stokes bubbling cauldrons of molten rock to purify ores and fashion items of unsurpassed quality. When other deities—especially Volibear—walk the earth and meddle in mortal affairs, Ornn arises to put these impetuous beings back in their place, either with his trusty hammer or the fiery power of the mountains themselves." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V25.23" ;
    lol:costBE "2400"^^xsd:integer ;
    lol:costRP "880"^^xsd:integer ;
    lol:allyTip "Learning build paths of items can help quickly select upgrades in lane." ;
    lol:allyTip "Volcanic Rupture can be used to set up zoning areas to threaten enemies." ;
    lol:allyTip "The order of your abilties matters! Try to optimize Brittle usage." ;
    lol:enemyTip "Try to stay away from walls. Ornn is much less strong if he cannot stun you." ;
    lol:enemyTip "Attack Ornn to keep him from creating items in lane." ;
    lol:hasRole role:Tank ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Freljord ;
