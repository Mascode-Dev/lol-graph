    lol:spellSlot "Q" ;
    lol:spellId "NocturneDuskbringer" ;
    lol:spellName "Duskbringer" ;
    lol:spellDescription "Nocturne throws a shadow blade that deals damage, leaves a Dusk Trail, and causes champions to leave a Dusk Trail. While on the trail, Nocturne can move through units and has increased Move Speed and Attack Damage." ;
    lol:spellTooltip "Nocturne throws a shadow blade, dealing {{ totaldamage }} physical damage and leaving a dusk trail for {{ e3 }} seconds. Enemy champions hit also leave a trail. While on the trail, Nocturne is Ghosted and gains {{ movespeed }}% Move Speed and {{ bonustrailad }} Attack Damage.{{ spellmodifierdescriptionappend }}" ;
