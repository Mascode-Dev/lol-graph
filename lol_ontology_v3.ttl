champ:Shaco a lol:Champion, owl:NamedIndividual ;
    lol:championId "Shaco" ;
    lol:championKey "35" ;
    lol:championName "Shaco" ;
    lol:championTitle "the Demon Jester" ;
    lol:blurb "Crafted long ago as a plaything for a lonely prince, the enchanted marionette Shaco now delights in murder and mayhem. Corrupted by dark magic and the loss of his beloved charge, the once-kind puppet finds pleasure only in the misery of the poor souls..." ;
    lol:lore "Crafted long ago as a plaything for a lonely prince, the enchanted marionette Shaco now delights in murder and mayhem. Corrupted by dark magic and the loss of his beloved charge, the once-kind puppet finds pleasure only in the misery of the poor souls he torments. He uses toys and simple tricks to deadly effect, finding the results of his bloody “games” hilarious—and for those who hear a dark chuckle in the dead of night, the Demon Jester may have marked them as his next plaything." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.01" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
    lol:allyTip "Using Deceive over terrain can help you make a clean escape." ;
    lol:allyTip "Try getting items with on-hit effects. These will also benefit your Hallucination clone." ;
    lol:allyTip "Backstab's damage can be increased with increased Critical Damage effects like Infinity Edge." ;
    lol:enemyTip "If Shaco is doing well early-game, it is worth the investment to place Stealth Wards near his Jungle camps." ;
    lol:enemyTip "If Shaco uses Deceive to enter a fight he won't be able to quickly use it again to get away. Work with your team to quickly focus him down." ;
    lol:hasRole role:Assassin ;
    lol:hasResourceType res:Mana ;
    lol:isFromRegion region:Runeterra ;
    lol:playsPosition pos:Jungle ;
    lol:playsPosition pos:Support ;
