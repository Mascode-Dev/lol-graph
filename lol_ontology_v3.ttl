    lol:spellDescription "Nasus ages an enemy champion, decelerating their Move Speed and Attack Speed over time." ;
    lol:spellTooltip "Nasus ages a champion, Slowing them by {{ slowbase }}%, increasing to {{ maxslowtooltiponly }}% over {{ duration }} seconds. Their Attack Speed is also reduced by {{ attackspeedslowmult*100 }}% of the Slow.{{ spellmodifierdescriptionappend }}" ;
