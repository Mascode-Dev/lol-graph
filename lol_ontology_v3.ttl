spell:Teemo_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "TeemoW" ;
    lol:spellName "Move Quick" ;
    lol:spellDescription "Teemo scampers around, passively increasing his Move Speed until he is struck by an enemy champion or turret. Teemo can sprint to gain bonus Move Speed that isn't stopped by being struck for a short time." ;
    lol:spellTooltip "Passive: Teemo gains {{ passivemovespeedbonus*100 }}% Move Speed while he hasn't been damaged by a champion or turret in the last {{ passivecooldownondamagetaken }} seconds.Active: Teemo sprints, gaining {{ activemovespeedbonus*100 }}% Move Speed that is not lost when struck for {{ activemovespeedbuffduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
