spell:Aurelion_Sol_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "AurelionSolQ" ;
    lol:spellName "Breath of Light" ;
    lol:spellDescription "Aurelion Sol channels his dragon breath for a few seconds, damaging the first enemy hit and splashing reduced damage onto nearby enemies. Each second the breath is channeled directly at an enemy will deal bonus damage, which is improved by the amount of Stardust that's been collected. This ability collects Stardust if the target is a champion." ;
    lol:spellTooltip "Aurelion Sol breathes starfire for up to {{ maxchannelduration }} seconds, dealing {{ damagepersecond }} magic damage per second to the first enemy hit and {{ aoemodifier*100 }}% of the damage to surrounding enemies.Each full second of breath on the same enemy deals a burst of {{ burstdamage }} magic damage plus {{ burstbonustruedamagetochamps }} max Health magic damage and absorbs {{ qmassstolen }} Stardust if they are a champion.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "3" ;
    lol:costBurn "35/40/45/50/55" ;
    lol:costType " Mana per second" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Aurelion_Sol .

spell:Aurelion_Sol_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "AurelionSolW" ;
    lol:spellName "Astral Flight" ;
    lol:spellDescription "Aurelion Sol flies over terrain in a targeted direction. While in this state, he can cast other abilities. Breath of Light no longer has a cooldown or maximum channel duration and deals increased damage while flying.Astral Flight's remaining cooldown is reduced whenever an enemy champion dies after being recently damaged by Aurelion Sol.Stardust increases Astral Flight's maximum range." ;
    lol:spellTooltip "Aurelion Sol flies in a direction. While flying, Breath of Light has no Cooldown, no max channel duration, and its flat damage is increased by {{ truedamagebonus*100 }}%.Takedowns on champions within {{ resetwindow }} seconds of damaging them refunds {{ tooltiptakedowncooldownmultiplier }}% of this Ability's Cooldown.Recast: End flight early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "22/20.5/19/17.5/16" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1500" ;
    lol:belongsToChampion champ:Aurelion_Sol .

spell:Aurelion_Sol_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "AurelionSolE" ;
    lol:spellName "Singularity" ;
    lol:spellDescription "Aurelion Sol summons a black hole, damaging enemies and slowly pulling them toward its center. This ability grants Stardust each time an enemy dies within the black hole and for each second an enemy champion is caught inside it. The center of the black hole executes enemies who are below a certain percentage of their maximum health. Stardust increases Singularity's area as well as the execution threshold." ;
    lol:spellTooltip "Aurelion Sol summons a black hole, dealing {{ damagepersecond }} magic damage per second and Dragging enemies towards the center for {{ duration }} seconds. Enemies in the center below {{ currentexecutionthreshold }}% max Health die instantly.The black hole absorbs Stardust when enemies die within it and each second an enemy champion is inside.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Aurelion_Sol .

spell:Aurelion_Sol_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "AurelionSolR" ;
    lol:spellName "Falling Star / The Skies Descend" ;
    lol:spellDescription "Falling Star: Aurelion Sol crashes a star into the earth. This impact deals magic damage and stuns enemies while also granting Stardust for each enemy champion it hits. Gathering enough Stardust transforms Aurelion Sol's next Falling Star into The Skies Descend.The Skies Descend: Aurelion Sol drags a giant star down from the heavens with an increased impact zone and increased damage, knocking up enemies rather than stunning them. A shockwave then spreads from the edge of the impact zone, which damages and slows the enemies it hits. Stardust increases the impact area of both Falling Star and The Skies Descend." ;
    lol:spellTooltip "Aurelion Sol plucks a star from the heavens and crashes it into the earth, dealing {{ maxdamagetooltip }} magic damage, Stunning enemies {{ stunduration }} second, and absorbing {{ massstolen }} Stardust for each champion hit.Gathering {{ calamitystacks }} Stardust transforms the next Falling Star into The Skies Descend.The Skies Descend: Aurelion Sol drags a constellation's worth of fury down from the cosmos, dealing {{ r2damage }} magic damage in a larger area, Knocking Up enemies hit for {{ stunduration }} second, and unleashing a massive shockwave that deals {{ shockwavedamage }} magic damage to champions and Epic Monsters and Slows all enemies hit by {{ shockwaveslow*100 }}% for 1 second.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/110/100" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1250" ;
    lol:belongsToChampion champ:Aurelion_Sol .

spell:Aurelion_Sol_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Cosmic Creator" ;
    lol:spellDescription "Aurelion Sol's damaging Abilities break down enemies into stacks of Stardust, which permanently improves each of his abilities." ;
    lol:belongsToChampion champ:Aurelion_Sol .

