    lol:spellTooltip "Graves creates a cloud of black smoke for 4 seconds, Slowing enemies inside by {{ e2 }}% and blocking their vision outside the area. The initial impact deals {{ impactdamage }} magic damage.{{ spellmodifierdescriptionappend }}" ;
