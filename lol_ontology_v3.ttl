    lol:spellId "AmbessaR" ;
    lol:spellName "Public Execution" ;
    lol:spellDescription "Ambessa blinks to the farthest enemy champion in a line of her choosing and suppresses them upon her arrival. She then slams the enemy into the ground where they take damage and are stunned." ;
    lol:spellTooltip "Passive: Ambessa gains {{ armor_penetration*100 }}% %i:scaleAPen% Armor Penetration and her Abilities heal her for {{ calc_omnivamp }} of the damage she dealt.Active: Ambessa becomes Unstoppable and blinks to the farthest enemy champion in a line, Suppressing the target for {{ suppress_duration }} seconds and then slamming them into the ground, dealing {{ calc_damage }} physical damage and Stunning them for {{ stun_duration }} seconds.{{ spellmodifierdescriptionappend }}" ;
