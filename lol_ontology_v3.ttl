spell:Ivern_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "IvernQ" ;
    lol:spellName "Rootcaller" ;
    lol:spellDescription "Ivern conjures a vine, dealing damage and rooting enemy targets hit. Ivern's allies can dash to the rooted target." ;
    lol:spellTooltip "Ivern conjures a vine dealing {{ totaldamage }} magic damage and Rooting the first enemy hit for {{ rootduration }} seconds. Allies that Attack a Rooted enemy dash into Attack Range. Recast: Ivern dashes directly onto the Rooted enemy.Hitting non-epic monsters reduces Rootcaller's cooldown by 50%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/13/12/11/10" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1125" ;
    lol:belongsToChampion champ:Ivern .

spell:Ivern_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "IvernW" ;
    lol:spellName "Brushmaker" ;
    lol:spellDescription "In brush, Ivern and his nearby allies attacks deal bonus magic damage. Ivern can activate this ability to create a patch of brush." ;
    lol:spellTooltip "Passive: While in brush and for {{ buffduration }} seconds after leaving, Ivern's Attacks deal an additional {{ totaldamage }} magic damage. Nearby allies will gain this effect for {{ allybuffduration }} seconds and deal {{ totalallydamage }} magic damage.Active: Ivern grows a patch of Brush, revealing the area for {{ revealduration }} seconds. The Brush persists until Ivern's team loses vision within it, or up to {{ maxbrushduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "0.5" ;
    lol:costBurn "30" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1150" ;
    lol:belongsToChampion champ:Ivern .

spell:Ivern_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "IvernE" ;
    lol:spellName "Triggerseed" ;
    lol:spellDescription "Ivern places a shield on an ally which explodes after a short duration slowing and damaging enemies. The shield refreshes if it hits no enemies." ;
    lol:spellTooltip "Ivern grants {{ totalshield }} Shield to an ally champion or Daisy. After {{ shieldduration }} seconds, it bursts, dealing {{ totaldamage }} magic damage and Slowing enemies by {{ slowamount*100 }}% for {{ slowduration }} seconds.If Triggerseed detonates and no enemy champions are hit while the shield still persists, the ally will be shielded for {{ totalshield }} for {{ shieldduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Ivern .

spell:Ivern_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "IvernR" ;
    lol:spellName "Daisy!" ;
    lol:spellDescription "Ivern summons his Sentinel friend Daisy to fight with him. Re-cast command Daisy to attack or move." ;
    lol:spellTooltip "Ivern summons his sentinel friend Daisy to leap into the fray for {{ daisyduration }} seconds.Daisy, Slam!: Daisy's 3rd consecutive Attack on the same champion or epic monster will launch a shockwave, dealing {{ totalshockwavedamage }} magic damage to all enemies hit as well as Knocking Up for {{ shockwaveccduration }} second. This effect can only occur once every {{ shockwavecd }} seconds.Recast: Instruct Daisy to Attack or move.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "140/130/120" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Ivern .

spell:Ivern_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Friend of the Forest" ;
    lol:spellDescription "Ivern cannot attack or be attacked by non-epic monsters. Ivern can create magical groves on jungle camps which grow over time. When the grove is fully grown, Ivern may free the monsters to receive gold and experience." ;
    lol:belongsToChampion champ:Ivern .

