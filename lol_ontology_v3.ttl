spell:Twitch_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "TwitchHideInShadows" ;
    lol:spellName "Ambush" ;
    lol:spellDescription "Twitch becomes Camouflaged for a short duration and gains Move Speed. When leaving Camouflage, Twitch gains Attack Speed for a short duration.When an enemy champion with Deadly Venom dies, Ambush's cooldown is reset." ;
    lol:spellTooltip "Twitch Camouflages and gains {{ movespeedmod }}% Move Speed for {{ stealthduration }} seconds. The Move Speed increases to {{ hiddenspeed }}% while near an enemy champion that can't see him. After exiting Camouflage, Twitch gains {{ attackspeedmod*100 }}% Attack Speed for {{ attackspeedduration }} seconds.When an enemy champion dies while afflicted with Venom, this Ability's Cooldown is refreshed.{{ spellmodifierdescriptionappend }}" ;
