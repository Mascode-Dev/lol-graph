spell:Fiora_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "FioraQ" ;
    lol:spellName "Lunge" ;
    lol:spellDescription "Fiora lunges in a direction and stabs a nearby enemy, dealing physical damage and applying on-hit effects." ;
    lol:spellTooltip "Fiora lunges in a direction and stabs the closest enemy, ward, or structure, dealing {{ totaldamage }} physical damage. The strike will prioritize Vitals and enemies it will kill.If Fiora strikes an enemy, this Ability's Cooldown is reduced by {{ cdrefundpercent*100 }}%.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
