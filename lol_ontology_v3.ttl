spell:Renekton_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "RenektonCleave" ;
    lol:spellName "Cull the Meek" ;
    lol:spellDescription "Renekton swings his blade, dealing moderate physical damage to all targets around him, and heals for a small portion of the damage dealt. If he has more than 50 Fury, his damage and heal are increased." ;
    lol:spellTooltip "Renekton swings his blade, dealing {{ basicdamage }} physical damage and restoring {{ nonchamphealing }} Health per non-champion and {{ champhealing }} per champion hit. He also generates {{ minionfurygain }} Fury per non-champion and {{ championfurygain }} Fury per champion.Fury Bonus: Damage is increased to {{ empdamage }} physical damage and healing is increased to {{ empnonchamphealing }} Health against non-champions and {{ empchamphealing }} Health against champions. Does not generate any Fury.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "7" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Renekton .

spell:Renekton_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "RenektonPreExecute" ;
    lol:spellName "Ruthless Predator" ;
    lol:spellDescription "Renekton slashes his target twice, dealing moderate physical damage and stuns them for 0.75 seconds. If Renekton has more than 50 Fury, he slashes his target three times, destroying damage shields on the target, dealing high physical damage, and stunning them for 1.5 seconds." ;
    lol:spellTooltip "Renekton's next Attack strikes twice, Stunning for {{ stunduration }} seconds and dealing a total of {{ basictotaldamage }} physical damage. Hitting a champion generates an additional {{ bonusfuryvschamps }} Fury.Fury Bonus: Renekton Attacks 3 times instead, destroying Shields before dealing {{ emptotaldamage }} physical damage and Stunning for {{ enragedstunduration }} seconds. Does not generate any Fury.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/14/12/10/8" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "300" ;
    lol:belongsToChampion champ:Renekton .

