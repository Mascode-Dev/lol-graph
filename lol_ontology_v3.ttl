spell:Kindred_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "KindredQ" ;
    lol:spellName "Dance of Arrows" ;
    lol:spellDescription "Kindred tumbles and shoots up to three arrows at nearby targets." ;
    lol:spellTooltip "Kindred vaults, firing an arrow at up to 3 enemies, dealing {{ totaldamage }} physical damage and gaining {{ totalqattackspeed }} Attack Speed for {{ e8 }} seconds.While inside of Wolf's Frenzy, this Ability's Cooldown is reduced to {{ e4 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9" ;
    lol:costBurn "35" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "340" ;
    lol:belongsToChampion champ:Kindred .

spell:Kindred_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "KindredW" ;
    lol:spellName "Wolf's Frenzy" ;
    lol:spellDescription "Wolf enrages and attacks enemies around him.  Lamb passively gains stacks by moving and attacking. When fully charged, Lamb's next attack restores health." ;
    lol:spellTooltip "Passive: Kindred gains stacks as they move and attack. At 100 stacks, Kindred's next Attack restores up to {{ attackheal }} Health based on their missing Health.Active: Kindred claims a territory, ordering Wolf to bite at the last enemy Lamb Attacked. Wolf's bites deal {{ basewolfdamage }} plus {{ percentwolfdamage }} current Health magic damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/17/16/15/14" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "560" ;
    lol:belongsToChampion champ:Kindred .

spell:Kindred_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "KindredEWrapper" ;
    lol:spellName "Mounting Dread" ;
    lol:spellDescription "Lamb fires a carefully placed shot, slowing the target. If Lamb attacks the target two more times, her third attack instead directs Wolf to pounce on the enemy, savaging them for massive damage." ;
    lol:spellTooltip "Kindred weakens an enemy, Slowing them by {{ totalslow }}% for {{ slowduration }} second.Kindred's third Attack against the target within {{ totalduration }} seconds of each other directs Wolf to pounce on the enemy, dealing an additional {{ basebitedamage }} plus {{ percentbitedamage }} missing Health physical damage.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "14/12.5/11/9.5/8" ;
    lol:costBurn "0" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Kindred .

spell:Kindred_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "KindredR" ;
    lol:spellName "Lamb's Respite" ;
    lol:spellDescription "Lamb grants all living things inside a zone a respite from death. Until the effect ends, nothing can die. At the end, units are healed." ;
    lol:spellTooltip "Kindred blesses the ground for {{ e2 }} seconds, allowing no unit, ally, enemy, or neutral to die while inside. Upon reaching 10% Health, units can't be damaged or healed while still inside the zone.When the blessing ends, all units inside heal for {{ e1 }} Health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "160/140/120" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "500" ;
    lol:belongsToChampion champ:Kindred .

spell:Kindred_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Mark of the Kindred" ;
    lol:spellDescription "Kindred can mark targets to Hunt. Successfully completing a Hunt permanently empowers Kindred's basic abilities. Every 4 hunts completed also increases Kindred's basic attack range." ;
    lol:belongsToChampion champ:Kindred .

