spell:Nidalee_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "JavelinToss" ;
    lol:spellName "Javelin Toss / Takedown" ;
    lol:spellDescription "In human form, Nidalee throws a spiked javelin at her target that gains damage as it flies.  As a cougar, her next attack will attempt to fatally wound her target, dealing more damage the less life they have." ;
    lol:spellTooltip "Human Form: Nidalee throws her javelin, dealing {{ humanminimumdamage }} magic damage, increased up to {{ humanmaximumdamage }} magic damage based on distance flown.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "6" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1500" ;
    lol:belongsToChampion champ:Nidalee .

spell:Nidalee_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "Bushwhack" ;
    lol:spellName "Bushwhack / Pounce" ;
    lol:spellDescription "In human form, Nidalee lays a trap for unwary opponents that, when sprung, damages and reveals its target. As a cougar, she jumps in a direction, dealing damage in an area where she lands." ;
    lol:spellTooltip "Human Form: Nidalee places an invisible trap for 2 minutes. When an enemy walks over it, they are dealt {{ damagepersecond }} magic damage per second for {{ e3 }} seconds.{{ maxtraps }} traps may be active at once.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "13/12/11/10/9" ;
    lol:costBurn "30/35/40/45/50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Nidalee .

spell:Nidalee_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "PrimalSurge" ;
    lol:spellName "Primal Surge / Swipe" ;
    lol:spellDescription "In human form, Nidalee channels the spirit of the cougar to heal her allies and imbue them with Attack Speed for a short duration. As a cougar, she claws in a direction, dealing damage to enemies in front of her." ;
    lol:spellTooltip "Human Form: Nidalee restores {{ totalhealing }} Health increased up to {{ maxhealing }} based on missing Health and grants them {{ bonusas*100 }}% Attack Speed for {{ asduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "12" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Nidalee .

spell:Nidalee_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "AspectOfTheCougar" ;
    lol:spellName "Aspect Of The Cougar" ;
    lol:spellDescription "Nidalee transforms into a cougar, gaining new abilities." ;
    lol:spellTooltip "Passive: While in Human Form, applying Hunted refreshes this Ability's Cooldown.Human Form: Nidalee transforms into Cougar Form, gaining melee Attacks and replacing her Active Abilities.Cougar Form: Nidalee transforms into Human Form, gaining ranged Attacks and replacing her Active Abilities.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "4"^^xsd:integer ;
    lol:cooldownBurn "3" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "20" ;
    lol:belongsToChampion champ:Nidalee .

spell:Nidalee_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Prowl" ;
    lol:spellDescription "Moving through brush increases Nidalee's Move Speed by 10% for 2 seconds, increased to 30% toward visible enemy champions within 1400 range.Hitting champions or monsters with Javelin Toss or Bushwhack triggers a Hunt, granting True Sight of them for 4 seconds. During this time, Nidalee gains 10% Move Speed (increased to 30% toward the Hunted target) and her Takedown and Pounce are enhanced against them." ;
    lol:belongsToChampion champ:Nidalee .

