spell:Ashe_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "AsheQ" ;
    lol:spellName "Ranger's Focus" ;
    lol:spellDescription "Ashe builds up Focus by attacking. At maximum Focus, Ashe can cast Ranger's Focus to consume all stacks of Focus, temporarily increasing her Attack Speed and transforming her basic attack into a powerful flurry attack for the duration." ;
    lol:spellTooltip "Passive: Ashe's Attacks grant a stack for {{ e1 }} seconds. At {{ e2 }} stacks, she may activate this Ability.Active: Ashe gains {{ e4 }}% Attack Speed and her Attacks deal {{ empowereddamage }} damage instead for {{ e3 }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "0" ;
    lol:costBurn "30" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Ashe .

spell:Ashe_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "Volley" ;
    lol:spellName "Volley" ;
    lol:spellDescription "Ashe fires arrows in a cone for increased damage. Also applies Frost Shot." ;
    lol:spellTooltip "Ashe fires a volley of {{ numberofarrowstooltip }} arrows, each dealing {{ totaldamage }} physical damage. Enemies can be hit by multiple arrows, but only take damage from the first.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/14.5/11/7.5/4" ;
    lol:costBurn "75/70/65/60/55" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1200" ;
    lol:belongsToChampion champ:Ashe .

spell:Ashe_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "AsheSpiritOfTheHawk" ;
    lol:spellName "Hawkshot" ;
    lol:spellDescription "Ashe sends her Hawk Spirit on a scouting mission anywhere on the map." ;
    lol:spellTooltip "Ashe sends forth a hawk to grant vision for 5 seconds anywhere on the map. It also reveals the area around it as it flies.This Ability has 2 charges ({{ chargecooldown }} second recharge).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "5" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Ashe .

spell:Ashe_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "EnchantedCrystalArrow" ;
    lol:spellName "Enchanted Crystal Arrow" ;
    lol:spellDescription "Ashe fires a missile of ice in a straight line. If the arrow collides with an enemy Champion, it deals damage and stuns the Champion, stunning for longer the farther arrow has traveled. In addition, surrounding enemy units take damage and are slowed." ;
    lol:spellTooltip "Ashe launches a crystal arrow of ice that Stuns the first champion hit and deals {{ rmaindamage }} magic damage. The Stun duration increases with distance travelled, up to {{ maxstunduration }} seconds. Surrounding enemies are Slowed by Frost Shot.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/80/60" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "25000" ;
    lol:belongsToChampion champ:Ashe .

spell:Ashe_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Frost Shot" ;
    lol:spellDescription "Ashe's attacks slow their target, causing her to deal increased damage to these targets.Ashe's critical strikes deal no bonus damage but apply an empowered slow to the target." ;
    lol:belongsToChampion champ:Ashe .

