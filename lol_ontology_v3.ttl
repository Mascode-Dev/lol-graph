spell:Orianna_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "OrianaRedactCommand" ;
    lol:spellName "Command: Protect" ;
    lol:spellDescription "Orianna commands her Ball to attach to an allied champion, Shielding them and dealing magic damage to any enemies it passes through on the way. Additionally, the Ball grants additional Armor and Magic Resist to the champion it is attached to." ;
    lol:spellTooltip "Passive: The Ball adds {{ e2 }} Armor and {{ e2 }} Magic Resist to the allied champion it is attached to.Active: Orianna commands her Ball to attach to an allied champion, granting them {{ totalshieldtooltip }} Shield for {{ e5 }} seconds. Enemies the Ball passes through take {{ totaldamagetooltip }} magic damage.{{ spellmodifierdescriptionappend }}" ;
