    lol:spellDescription "Sylas lunges at an enemy with magical force dealing damage and healing himself against enemy champions." ;
    lol:spellTooltip "Sylas lunges at an enemy with magical force dealing {{ mindamage }} magic damage. Against champions, Sylas restores between {{ minhealing }} and {{ maxhealing }} Health based on his missing Health (max healing at or below {{ maxexecutethreshold*100 }}% Health).{{ spellmodifierdescriptionappend }}" ;
