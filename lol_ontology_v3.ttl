spell:Anivia_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "FlashFrost" ;
    lol:spellName "Flash Frost" ;
    lol:spellDescription "Anivia brings her wings together and summons a sphere of ice that flies towards her opponents, chilling and damaging anyone in its path. When the sphere explodes it does moderate damage in a radius, stunning anyone in the area." ;
    lol:spellTooltip "Anivia fires a massive chunk of ice, dealing {{ totalpassthroughdamage }} magic damage and Chilling enemies for {{ slowduration }} seconds, Slowing them by {{ spell.glacialstorm:slowamount }}%. At the end of its range, the ice detonates, Stunning enemies for {{ stunduration }} seconds and dealing {{ totalexplosiondamage }} magic damage.Anivia can Recast this ability while the ice flies to detonate it early.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "80/85/90/95/100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1075" ;
    lol:belongsToChampion champ:Anivia .

spell:Anivia_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "Crystallize" ;
    lol:spellName "Crystallize" ;
    lol:spellDescription "Anivia condenses the moisture in the air into an impassable wall of ice to block all movement. The wall only lasts a short duration before it melts." ;
    lol:spellTooltip "Anivia summons a wall of ice {{ e2 }} units wide. The wall lasts for {{ e1 }} seconds before it melts.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "17" ;
    lol:costBurn "70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1000" ;
    lol:belongsToChampion champ:Anivia .

spell:Anivia_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "Frostbite" ;
    lol:spellName "Frostbite" ;
    lol:spellDescription "With a flap of her wings, Anivia blasts a freezing gust of wind at her target, dealing damage. If the target was recently hit by Flash Frost or damaged by a fully formed Glacial Storm, the damage they take is doubled." ;
    lol:spellTooltip "Anivia blasts an enemy with a freezing wind, dealing {{ totaldamage }} magic damage. Against Chilled enemies, Anivia deals {{ empowereddamage }} magic damage instead.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "50" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "650" ;
    lol:belongsToChampion champ:Anivia .

spell:Anivia_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "GlacialStorm" ;
    lol:spellName "Glacial Storm" ;
    lol:spellDescription "Anivia summons a driving rain of ice and hail to damage her enemies and slow their advance." ;
    lol:spellTooltip "Toggle: Anivia calls forth a driving rain of ice and hail that Slows enemies by {{ slowamount }}% and deals {{ totaldamagepersecond }} magic damage per second. The storm increases in size over {{ growthtime }} seconds.When the storm is fully formed, it Chills, Slows by {{ slowpercentempoweredtt }}%, and does {{ empowereddamagepersecondtooltiponly }} magic damage per second instead.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "4/3/2" ;
    lol:costBurn "60" ;
    lol:costType " + {{ manacostpersecond }} Mana per second" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Anivia .

