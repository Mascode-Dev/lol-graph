spell:Jinx_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "JinxQ" ;
    lol:spellName "Switcheroo!" ;
    lol:spellDescription "Jinx modifies her basic attacks by swapping between Pow-Pow, her minigun and Fishbones, her rocket launcher. Attacks with Pow-Pow grant Attack Speed, while attacks with Fishbones deal area of effect damage, gain increased range, but drain Mana and attack slower." ;
    lol:spellTooltip "Jinx swaps weapons between Fishbones the rocket launcher and Pow-Pow the minigun.While using the rocket launcher, Jinx's Attacks deal {{ rocketdamage }} physical damage to the target and nearby enemies, gain {{ rocketbonusrange }} range, cost Mana, and scale {{ rocketaspdpenalty*100 }}% less with bonus Attack Speed.While using the minigun, Jinx's Attacks grant Attack Speed for {{ minigunattackspeedduration }} seconds, stacking up to {{ minigunattackspeedstacks }} times (+{{ minigunattackspeedmax }}% %i:scaleAS% max).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "0.9" ;
    lol:costBurn "20" ;
    lol:costType " Mana Per Rocket" ;
    lol:rangeBurn "600" ;
    lol:belongsToChampion champ:Jinx .

