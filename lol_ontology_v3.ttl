spell:Viktor_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "ViktorW" ;
    lol:spellName "Gravity Field" ;
    lol:spellDescription "Viktor conjures a heavy gravitational field that slows enemies caught within its radius. Enemies who stay in the field for too long become stunned.Augment: Viktor's spells apply a slow to enemies." ;
    lol:spellTooltip "Viktor deploys a gravitational imprisonment device for {{ fieldduration }} seconds, Slowing enemies inside it by {{ slowpotency*-1 }}%. Enemies who remain within its radius for 1.25 seconds are Stunned for {{ stunduration }} seconds.Upgraded Passive: Viktor's Abilities Slow by {{ augmentslow }}% for 1 second.{{ spellmodifierdescriptionappend }}" ;
