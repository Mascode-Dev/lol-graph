    lol:spellDescription "Yone blinks behind the last champion in a line with a slash so powerful it pulls all enemies hit towards him." ;
    lol:spellTooltip "Yone strikes all enemies along a path for {{ tooltipdamage }} physical damage and {{ tooltipdamage }} magic damage, teleporting behind the last champion hit and Knocking Up victims towards Yone.{{ spellmodifierdescriptionappend }}" ;
