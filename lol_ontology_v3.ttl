spell:Illaoi_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "IllaoiQ" ;
    lol:spellName "Tentacle Smash" ;
    lol:spellDescription "Increases the damage dealt by Tentacles. When activated, Illaoi smashes down a Tentacle that deals physical damage." ;
    lol:spellTooltip "Passive: Slam damage is increased by {{ spell.illaoiq:tentacledamageamp*100 }}% (currently {{ spell.illaoiq:tentacledamagetotal }} physical damage).Active: Illaoi swings her idol, causing a Tentacle to Slam forward.{{ spellmodifierdescriptionappend }}" ;
