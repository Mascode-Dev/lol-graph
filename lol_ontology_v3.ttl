spell:Varus_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "VarusQ" ;
    lol:spellName "Piercing Arrow" ;
    lol:spellDescription "Varus readies and then fires a powerful shot that gains extra range and damage the longer he spends preparing to fire." ;
    lol:spellTooltip "Begin Charging: Varus draws back his next shot, Slowing himself by {{ e7 }}%. After {{ e5 }} seconds, if not fired, Varus will cancel the Ability and refund {{ e4 }}% of its Mana cost.Release: Varus releases the arrow, dealing {{ totaldamagemintooltip }} physical damage, reduced by {{ e3 }}% per enemy hit (minimum {{ e9 }}%). Damage and Blight detonation effects are increased by up to {{ maxchargeamp*100 }}% based on charge time (maximum {{ totaldamagemax }}) .{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "16/15/14/13/12" ;
    lol:costBurn "50/55/60/65/70" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "925" ;
    lol:belongsToChampion champ:Varus .

spell:Varus_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "VarusW" ;
    lol:spellName "Blighted Quiver" ;
    lol:spellDescription "Passive: Varus' basic attacks deal bonus magic damage and apply Blight. Varus' other abilities detonate Blight, dealing magic damage based on the target's maximum Health. Active: Varus empowers his next Piercing Arrow." ;
    lol:spellTooltip "Passive: Varus' Attacks deal an additional {{ onhitdamage }} magic damage and apply a Blight stack for {{ e3 }} seconds (max {{ e4 }} stacks).Varus' other Abilities detonate Blight stacks dealing {{ percenthpperstack }} max Health magic damage per stack (max {{ maxpercenthpperstack }} max Health damage). Detonating Blight on champions and epic monsters also reduces his basic Abilities' Cooldowns by {{ cdrperblightstack*100 }}% of their Maximum per stack.Active: Varus' next Piercing Arrow deals an additional {{ qempowerpercenthp }} missing Health magic damage, increased up to {{ maxqempowerpercenthp }} missing Health damage based on charge time.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "40" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "750" ;
    lol:belongsToChampion champ:Varus .

spell:Varus_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "VarusE" ;
    lol:spellName "Hail of Arrows" ;
    lol:spellDescription "Varus fires a hail of arrows that deal physical damage and desecrate the ground. Desecrated ground slows enemies' Move Speed and reduces their self healing and regeneration." ;
    lol:spellTooltip "Varus fires a hail of arrows that deals {{ totaldamage }} physical damage and desecrates the ground for {{ e3 }} seconds, Slowing enemies by {{ slowpercent*-100 }}% and applying {{ grievousamount*100 }}% Grievous Wounds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "18/16/14/12/10" ;
    lol:costBurn "90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "925" ;
    lol:belongsToChampion champ:Varus .

spell:Varus_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "VarusR" ;
    lol:spellName "Chain of Corruption" ;
    lol:spellDescription "Varus flings out a damaging tendril of corruption that immobilizes the first enemy champion hit and then spreads towards nearby uninfected champions, immobilizing them too on contact." ;
    lol:spellTooltip "Varus flings out a tendril of corruption, Rooting the first champion hit for {{ e2 }} seconds and dealing {{ totaldamage }} magic damage. Rooted enemies gain {{ e4 }} Blight stacks over the duration.The corruption spreads from its target to uninfected enemy champions. If it reaches them, they take the same damage and Root.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/80/60" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1300" ;
    lol:belongsToChampion champ:Varus .

