spell:Dr__Mundo_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "DrMundoQ" ;
    lol:spellName "Infected Bonesaw" ;
    lol:spellDescription "Dr. Mundo throws an infected bonesaw, dealing damage to the first enemy hit based on their current health and slowing them." ;
    lol:spellTooltip "Dr. Mundo hurls his bonesaw, dealing {{ currenthealthdamage*100 }}% current Health magic damage to the first enemy hit and Slowing them by {{ slowamount*100 }}% for {{ slowduration }} seconds.If the bonesaw hits a champion or monster, Dr. Mundo restores {{ healthrestoreonhitchampionmonster }} Health. If it hits a non-champion or non-monster, Dr. Mundo instead restores {{ healthrestoreonhitminion }} Health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "4" ;
    lol:costBurn "0" ;
    lol:costType " Health" ;
    lol:rangeBurn "975" ;
    lol:belongsToChampion champ:Dr__Mundo .

spell:Dr__Mundo_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "DrMundoW" ;
    lol:spellName "Heart Zapper" ;
    lol:spellDescription "Dr. Mundo electrocutes himself, dealing persistent damage to nearby enemies and storing a portion of damage he takes. At the end of the duration or on Recast, Dr. Mundo deals a burst of damage to nearby enemies. If the burst hit an enemy, he heals a percentage of the stored damage." ;
    lol:spellTooltip "Dr. Mundo charges up a defibrilator, dealing {{ damagepertick*4 }} magic damage each second for up to {{ duration }} seconds to nearby enemies. Additionally he stores {{ grayhealthstorageinitial }} of damage taken for the first {{ grayhealthinitialduration }} seconds and {{ grayhealthstorage*100 }}% for the remaining duration as gray health and can Recast.Recast: Detonate the defibrilator, dealing {{ totaldamage }} magic damage to nearby enemies. If this hits at least one champion, Dr. Mundo restores {{ grayhealthbigmod*100 }}% of gray health, otherwise he instead restores {{ grayhealthsmallmod*100 }}% of gray health.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "17/16.5/16/15.5/15" ;
    lol:costBurn "0" ;
    lol:costType "% Current Health" ;
    lol:rangeBurn "325" ;
    lol:belongsToChampion champ:Dr__Mundo .

spell:Dr__Mundo_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "DrMundoE" ;
    lol:spellName "Blunt Force Trauma" ;
    lol:spellDescription "Passive - Dr. Mundo gains bonus Attack Damage, increasing based on his max Health.Active - Dr. Mundo slams his “medical” bag into an enemy, dealing additional damage based on his missing Health. If the enemy dies they are swatted away, dealing damage to enemies they pass through." ;
    lol:spellTooltip "Passive: Dr Mundo gains {{ passivebonusad }} Attack Damage.Active: Dr Mundo violently swings his \"medical\" bag, causing his next Attack to deal an additional {{ additionaldamage }} physical damage, increased by up to {{ maxdamageamptooltip }} based on his missing Health. If the enemy is killed, Mundo swats them away, dealing {{ additionaldamage }} physical damage to enemies they pass through.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.25/7.5/6.75/6" ;
    lol:costBurn "0" ;
    lol:costType " Health" ;
    lol:rangeBurn "0" ;
    lol:belongsToChampion champ:Dr__Mundo .

spell:Dr__Mundo_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "DrMundoR" ;
    lol:spellName "Maximum Dosage" ;
    lol:spellDescription "Dr. Mundo pumps himself with chemicals, instantly healing a percent of his missing Health. He then gains Move Speed and regenerates a portion of his maximum Health over a long duration." ;
    lol:spellTooltip "Dr. Mundo pumps himself with chemicals, gaining {{ missinghealthheal*100 }}% of his missing Health as max Health, {{ speedboostamount*100 }}% Move Speed, and regenerating {{ maxhealthhot*100 }}% max Health over {{ duration }} seconds.At Rank 3, both healing effects are increased by an additional {{ bonuspernearbychampion*100 }}% per nearby enemy champion.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120" ;
    lol:costBurn "0" ;
    lol:costType "No Cost" ;
    lol:rangeBurn "20" ;
    lol:belongsToChampion champ:Dr__Mundo .

spell:Dr__Mundo_Passive a lol:PassiveAbility, owl:NamedIndividual ;
    lol:spellName "Goes Where He Pleases" ;
    lol:spellDescription "Dr. Mundo resists the first Immobilizing effect that hits him, instead losing Health and dropping a chemical cannister nearby. Dr. Mundo can pick it up by walking over it, restoring Health and reducing this Ability's Cooldown.Dr. Mundo also has significantly increased Health regeneration." ;
    lol:belongsToChampion champ:Dr__Mundo .

