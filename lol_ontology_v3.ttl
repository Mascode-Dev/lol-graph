champ:Senna a lol:Champion, owl:NamedIndividual ;
    lol:championId "Senna" ;
    lol:championKey "235" ;
    lol:championName "Senna" ;
    lol:championTitle "the Redeemer" ;
    lol:blurb "Cursed from childhood to be haunted by the supernatural Black Mist, Senna joined a sacred order known as the Sentinels of Light, and fiercely fought back—only to be killed, her soul imprisoned in a lantern by the cruel specter Thresh. But refusing to..." ;
    lol:lore "Cursed from childhood to be haunted by the supernatural Black Mist, Senna joined a sacred order known as the Sentinels of Light, and fiercely fought back—only to be killed, her soul imprisoned in a lantern by the cruel specter Thresh. But refusing to lose hope, within the lantern Senna learned to use the Mist, and reemerged to new life, forever changed. Now wielding darkness along with light, Senna seeks to end the Black Mist by turning it against itself—with every blast of her relic weapon, redeeming the souls lost within." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V26.05" ;
