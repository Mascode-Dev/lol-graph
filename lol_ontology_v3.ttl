spell:Heimerdinger_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "HeimerdingerQ" ;
    lol:spellName "H-28 G Evolution Turret" ;
    lol:spellDescription "Heimerdinger lays down a rapid-fire cannon turret equipped with a secondary pass-through beam attack (turrets deal half damage to towers)." ;
    lol:spellTooltip "Heimerdinger constructs a Turret that attacks nearby enemies. Heimerdinger can have {{ maxturrets }} turrets active at once. Turrets slowly build up charge. At max charge, they fire a stronger attack.If Heimerdinger gets too far away, his Turrets will deactivate after 8 seconds.This Ability has {{ maxkits }} charges.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "1" ;
    lol:costBurn "20" ;
    lol:costType " Turret Kit & {{ cost }} Mana" ;
    lol:rangeBurn "350" ;
    lol:belongsToChampion champ:Heimerdinger .

spell:Heimerdinger_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "HeimerdingerW" ;
    lol:spellName "Hextech Micro-Rockets" ;
    lol:spellDescription "Heimerdinger fires long-range rockets that converge on his cursor." ;
    lol:spellTooltip "Heimerdinger unleashes a barrage of {{ rockets }} rockets that deal {{ damage }} magic damage to the first enemy hit. Additional rocket hits deal reduced damage.Max Damage: {{ totaldamage }} magic damage.Nearby Turrets gain 20% charge per rocket that hits a champion.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1325" ;
    lol:belongsToChampion champ:Heimerdinger .

spell:Heimerdinger_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "HeimerdingerE" ;
    lol:spellName "CH-2 Electron Storm Grenade" ;
    lol:spellDescription "Heimerdinger lobs a grenade at a location, dealing damage to enemy units, as well as stunning anyone directly hit and slowing surrounding units." ;
    lol:spellTooltip "Heimerdinger hurls a grenade that deals {{ damage }} magic damage in an area and Slows by {{ slowpercent.0*100 }}% for {{ slowduration }} seconds. Enemies in the center are also Stunned for {{ stunduration }} seconds.Hitting a champion fully charges nearby Turrets.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11" ;
    lol:costBurn "85" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "970" ;
    lol:belongsToChampion champ:Heimerdinger .

spell:Heimerdinger_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "HeimerdingerR" ;
    lol:spellName "UPGRADE!!!" ;
    lol:spellDescription "Heimerdinger invents an upgrade, causing his next spell to have increased effects." ;
    lol:spellTooltip "Heimerdinger upgrades his next non-ultimate Ability.H-28Q Apex Turret: Place an upgraded Turret for 8 seconds that doesn't count towards Heimerdinger's max turrets, deals {{ qultdamage }} magic damage per shot and {{ qultdamagebeam }} magic damage per charged shot. Its attacks deal damage in an area, Slow by 25% for 2 seconds, and it is immune to crowd control.Hextech Rocket Swarm: Fires 4 waves of rockets that each deal {{ wultdamage }} magic damage. Champions and jungle monsters hit by additional rockets take reduced damage, and minions take increased damage. Max Damage: {{ wulttotaldamage }} magic damage. CH-3X Lightning Grenade: Throws a bouncing grenade that discharges three times, dealing {{ eultdamage }} magic damage. The Stun and Slow areas are larger.Recast: Cancel this Ability.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "100/85/70" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "1" ;
    lol:belongsToChampion champ:Heimerdinger .

