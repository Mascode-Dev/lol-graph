spell:Naafiri_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "NaafiriQ" ;
    lol:spellName "Darkin Daggers" ;
    lol:spellDescription "Naafiri hurls up to two daggers, each inflicting bleed, or each inflicting bonus damage if the target is already bleeding.Packmates leap to attack the first champion or monster hit by this skill." ;
    lol:spellTooltip "Naafiri hurls Darkin-tainted blades, dealing {{ spell.naafiriq:totaldamagefirstcast }} physical damage and inflicting a bleed, dealing {{ spell.naafiriq:totalbleeddamage }} physical damage over {{ spell.naafiriq:bleedduration }} seconds.Naafiri can Recast this Ability. If enemies hit are already bleeding from this Ability, it instead deals the remaining bleed damage plus between {{ spell.naafiriq:totalmindamagesecondcast }} and {{ spell.naafiriq:totalmaxdamagesecondcast }} physical damage, based on their missing Health. If that target was a champion or large monster, Naafiri restores {{ spell.naafiriq:totalhealsecondcast }} Health.Packmates will leap at the first champion or monster hit and attack them for {{ spell.naafirip:packmatetauntduration }} seconds. {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "9/8.5/8/7.5/7" ;
    lol:costBurn "50/60/70/80/90" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "900" ;
    lol:belongsToChampion champ:Naafiri .

spell:Naafiri_W a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "W" ;
    lol:spellId "NaafiriR" ;
    lol:spellName "The Call of the Pack" ;
    lol:spellDescription "Naafiri becomes Untargetable and empowers her pack, spawning additional packmates and gaining increased Move Speed and Attack Damage." ;
    lol:spellTooltip "Naafiri becomes Untargetable for {{ untargetableduration }} second and prepares to hunt, spawning {{ packmatestoadd }} additional Packmates and gaining {{ bonusad }} Attack Damage and {{ movespeedamount*100 }}% Move Speed for {{ duration }} seconds.Packmates become Untargetable and are recalled to Naafiri.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "26/24/22/20/18" ;
    lol:costBurn "60" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "400" ;
    lol:belongsToChampion champ:Naafiri .

spell:Naafiri_E a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "E" ;
    lol:spellId "NaafiriE" ;
    lol:spellName "Eviscerate" ;
    lol:spellDescription "Naafiri dashes and damages enemies in an area around her, recalling her packmates and fully healing them." ;
    lol:spellTooltip "Naafiri surges forward, dealing {{ totaldamagefirstslash }} physical damage, then explodes in a flurry of blades, dealing {{ totaldamagesecondslash }} physical damage.Packmates become Untargetable and are recalled to Naafiri restoring 100% Health. {{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
    lol:cooldownBurn "11/10/9/8/7" ;
    lol:costBurn "40" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "450" ;
    lol:belongsToChampion champ:Naafiri .

spell:Naafiri_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "NaafiriW" ;
    lol:spellName "Hounds' Pursuit" ;
    lol:spellDescription "Naafiri and her packmates dash at a champion, dealing damage. Naafiri reveals nearby enemies if she scores a takedown and can recast this Ability once. The second cast grants a shield." ;
    lol:spellTooltip "Naafiri dashes at an enemy champion, dealing {{ totaldamage }} physical damage and briefly Slowing them. Packmates become Untargetable and dash alongside Naafiri, dealing {{ packmatedamage }} physical damage per Packmate.If Naafiri scores a Takedown within {{ takedownwindow }} seconds she reveals nearby enemies and can recast this Ability once. The second cast grants {{ shieldtotal }} Shield for {{ shieldduration }} seconds.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "110/95/80" ;
