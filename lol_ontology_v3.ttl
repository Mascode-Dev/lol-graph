    lol:spellId "MorganaE" ;
    lol:spellName "Black Shield" ;
    lol:spellDescription "Morgana anoints an ally with a protective barrier of starfire, which absorbs magical damage and disabling effects until it is broken." ;
    lol:spellTooltip "Morgana grants an ally champion {{ totalshieldstrength }} Magic Shield for {{ shieldduration }} seconds. The shield prevents Disabling and Immobilizing effects until it breaks.{{ spellmodifierdescriptionappend }}" ;
