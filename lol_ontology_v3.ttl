champ:Vayne a lol:Champion, owl:NamedIndividual ;
    lol:championId "Vayne" ;
    lol:championKey "67" ;
    lol:championName "Vayne" ;
    lol:championTitle "the Night Hunter" ;
    lol:blurb "Shauna Vayne is a deadly, remorseless Demacian monster hunter, who has dedicated her life to finding and destroying the demon that murdered her family. Armed with a wrist-mounted crossbow and a heart full of vengeance, she is only truly happy when..." ;
    lol:lore "Shauna Vayne is a deadly, remorseless Demacian monster hunter, who has dedicated her life to finding and destroying the demon that murdered her family. Armed with a wrist-mounted crossbow and a heart full of vengeance, she is only truly happy when slaying practitioners or creations of the dark arts, striking from the shadows with a flurry of silver bolts." ;
    lol:adaptiveType "Physical" ;
    lol:lastChanged "V25.17" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
    lol:allyTip "Tumble has many uses, but it cannot pass over walls." ;
    lol:allyTip "Condemn can be used to both pin targets to walls to ensure a kill, or to escape a pursuer." ;
    lol:allyTip "Don't go in first to a large teamfight. Wait for your teammates to initiate." ;
    lol:enemyTip "Vayne is fragile - turn the pressure up on her and she will be forced to play cautiously." ;
    lol:enemyTip "Deny Vayne the opportunity to pin you against walls." ;
