spell:Viktor_R a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "R" ;
    lol:spellId "ViktorR" ;
    lol:spellName "Arcane Storm" ;
    lol:spellDescription "Viktor conjures an Arcane Storm on the field, dealing magic damage and interrupting enemy channels. The storm periodically does magic damage to all nearby enemies and can be redirected by Viktor.Augment: The Arcane Storm moves 25% faster, and whenever champions die after taking damage from it, the storm grows and increases in its duration." ;
    lol:spellTooltip "Viktor conjures an Arcane Storm in an area for {{ stormduration }} seconds, which instantly deals {{ initialburstdamage }} magic damage followed by {{ subsequentburstdamage }} magic damage per second to surrounding enemies. The storm automatically follows champions it has recently damaged.Recast: Viktor can manually move the storm.Upgraded: The storm moves {{ augmentboost*100 }}% faster. If a champion that the storm has damaged dies, the storm increases its size and its duration by {{ tooltip_durationextension }} seconds (up to {{ maxgrowths }} times).{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "3"^^xsd:integer ;
    lol:cooldownBurn "120/100/80" ;
    lol:costBurn "100" ;
    lol:costType " {{ abilityresourcename }}" ;
    lol:rangeBurn "700" ;
    lol:belongsToChampion champ:Viktor .

