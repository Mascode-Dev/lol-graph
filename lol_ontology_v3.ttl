    lol:spellSlot "E" ;
    lol:spellId "BrandE" ;
    lol:spellName "Conflagration" ;
    lol:spellDescription "Brand conjures a powerful blast at his target that spreads to nearby enemies, dealing magic damage. If the target is ablaze, Conflagration's spread is doubled." ;
    lol:spellTooltip "Brand conjures a powerful blast at his target, dealing {{ edamagecalc }} magic damage to surrounding units.If the target is Ablaze, the spread range is doubled.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
