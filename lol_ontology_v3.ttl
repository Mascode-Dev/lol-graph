spell:Briar_Q a lol:ActiveSpell, owl:NamedIndividual ;
    lol:spellSlot "Q" ;
    lol:spellId "BriarQ" ;
    lol:spellName "Head Rush" ;
    lol:spellDescription "Briar leaps to a unit and hits enemies with The Heel Wheel (of Pain), stunning them and breaking their Armor." ;
    lol:spellTooltip "Briar leaps to a target, Stunning it for {{ stunduration }} seconds, dealing {{ totaldamage }} physical damage and reducing {{ shredpercent*100 }}% Armor and Magic Resist for {{ shredduration }} seconds.Briar will stop prioritizing champions if she casts this Ability on a minion or monster during Blood Frenzy.{{ spellmodifierdescriptionappend }}" ;
    lol:maxRank "5"^^xsd:integer ;
