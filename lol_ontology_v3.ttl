champ:Vex a lol:Champion, owl:NamedIndividual ;
    lol:championId "Vex" ;
    lol:championKey "711" ;
    lol:championName "Vex" ;
    lol:championTitle "the Gloomist" ;
    lol:blurb "In the black heart of the Shadow Isles, a lone yordle trudges through the spectral fog, content in its murky misery. With an endless supply of teen angst and a powerful shadow in tow, Vex lives in her own self-made slice of gloom, far from the revolting..." ;
    lol:lore "In the black heart of the Shadow Isles, a lone yordle trudges through the spectral fog, content in its murky misery. With an endless supply of teen angst and a powerful shadow in tow, Vex lives in her own self-made slice of gloom, far from the revolting cheer of the “normie” world. Though she lacks ambition, she is quick to strike down color and happiness, stopping all would-be interlopers with her magical malaise." ;
    lol:adaptiveType "Magic" ;
    lol:lastChanged "V25.09" ;
    lol:costBE "1575"^^xsd:integer ;
    lol:costRP "790"^^xsd:integer ;
